@using HRM.Models
@using HRM.Models.Archives
@model EmployeeProfileViewModel
@{
    ViewData["Title"] = "Employee Profile Page";
}

<div class="max-w-7xl mx-auto">
    <!-- Page Header -->
    <div class="flex justify-between items-end mb-6">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Employee Profile</h1>
            <p class="text-slate-500 text-sm mt-1">View and manage employee information.</p>
        </div>
        <button class="bg-blue-50 text-blue-600 hover:bg-blue-100 border border-blue-200 px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
            Edit Profile
        </button>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- ========================================== -->
        <!-- LEFT COLUMN: Identity & Quick Contact      -->
        <!-- ========================================== -->
        <div class="space-y-6">
            <!-- Profile Identity Card -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex flex-col items-center relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-24 bg-gradient-to-r from-blue-500 to-blue-700 opacity-10"></div>
                <img src="@Model.ProfileImageUrl" alt="@Model.FullName" class="w-24 h-24 rounded-full border-4 border-white shadow-md z-10 object-cover" />
                <h2 class="text-xl font-bold text-slate-800 mt-4">@Model.FullName</h2>
                <p class="text-sm text-blue-600 font-medium mb-1">@Model.Division</p>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800 mb-6">
                    @Model.JobState
                </span>

                <div class="w-full space-y-3 text-sm border-t border-slate-100 pt-4">
                    <div class="flex justify-between">
                        <span class="text-slate-500">Employee No</span>
                        <span class="font-medium text-slate-800">@Model.EmployeeNumber</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-500">SAP Number</span>
                        <span class="font-medium text-slate-800">@Model.SAPNumber</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-500">NID / Passport</span>
                        <span class="font-medium text-slate-800">@Model.NidPassport</span>
                    </div>
                </div>
            </div>

            <!-- Quick Contact Card -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
                <h3 class="font-semibold text-slate-800 mb-4 pb-2 border-b border-slate-100">Contact Details</h3>
                <ul class="space-y-3 text-sm">
                    <li class="flex items-center gap-3">
                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                        <span class="text-slate-700">@Model.Email</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                        <span class="text-slate-700">Mobile: @Model.Mobile</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                        <span class="text-slate-700">Phone: @Model.Phone</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- ========================================== -->
        <!-- RIGHT COLUMN: Detailed Information Cards   -->
        <!-- ========================================== -->
        <div class="lg:col-span-2 space-y-6">

            <!-- Personal Information & Address -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
                <h3 class="font-semibold text-slate-800 mb-4 pb-2 border-b border-slate-100">Personal Information</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-y-4 gap-x-8 text-sm">
                    <div>
                        <p class="text-slate-500 mb-1">Full Name</p>
                        <p class="font-medium text-slate-800">@Model.FullName</p>
                    </div>
                    <div>
                        <p class="text-slate-500 mb-1">Address</p>
                        <p class="font-medium text-slate-800">@Model.Address</p>
                    </div>
                    <div>
                        <p class="text-slate-500 mb-1">Island</p>
                        <p class="font-medium text-slate-800">@Model.Island</p>
                    </div>
                    <div>
                        <p class="text-slate-500 mb-1">Atoll</p>
                        <p class="font-medium text-slate-800">@Model.Atoll</p>
                    </div>
                    <div>
                        <p class="text-slate-500 mb-1">Country</p>
                        <p class="font-medium text-slate-800">@Model.Country</p>
                    </div>
                </div>
            </div>

            <!-- Job Information -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
                <h3 class="font-semibold text-slate-800 mb-4 pb-2 border-b border-slate-100">Job Information</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-y-4 gap-x-6 text-sm">
                    <div>
                        <p class="text-slate-500 mb-1">Organisation</p>
                        <p class="font-medium text-slate-800">@Model.Organisation</p>
                    </div>
                    <div>
                        <p class="text-slate-500 mb-1">Division / Unit</p>
                        <p class="font-medium text-slate-800">@Model.Division</p>
                    </div>
                    <div>
                        <p class="text-slate-500 mb-1">Employee Type</p>
                        <p class="font-medium text-slate-800">@Model.EmployeeType</p>
                    </div>
                    <div>
                        <p class="text-slate-500 mb-1">Active Date</p>
                        <p class="font-medium text-slate-800">@Model.ActiveDate.ToString("dd-MMM-yyyy")</p>
                    </div>
                    <div>
                        <p class="text-slate-500 mb-1">Job State</p>
                        <p class="font-medium text-slate-800">@Model.JobState</p>
                    </div>
                    <div>
                        <p class="text-slate-500 mb-1">Basic Salary</p>
                        <p class="font-medium text-emerald-600">USD @Model.BasicSalary.ToString("N2")</p>
                    </div>
                </div>
            </div>

            <!-- Split Cards: Emergency Contact & Bank Info -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                <!-- Emergency Contact -->
                <div class="bg-rose-50/50 rounded-xl shadow-sm border border-rose-100 p-6">
                    <h3 class="font-semibold text-rose-800 mb-4 pb-2 border-b border-rose-100/50 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
                        Emergency Contact
                    </h3>
                    <div class="space-y-3 text-sm">
                        <div>
                            <p class="text-slate-500 mb-1">Name (Relation)</p>
                            <p class="font-medium text-slate-800">@Model.EmergencyName <span class="text-slate-400 font-normal">(@Model.EmergencyRelation)</span></p>
                        </div>
                        <div>
                            <p class="text-slate-500 mb-1">Mobile</p>
                            <p class="font-medium text-slate-800">@Model.EmergencyMobile</p>
                        </div>
                        <div>
                            <p class="text-slate-500 mb-1">Email</p>
                            <p class="font-medium text-slate-800">@Model.EmergencyEmail</p>
                        </div>
                    </div>
                </div>

                <!-- Bank Info -->
                <div class="bg-slate-50 rounded-xl shadow-sm border border-slate-200 p-6">
                    <h3 class="font-semibold text-slate-800 mb-4 pb-2 border-b border-slate-200 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                        Bank Information
                    </h3>
                    <div class="space-y-4 text-sm">
                        <div class="bg-white p-3 rounded-lg border border-slate-200 shadow-sm">
                            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Bank of My County</p>
                            <p class="font-medium text-slate-800 font-mono tracking-tight">A/C: 1114447778</p>
                        </div>
                        <div class="bg-white p-3 rounded-lg border border-slate-200 shadow-sm">
                            <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Bank of That Country</p>
                            <p class="font-medium text-slate-800 font-mono tracking-tight">A/C: 224455778</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>