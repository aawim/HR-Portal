@inherits LayoutComponentBase
@attribute [Authorize]


@using Microsoft.AspNetCore.Components.Authorization
@using HRM.Services
@using HRM.Components.Shared
@using HRM.Services.Interfaces

@inject ToastService ToastService

@if (Loading)
{
    <div class="flex items-center justify-center min-h-[400px]">
        <div class="text-center">

            <div class="w-12 h-12 border-4 border-blue-600 border-t-transparent rounded-full animate-spin mx-auto"></div>

            <p class="mt-3 text-sm text-slate-500">
                Loading dashboard...
            </p>

        </div>
    </div>
}
else
{
    <div class="space-y-4">

        @if (Header != null)
        {
            @Header
        }
 
        <div class="grid grid-cols-1 xl:grid-cols-12 gap-4">

            <aside class="xl:col-span-2 space-y-4">
                @Left
            </aside>

            <main class="xl:col-span-7 space-y-4">
                @Center
            </main>

            <aside class="xl:col-span-3 space-y-4">
                @Right
            </aside>

        </div>

    </div>
}

@code {

    [Parameter]
    public bool Loading { get; set; }


    [Parameter]
    public RenderFragment? Header { get; set; }

    [Parameter]
    public RenderFragment? Left { get; set; }

    [Parameter]
    public RenderFragment? Center { get; set; }

    [Parameter]
    public RenderFragment? Right { get; set; }

}