@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using HRM.Services
@using HRM.Services.Interfaces
@using HRM.DTOs
@using HRM.Components.Shared

 
@inject UserService UserService
@inject IUserContext UserContext
@inject PortalContext PortalContext

<div class="flex h-screen bg-slate-50">

    <Sidebar />

    <div class="flex flex-col flex-1 overflow-hidden">

        <Topbar @rendermode="RenderMode.InteractiveServer" />

        <main class="flex-1 overflow-x-hidden overflow-y-auto p-4">

           @if (_session is not null)
            {
                <PortalSwitcher InitialOrgId="@_session.OrganisationId"
                                InitialOrgName="@_session.OrganisationName" />
            }



            @Body

        </main>
    </div>
</div>

@code {

    private UserSessionDto? _session;
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _session = await UserContext.GetSessionAsync();

        if (_session != null)
        {
            PortalContext.Initialize(
                _session.OrganisationId,
                _session.OrganisationName,
                _session.CanAccessAdminPortal);
        }
    }

    public class UserSession
    {
        public int UserId { get; set; }
        public int IndividualId { get; set; }
        public int JobId { get; set; }

        public int? UserOrganisationId { get; set; }
        public string OrganisationName { get; set; } = "";

        public event Action? OnChange;

        public void Notify() => OnChange?.Invoke();
    }
}