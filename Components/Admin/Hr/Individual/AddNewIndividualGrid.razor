@page "/individuals/new"
@using Microsoft.EntityFrameworkCore
@using HRM.Models 
@using HRM.Services

@rendermode RenderMode.InteractiveServer
@inject HrmTeContext DbContext

<div class="max-w-4xl mx-auto py-6">

    <div class="mb-16">
        <h2 class="text-2xl font-bold text-slate-800">Add New Individual</h2>
        <p class="text-sm text-slate-500 mt-1">Register a new person in the system via DNR or manual entry.</p>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">

        <div class="border-b border-slate-200 bg-slate-50/50 px-6 pt-4">
            <nav class="-mb-px flex gap-6">
                <button @onclick="() => activeTab = 1" class="pb-4 px-1 text-sm font-bold border-b-2 transition-colors @(activeTab == 1 ? "border-blue-600 text-blue-700" : "border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300")">
                    1. Personal Details
                </button>
                <button @onclick="() => activeTab = 2" class="pb-4 px-1 text-sm font-bold border-b-2 transition-colors @(activeTab == 2 ? "border-blue-600 text-blue-700" : "border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300")">
                    2. Address
                </button>
                <button @onclick="() => activeTab = 3" class="pb-4 px-1 text-sm font-bold border-b-2 transition-colors @(activeTab == 3 ? "border-blue-600 text-blue-700" : "border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300")">
                    3. Contact Info
                </button>
            </nav>
        </div>

        <div class="p-6">
            @if (activeTab == 1)
            {
                <div class="flex p-1 bg-slate-100 rounded-lg w-fit mb-8 border border-slate-200">
                    <button @onclick="() => isMaldivian = true" class="px-6 py-2 rounded-md text-sm font-bold transition-all @(isMaldivian ? "bg-white text-blue-700 shadow-sm" : "text-slate-500 hover:text-slate-700")">
                        Maldivian
                    </button>
                    <button @onclick="() => isMaldivian = false" class="px-6 py-2 rounded-md text-sm font-bold transition-all @(!isMaldivian ? "bg-white text-blue-700 shadow-sm" : "text-slate-500 hover:text-slate-700")">
                        Foreigner
                    </button>
                </div>

                @if (isMaldivian)
                {
                    <div class="bg-blue-50/50 p-5 rounded-xl border border-blue-100 mb-6">
                        <h4 class="text-sm font-bold text-blue-800 mb-2 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            DNR Search Requirements
                        </h4>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">ID Card No. <span class="text-rose-500">*</span></label>
                                <input type="text" @bind="form.IdCardNo" placeholder="AXXXXXX" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Card Serial No. <span class="text-rose-500">*</span></label>
                                <input type="text" @bind="form.CardSerialNo" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">First Name <span class="text-rose-500">*</span></label>
                                <div class="flex gap-2">
                                    <input type="text" @bind="form.FirstName" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                                    <button @onclick="FetchDNR" disabled="@isFetchingDnr" class="shrink-0 h-10 px-4 bg-blue-600 hover:bg-blue-700 disabled:bg-blue-400 text-white rounded-md text-sm font-bold transition-all shadow-sm">
                                        @if (isFetchingDnr)
                                        {
                                            <span>Loading...</span>
                                        }
                                        else
                                        {
                                            <span>Fetch DNR</span>
                                        }
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="border-slate-100 mb-4" />

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Middle Name</label>
                            <input type="text" @bind="form.MiddleName" disabled class="w-full h-10 px-3 text-sm text-slate-500 bg-slate-50 border border-slate-200 rounded-md cursor-not-allowed" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Last Name</label>
                            <input type="text" @bind="form.LastName" disabled class="w-full h-10 px-3 text-sm text-slate-500 bg-slate-50 border border-slate-200 rounded-md cursor-not-allowed" />
                        </div>

                        <div class="hidden md:block"></div>

                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">First Name (Dhivehi)</label>
                            <input type="text" @bind="form.FirstNameDhivehi" disabled dir="rtl" class="w-full h-10 px-3 text-sm text-slate-500 bg-slate-50 border border-slate-200 rounded-md cursor-not-allowed font-dhivehi" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Middle Name (Dhivehi)</label>
                            <input type="text" @bind="form.MiddleNameDhivehi" disabled dir="rtl" class="w-full h-10 px-3 text-sm text-slate-500 bg-slate-50 border border-slate-200 rounded-md cursor-not-allowed font-dhivehi" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Last Name (Dhivehi)</label>
                            <input type="text" @bind="form.LastNameDhivehi" disabled dir="rtl" class="w-full h-10 px-3 text-sm text-slate-500 bg-slate-50 border border-slate-200 rounded-md cursor-not-allowed font-dhivehi" />
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Date of Birth</label>
                            <input type="date" @bind="form.DateOfBirth" disabled class="w-full h-10 px-3 text-sm text-slate-500 bg-slate-50 border border-slate-200 rounded-md cursor-not-allowed" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Gender</label>
                            <input type="text" @bind="form.Gender" disabled class="w-full h-10 px-3 text-sm text-slate-500 bg-slate-50 border border-slate-200 rounded-md cursor-not-allowed" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Country</label>
                            <input type="text" @bind="form.CountryName" disabled class="w-full h-10 px-3 text-sm text-slate-500 bg-slate-50 border border-slate-200 rounded-md cursor-not-allowed" />
                        </div>
                    </div>
                }
                else
                {
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
                        <div class="col-span-1 md:col-span-3 pb-4 mb-2 border-b border-slate-100">
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Passport No. <span class="text-rose-500">*</span></label>
                            <input type="text" @bind="form.PassportNo" class="w-full md:w-1/3 h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">First Name <span class="text-rose-500">*</span></label>
                            <input type="text" @bind="form.FirstName" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Middle Name</label>
                            <input type="text" @bind="form.MiddleName" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Last Name</label>
                            <input type="text" @bind="form.LastName" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">First Name (Dhivehi)</label>
                            <input type="text" @bind="form.FirstNameDhivehi" dir="rtl" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-dhivehi" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Middle Name (Dhivehi)</label>
                            <input type="text" @bind="form.MiddleNameDhivehi" dir="rtl" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-dhivehi" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Last Name (Dhivehi)</label>
                            <input type="text" @bind="form.LastNameDhivehi" dir="rtl" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-dhivehi" />
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Date of Birth</label>
                            <input type="date" @bind="form.DateOfBirth" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Gender</label>
                            <select @bind="form.Gender" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all cursor-pointer">
                                <option value="">-- Select Gender --</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Country</label>
                            <select @bind="form.CountryId" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all cursor-pointer">
                                <option value="0">-- Select Country --</option>
                                @foreach (var c in countries)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                }
            }

            @if (activeTab == 2)
            {
                <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

                    <div class="col-span-1 md:col-span-3 flex items-center justify-between p-4 bg-slate-50 border border-slate-200 rounded-lg mb-2">
                        <div>
                            <h4 class="text-sm font-bold text-slate-800">Permanent Address</h4>
                            <p class="text-xs text-slate-500">Is this the individual's registered permanent address?</p>
                        </div>
                        <div class="flex bg-slate-200 p-1 rounded-md shrink-0">
                            <button @onclick="() => form.IsPermanent = true" type="button" class="px-5 py-1.5 rounded text-sm font-bold transition-all @(form.IsPermanent ? "bg-white text-blue-700 shadow-sm" : "text-slate-500 hover:text-slate-700")">
                                Yes
                            </button>
                            <button @onclick="() => form.IsPermanent = false" type="button" class="px-5 py-1.5 rounded text-sm font-bold transition-all @(!form.IsPermanent ? "bg-white text-blue-700 shadow-sm" : "text-slate-500 hover:text-slate-700")">
                                No
                            </button>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Address Type <span class="text-rose-500">*</span></label>
                        <select @bind="form.AddressType" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all cursor-pointer">
                            <option value="">-- Select Type --</option>
                            <option value="Apartment">Apartment</option>
                            <option value="Office">Office</option>
                            <option value="Shop">Shop</option>
                            <option value="Cafe/Restaurant">Cafe/Restaurant</option>
                            <option value="Garage">Garage</option>
                            <option value="Carpentry">Carpentry</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Location Type <span class="text-rose-500">*</span></label>
                        <select @bind="form.LocationType" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all cursor-pointer">
                            <option value="">-- Select Location --</option>
                            <option value="House">House</option>
                            <option value="Building">Building</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Name (House/Building) <span class="text-rose-500">*</span></label>
                        <input type="text" @bind="form.AddressName" placeholder="e.g. G. Blue House" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Floor</label>
                        <input type="text" @bind="form.Floor" placeholder="e.g. 1st Floor, Apt 1B" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Address Line 1</label>
                        <input type="text" @bind="form.AddressLine1" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Address Line 2</label>
                        <input type="text" @bind="form.AddressLine2" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Road</label>
                        <input type="text" @bind="form.Road" placeholder="e.g. Majeedhee Magu" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Municipality Number</label>
                        <input type="text" @bind="form.MunicipalityNumber" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Post Code</label>
                        <input type="text" @bind="form.PostCode" placeholder="e.g. 20000" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Country</label>
                        <select @bind="form.AddressCountryId" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all cursor-pointer">
                            <option value="0">-- Select Country --</option>
                            @foreach (var c in countries)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>

                    <div class="md:col-span-1">
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Island / Atoll</label>
                        <select @bind="form.IslandId" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all cursor-pointer">
                            <option value="0">-- Select Island --</option>
                            @foreach (var island in islands)
                            {
                                <option value="@island.Id">@island.Name</option>
                            }
                        </select>
                    </div>
                    <div class="md:col-span-1">
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Ward</label>
                        <select @bind="form.WardId" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all cursor-pointer">
                            <option value="0">-- Select Ward --</option>
                            @foreach (var ward in wards)
                            {
                                <option value="@ward.Id">@ward.Name</option>
                            }
                        </select>
                    </div>
                </div>
            }

            @if (activeTab == 3)
            {
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Mobile Number</label>
                        <input type="tel" @bind="form.Mobile" placeholder="+960 XXXXXXX" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Phone Number</label>
                        <input type="tel" @bind="form.Phone" placeholder="+960 XXXXXXX" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Email Address</label>
                        <input type="email" @bind="form.Email" placeholder="example@email.com" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Fax</label>
                        <input type="tel" @bind="form.Fax" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Website</label>
                        <input type="url" @bind="form.Website" placeholder="https://www.example.com" class="w-full h-10 px-3 text-sm text-slate-700 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
                    </div>
                </div>
            }
        </div>

        <div class="p-6 border-t border-slate-100 bg-slate-50/50 flex justify-between items-center">

            <div>
                @if (activeTab > 1)
                {
                    <button @onclick="() => activeTab--" class="px-5 py-2 text-sm font-bold text-slate-600 hover:text-slate-800 transition-colors">
                        &larr; Previous Tab
                    </button>
                }
            </div>

            <div class="flex gap-3">
                @if (activeTab < 3)
                {
                    <button @onclick="() => activeTab++" class="px-6 py-2.5 rounded-md text-sm font-bold text-blue-600 bg-blue-50 hover:bg-blue-100 transition-colors">
                        Next Step &rarr;
                    </button>
                }
                else
                {
                    <button class="px-6 py-2.5 rounded-md text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 shadow-md transition-colors flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Save Individual
                    </button>
                }
            </div>
        </div>

    </div>
</div>

@code {
    private int activeTab = 1;
    private bool isMaldivian = true;
    private bool isFetchingDnr = false;

    private IndividualFormModel form = new();
    private List<DropdownItem> countries = new();

    private List<DropdownItem> islands = new();
    private List<DropdownItem> wards = new();


    protected override async Task OnInitializedAsync()
    {
        // 1. Fetch Countries
        countries = await DbContext.Countries
            .Select(c => new DropdownItem { Id = c.CountryId, Name = c.NameEnglish })
            .ToListAsync();

        // 2. Fetch Islands (Adjust DbSet name as needed)
        islands = await DbContext.Islands
            .Select(i => new DropdownItem { Id = i.IslandId, Name = i.NameEnglish })
            .ToListAsync();

        // 3. Fetch Wards (Adjust DbSet name as needed)
        wards = await DbContext.Wards
            .Select(w => new DropdownItem { Id = w.WardId, Name = w.NameEnglish })
            .ToListAsync();

        form.CountryName = "Maldives";
    }

    private async Task FetchDNR()
    {
        // Simple Validation
        if (string.IsNullOrWhiteSpace(form.IdCardNo) ||
            string.IsNullOrWhiteSpace(form.CardSerialNo) ||
            string.IsNullOrWhiteSpace(form.FirstName))
        {
            // You can implement a Toast/Alert here to warn the user
            return;
        }

        isFetchingDnr = true;
        StateHasChanged();

        try
        {
            // TODO: Implement actual DNR Web Service Call Here!
            // Example: var dnrData = await DnrService.GetPersonAsync(form.IdCardNo, form.CardSerialNo, form.FirstName);

            // SIMULATING NETWORK DELAY
            await Task.Delay(1500);

            // SIMULATING MOCK RESPONSE
            form.MiddleName = "Ahmed";
            form.LastName = "Manik";
            form.FirstNameDhivehi = "އަލީ";
            form.MiddleNameDhivehi = "އަޙްމަދު";
            form.LastNameDhivehi = "މަނިކު";
            form.DateOfBirth = new DateTime(1990, 5, 12);
            form.Gender = "Male";
        }
        finally
        {
            isFetchingDnr = false;
        }
    }

    // --- DTOs & Models ---
