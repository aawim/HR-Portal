    // ---------------------------------------------------------
    // WIZARD STEP 1: SAVE ORGANISATION
    // ---------------------------------------------------------
    private async Task SaveOrganisationDetails()
    {
        isSubmitting = true;
        try
        {
            // Resolve Parent Organisation Search
            if (!string.IsNullOrWhiteSpace(parentOrgSearchText))
            {
                var parent = parentOrganisations.FirstOrDefault(p => p.Name.Equals(parentOrgSearchText, StringComparison.OrdinalIgnoreCase));
                if (parent != null) model.ParentOrganisationBusinessEntityID = parent.Id;
            }

            if (createdOrganisationId == 0)
            {

                var existingOrg = await DbContext.Organisations
                    .FirstOrDefaultAsync(o => o.RegistrationNumber == model.RegistrationNumber);

                if (existingOrg != null)
                {
                    // DUPLICATE FOUND: Grab the existing ID, do NOT insert a new row
                    createdOrganisationId = existingOrg.BusinessEntityID;
                    activeOrganisationRecord = existingOrg;

                    Console.WriteLine($"Organisation already exists! Using existing ID: {createdOrganisationId}");

                    // Optional: If you want to show a UI alert, you could set a boolean here
                    // like 'showDuplicateWarning = true;' before moving to the next tab.
                }
                else
                {
                    // 1. GENERATE THE OPERATION LOG
                    // Let's say Action Type ID 10 = "Create Organisation"
                    int newLogId = await LogService.CreateLogAsync(SharedConfig.OperationLogActionTypes.BUSINESS_ENTITY_CREATE, $"Created new organisation: {model.OrganisationName}");

                    // 2. DYNAMICALLY FETCH THE BUSINESS ENTITY TYPE ID
                    var orgType = await DbContext.BusinessEntityTypes
                        .FirstOrDefaultAsync(t => t.TypeName == "Organisation");

                    if (orgType == null)
                    {
                        Console.WriteLine("❌ ERROR: 'Organisation' type missing from BusinessEntityTypes table!");
                        return; // Stop saving to prevent DB errors
                    }

                    // 2. CREATE THE BASE BUSINESS ENTITY FIRST
                    var newBaseEntity = new BusinessEntity
                        {
                        // You will need to check your BusinessEntityTypes table to see what ID = "Organisation"
                        // I will assume 2 for this example.
                            BusinessEntityTypeId = orgType.BusinessEntityTypeId,

                        // Default state (e.g., 1 = Active / Pending)
                            BusinessEntityStateId = 2,

                            OperationLogId = newLogId,
                            LastStateChangeDate = DateTime.Now
                        };

                    DbContext.BusinessEntities.Add(newBaseEntity);

                    // Save to generate the ID!
                    await DbContext.SaveChangesAsync();
                    int generatedId = newBaseEntity.BusinessEntityID;

                    // 3. CREATE THE ORGANISATION USING THE GENERATED ID
                    activeOrganisationRecord = new Organisation
                        {
                            BusinessEntityID = generatedId, // <-- The crucial link!

                            OrganisationTypeId = (int)model.OrganisationTypeID,
                            RegistrationNumber = model.RegistrationNumber,
                            OrganisationName = model.OrganisationName,
                            OrganisationNameDhivehi = model.OrganisationNameDhivehi,
                            RegistrationDate = model.RegistrationDate,
                            CountryId = (int)model.CountryID,
                            ParentOrganisationBusinessEntityId = model.ParentOrganisationBusinessEntityID
                        };

                    DbContext.Organisations.Add(activeOrganisationRecord);
                    await DbContext.SaveChangesAsync();

                    // UNLOCK TABS
                    createdOrganisationId = generatedId;
                    Console.WriteLine($"Successfully Created BusinessEntity & Organisation with ID: {createdOrganisationId}");
                }

            }
            else
            {
                // UPDATE EXISTING (If they just modified Tab 1)
                activeOrganisationRecord.OrganisationTypeId = (int)model.OrganisationTypeID;
                activeOrganisationRecord.RegistrationNumber = model.RegistrationNumber;
                activeOrganisationRecord.OrganisationName = model.OrganisationName;
                activeOrganisationRecord.OrganisationNameDhivehi = model.OrganisationNameDhivehi;
                activeOrganisationRecord.RegistrationDate = model.RegistrationDate;
                activeOrganisationRecord.CountryId = (int)model.CountryID;
                activeOrganisationRecord.ParentOrganisationBusinessEntityId = model.ParentOrganisationBusinessEntityID;

                DbContext.Organisations.Update(activeOrganisationRecord);
                await DbContext.SaveChangesAsync();
            }

            // AUTO-MOVE TO TAB 2

            await ShowToast("Organisation details saved successfully!", "success");


            activeTab = "Address";
            StateHasChanged();

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving: {ex.InnerException?.Message ?? ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // ---------------------------------------------------------
    // WIZARD STEP 2: SAVE ADDRESSES
    // ---------------------------------------------------------
    private async Task SaveAddressDetails()
    {
        addressErrorMessage = "";
        isSubmitting = true;

        try
        {
            int finalLocationId = 0;

            if (model.CreateNewRegisteredAddress)
            {
                // 1. MANUAL VALIDATION
                if (model.NewAddressInstanceTypeID == null || string.IsNullOrWhiteSpace(model.NewAddressLine1) || model.NewWardID == null)
                {
                    await ShowToast("Please fill in Address Base Type, Address Line 1, and Ward.", "error");
                    isSubmitting = false; return;
                }


                // 2. CREATE ADDRESS BASE
                var newAddressBase = new AddressBasis
                    {
                        AddressLine1 = model.NewAddressLine1,
                        HomeNameDhivehi = model.NewAddressName,
                        AddressLine2 = model.NewAddressLine2,
                        StreetNameEnglish = model.NewRoad,
                        StreetNameDhivehi = null,
                        IsCurrent = true,
                        MunicipalityNumber = model.NewMunicipalityNumber ?? null,
                        PostCode = model.NewPostCode,
                        AddressBaseTypeId = model.NewAddressTypeID ?? 1,
                        WardId = model.NewWardID,
                    };

                DbContext.AddressBases.Add(newAddressBase);
                await DbContext.SaveChangesAsync(); // SAVE #1: Generates AddressBaseID

                // 3. CREATE BASE LOCATION
                var newLocation = new Location
                    {
                        LocationTypeId = model.NewLocationTypeID ?? 1,
                        CountryId = model.NewCountryID ?? 1
                    };
                DbContext.Locations.Add(newLocation);
                await DbContext.SaveChangesAsync(); // SAVE #2: Generates LocationID
                finalLocationId = newLocation.LocationId;

                // 4. CREATE ADDRESS (Island Data)
                var newGeoAddress = new Address
                    {
                        LocationId = finalLocationId,
                        IslandId = model.NewIslandID
                    };
                DbContext.Addresses.Add(newGeoAddress);

                // 5. CREATE ADDRESS INSTANCE (Floor/Suite)
                var newInstance = new AddressInstance
                    {
                        LocationId = finalLocationId,
                        AddressBaseId = newAddressBase.AddressBaseId,
                        Name = model.NewAddressName,
                        Floor = model.NewAddressFloor,
                        AddressInstanceTypeId = null
                    };
                DbContext.AddressInstances.Add(newInstance);

                await DbContext.SaveChangesAsync(); // SAVE #3: Commits Location extensions

                await ShowToast("New address network created successfully!", "success");
            }
            else
            {
                // USER SEARCHED AND SELECTED EXISTING ADDRESS
                if (model.RegisteredAddressId == null || model.RegisteredAddressId == 0)
                {
                    await ShowToast("Please search and select an address.", "error");
                    isSubmitting = false; return;
                }
                finalLocationId = model.RegisteredAddressId.Value;
            }

            // 6. LINK LOCATION TO THE ORGANISATION
            if (finalLocationId > 0 && createdOrganisationId > 0)
            {
                var existingLink = await DbContext.BusinessEntityLocations
                    .FirstOrDefaultAsync(bel => bel.BusinessEntityId == createdOrganisationId
                                             && bel.LocationId == finalLocationId);

                if (existingLink != null)
                {
                    await ShowToast("This Organisation already has this exact location linked.", "warning");
                }
                else
                {
                    var link = new BusinessEntityLocation
                        {
                            BusinessEntityId = createdOrganisationId,
                            LocationId = finalLocationId,
                            BusinessEntityLocationTypeId = 1, // 1 = Default link type
                            IsValid = true
                        };

                    DbContext.BusinessEntityLocations.Add(link);
                    await DbContext.SaveChangesAsync(); // SAVE #4: Creates link

                    await ShowToast("Address successfully linked to Organisation!", "success");
                }
            }

            // Move to Tab 3
            activeTab = "Contact";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"DB Error: {ex.InnerException?.Message ?? ex.Message}");
            await ShowToast("An error occurred. Please check console.", "error");
        }
        finally
        {
            isSubmitting = false;
        }
    }

