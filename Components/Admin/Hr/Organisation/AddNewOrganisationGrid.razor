@page "/add-organisation"
@using HRM.Components.Shared
@using HRM.DTOs
@using HRM.DTOs.Organisation.Address
@using HRM.Models
@using HRM.Models.Archives
@using HRM.Services.Interfaces
@using Microsoft.EntityFrameworkCore

@rendermode InteractiveServer
@inject IOperationLogService LogService
@inject HrmTeContext DbContext


@if (isToastVisible)
{
    <div class="fixed top-4 right-4 z-50 animate-in slide-in-from-top-5 fade-in duration-300 flex items-center gap-3 px-4 py-3 rounded-lg shadow-lg border @(toastType == "success" ? "bg-emerald-50 border-emerald-200 text-emerald-800" : "bg-rose-50 border-rose-200 text-rose-800")">
        @if (toastType == "success")
        {
            <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
        }
        else
        {
            <svg class="w-5 h-5 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        }
        <span class="text-sm font-bold">@toastMessage</span>
        <button @onclick="() => isToastVisible = false" class="ml-2 text-slate-400 hover:text-slate-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
    </div>
}


<div class="max-w-4xl mx-auto bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mt-6">

    <div class="px-6 py-4 border-b border-slate-100 bg-slate-50 flex justify-between items-center">
        <div>
            <h2 class="text-xl font-bold text-slate-800">Add New Organisation</h2>
            <p class="text-sm text-slate-500">
                @(createdOrganisationId == 0 ? "Step 1: Save core details to unlock addresses and contacts." : $"Editing Draft ID: {createdOrganisationId}")
            </p>
        </div>
    </div>

    <div class="flex border-b border-slate-200 bg-slate-50 px-2 pt-2">
        <button type="button" @onclick='() => SetTab("Detail")'
                class="px-6 py-3 text-sm font-bold rounded-t-lg transition-all @(activeTab == "Detail" ? "bg-white text-blue-600 border-t border-l border-r border-slate-200 shadow-[0_4px_0_white]" : "text-slate-500 hover:text-slate-700 hover:bg-slate-100")">
            1. Organisation Detail
        </button>

        <button type="button" @onclick='() => SetTab("Address")'
                disabled="@(createdOrganisationId == 0)"
                class="px-6 py-3 text-sm font-bold rounded-t-lg transition-all @(activeTab == "Address" ? "bg-white text-blue-600 border-t border-l border-r border-slate-200 shadow-[0_4px_0_white]" : "text-slate-500 hover:text-slate-700 hover:bg-slate-100") @(createdOrganisationId == 0 ? "opacity-40 cursor-not-allowed bg-transparent hover:bg-transparent" : "")">
            2. Address
            @if (createdOrganisationId == 0)
            {
                <span class="ml-2 text-[10px] bg-slate-200 text-slate-500 px-1.5 py-0.5 rounded">Locked</span>
            }
        </button>

        <button type="button" @onclick='() => SetTab("Contact")'
                disabled="@(createdOrganisationId == 0)"
                class="px-6 py-3 text-sm font-bold rounded-t-lg transition-all @(activeTab == "Contact" ? "bg-white text-blue-600 border-t border-l border-r border-slate-200 shadow-[0_4px_0_white]" : "text-slate-500 hover:text-slate-700 hover:bg-slate-100") @(createdOrganisationId == 0 ? "opacity-40 cursor-not-allowed bg-transparent hover:bg-transparent" : "")">
            3. Contact
            @if (createdOrganisationId == 0)
            {
                <span class="ml-2 text-[10px] bg-slate-200 text-slate-500 px-1.5 py-0.5 rounded">Locked</span>
            }
        </button>
    </div>

    <div class="p-6 bg-white min-h-[400px]">

        @if (activeTab == "Detail")
        {
            <EditForm Model="@model" OnValidSubmit="SaveOrganisationDetails" OnInvalidSubmit="ShowValidationError">
                <DataAnnotationsValidator />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 animate-in fade-in duration-300 pb-16">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Organisation Type <span class="text-rose-500">*</span></label>
                        <InputSelect @bind-Value="model.OrganisationTypeID" class="w-full p-2.5 border border-slate-300 rounded-lg text-sm bg-white">
                            <option value="">-- Select Type --</option>
                            @foreach (var type in organisationTypes)
                            {
                                <option value="@type.Id">@type.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => model.OrganisationTypeID)" class="text-xs text-rose-500 mt-1" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Registration Number <span class="text-rose-500">*</span></label>
                        <InputText @bind-Value="model.RegistrationNumber" class="w-full p-2.5 border border-slate-300 rounded-lg text-sm" />
                        <ValidationMessage For="@(() => model.RegistrationNumber)" class="text-xs text-rose-500 mt-1" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Organisation Name <span class="text-rose-500">*</span></label>
                        <InputText @bind-Value="model.OrganisationName" class="w-full p-2.5 border border-slate-300 rounded-lg text-sm" />
                        <ValidationMessage For="@(() => model.OrganisationName)" class="text-xs text-rose-500 mt-1" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Name In Dhivehi</label>
                        <InputText @bind-Value="model.OrganisationNameDhivehi" class="w-full p-2.5 border border-slate-300 rounded-lg text-sm font-mv-boli text-right" dir="rtl" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Registration Date</label>
                        <InputDate @bind-Value="model.RegistrationDate" class="w-full p-2.5 border border-slate-300 rounded-lg text-sm" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Country <span class="text-rose-500">*</span></label>
                        <InputSelect @bind-Value="model.CountryID" class="w-full p-2.5 border border-slate-300 rounded-lg text-sm bg-white">
                            <option value="">-- Select Country --</option>
                            @foreach (var country in countries)
                            {
                                <option value="@country.Id">@country.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => model.CountryID)" class="text-xs text-rose-500 mt-1" />
                    </div>

                    <div class="col-span-1 md:col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Parent Organisation</label>
                        <input type="text" list="parentOrgs" @bind="parentOrgSearchText" class="w-full p-2.5 border border-slate-300 rounded-lg text-sm" />
                        <datalist id="parentOrgs">
                            @foreach (var org in parentOrganisations)
                            {
                                <option value="@org.Name">@org.RegistrationNumber</option>
                            }
                        </datalist>
                    </div>
                </div>

                <div class="absolute bottom-0 left-0 right-0 px-6 py-4 border-t border-slate-200 bg-slate-50 flex justify-between items-center rounded-b-xl">
                    <ValidationSummary class="text-rose-500 text-xs font-bold list-none p-0 m-0" />
                    <button type="submit" disabled="@isSubmitting" class="px-6 py-2.5 text-sm font-bold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-sm disabled:opacity-50 ml-auto flex items-center gap-2">
                        @(isSubmitting ? "Saving..." : (createdOrganisationId > 0 ? "Update Details" : "Save & Continue to Address"))
                        @if (createdOrganisationId == 0)
                        {
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        }
                    </button>
                </div>
            </EditForm>
        }

        @if (activeTab == "Address")
        {
            <EditForm Model="@model" OnValidSubmit="SaveAddressDetails" Context="addressContext">
                <div class="space-y-6 animate-in fade-in duration-300 pb-24">

                    <div class="flex gap-4 p-1 bg-slate-100 rounded-lg w-fit">
                        <button type="button" @onclick="() => SetAddressMode(false)"
                                class="px-4 py-2 text-sm font-bold rounded-md transition-all @(!model.CreateNewRegisteredAddress ? "bg-white text-blue-600 shadow-sm" : "text-slate-500 hover:text-slate-700")">
                            Search Existing Address
                        </button>
                        <button type="button" @onclick="() => SetAddressMode(true)"
                                class="px-4 py-2 text-sm font-bold rounded-md transition-all @(model.CreateNewRegisteredAddress ? "bg-white text-blue-600 shadow-sm" : "text-slate-500 hover:text-slate-700")">
                            + Create New Address
                        </button>
                    </div>

                    @if (!model.CreateNewRegisteredAddress)
                    {
                        <div class="p-4 bg-slate-50 rounded-lg border border-slate-200 animate-in fade-in">
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Search Registered Address</label>

                            @if (model.RegisteredAddressId > 0 && selectedRegisteredAddress != null)
                            {
                                <div class="p-3 bg-white border border-emerald-300 rounded-lg flex justify-between items-center shadow-sm">
                                    <div>
                                        <p class="text-sm font-bold text-slate-800">@selectedRegisteredAddress.HouseBuilding, @selectedRegisteredAddress.Address</p>
                                        <p class="text-[10px] text-slate-500 font-bold uppercase mt-0.5">Type: @selectedRegisteredAddress.AddressType</p>
                                    </div>
                                    <button type="button" @onclick="ClearRegisteredAddress" class="text-xs font-bold px-3 py-1.5 bg-rose-50 text-rose-600 rounded hover:bg-rose-100 transition-colors">
                                        Change
                                    </button>
                                </div>
                            }
                            else
                            {
                                <input type="text" @bind="addressSearchQuery" @bind:event="oninput" @onkeyup="PerformAddressSearch"
                                       placeholder="Search by address, street, or postcode..."
                                       class="w-full p-2.5 border border-slate-300 rounded-lg text-sm mb-2" />

                                @if (isSearchingAddresses)
                                {
                                    <p class="text-xs text-blue-500 font-bold mt-2 animate-pulse">Searching database...</p>
                                }
                                else if (addressSearchQuery.Length >= 2 && !addressSearchResults.Any())
                                {
                                    <div class="mt-4 p-6 bg-slate-50 border border-dashed border-slate-300 rounded-lg text-center animate-in fade-in">
                                        <p class="text-sm text-slate-500 mb-3">No matching addresses found for "<span class="font-bold">@addressSearchQuery</span>".</p>
                                        <button type="button" @onclick="() => SetAddressMode(true)" class="px-4 py-2 bg-blue-600 text-white text-sm font-bold rounded-lg hover:bg-blue-700 transition-colors shadow-sm">
                                            + Add Address Manually
                                        </button>
                                    </div>
                                }
                                else if (addressSearchResults.Any())
                                {
                                    <div class="mt-3 bg-white border border-slate-200 rounded-lg overflow-hidden shadow-sm animate-in fade-in">
                                        <table class="w-full text-left text-xs">
                                            <thead class="bg-slate-100 text-slate-600 border-b border-slate-200">
                                                <tr>
                                                    <th class="p-2 font-bold">Address Type</th>
                                                    <th class="p-2 font-bold">Address</th>
                                                    <th class="p-2 font-bold text-center">Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var addr in addressSearchResults)
                                                {
                                                    <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors">
                                                        <td class="p-2 text-slate-600">@addr.AddressType</td>
                                                        <td class="p-2 font-medium text-slate-800">@addr.HouseBuilding, @addr.Address</td>
                                                        <td class="p-2 text-center">
                                                            <button type="button" @onclick="() => SelectAddress(addr)" class="px-3 py-1 bg-blue-100 text-blue-700 rounded font-bold hover:bg-blue-200 transition-colors">
                                                                Select
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                        <div class="p-3 bg-slate-50 border-t border-slate-200 text-center">
                                            <p class="text-xs text-slate-500 inline-block mr-2">Didn't find it?</p>
                                            <button type="button" @onclick="() => SetAddressMode(true)" class="text-xs font-bold text-blue-600 hover:underline">Add it manually</button>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <div class="p-5 bg-blue-50/50 rounded-lg border border-blue-100 animate-in fade-in">
                            <h3 class="text-sm font-bold text-blue-800 mb-4 pb-2 border-b border-blue-100">New Address Details</h3>

                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

                                @*  <div>
                                    <label class="block text-[11px] font-bold text-slate-500 mb-1">Address Type <span class="text-rose-500">*</span></label>
                                    <InputSelect @bind-Value="model.NewAddressInstanceTypeID" class="w-full p-2 border border-slate-300 rounded-lg text-sm bg-white">
                                        <option value="">-- Select Type --</option>
                                        @foreach (var addrType in addressInstanceTypes)
                                        {
                                            <option value="@addrType.Id">@addrType.Name</option>
                                        }
                                    </InputSelect>
                                </div> *@

                                <div>
                                    <label class="block text-[11px] font-bold text-slate-500 mb-1">Address Type <span class="text-rose-500">*</span></label>
                                    <InputSelect @bind-Value="model.NewAddressInstanceTypeID" class="w-full p-2 border border-slate-300 rounded-lg text-sm bg-white">
                                        <option value="">-- Select Type --</option>
                                        @foreach (var addrType in addressInstanceTypes)
                                        {
                                            <option value="@addrType.Id">@addrType.Name</option>
                                        }
                                    </InputSelect>
                                </div>

                                <div>
                                    <label class="block text-[11px] font-bold text-slate-500 mb-1">Location Type</label>
                                    <InputSelect @bind-Value="model.NewLocationTypeID" class="w-full p-2 border border-slate-300 rounded-lg text-sm bg-white">
                                        <option value="">-- Select Type --</option>
                                        @foreach (var addrType in addressLocationTypes)
                                        {
                                            <option value="@addrType.Id">@addrType.Name</option>
                                        }
                                    </InputSelect>
                                </div>

                                <div>
                                    <label class="block text-[11px] font-bold text-slate-500 mb-1">Address Line 1 <span class="text-rose-500">*</span></label>
                                    <InputText @bind-Value="model.NewAddressLine1" class="w-full p-2 border border-slate-300 rounded-lg text-sm" />
                                </div>

                                <div>
                                    <label class="block text-[11px] font-bold text-slate-500 mb-1">House / Building Name</label>
                                    <InputText @bind-Value="model.NewAddressName" class="w-full p-2 border border-slate-300 rounded-lg text-sm" />
                                </div>

                                <div>
                                    <label class="block text-[11px] font-bold text-slate-500 mb-1">Floor / Suite</label>
                                    <InputText @bind-Value="model.NewAddressFloor" class="w-full p-2 border border-slate-300 rounded-lg text-sm" />
                                </div>

                                <div>
                                    <label class="block text-[11px] font-bold text-slate-500 mb-1">Road / Street Name</label>
                                    <InputText @bind-Value="model.NewRoad" class="w-full p-2 border border-slate-300 rounded-lg text-sm" />
                                </div>

                                <div>
                                    <label class="block text-[11px] font-bold text-slate-500 mb-1">Country</label>
                                    <InputSelect @bind-Value="model.NewCountryID" class="w-full p-2 border border-slate-300 rounded-lg text-sm bg-white">
                                        <option value="">-- Select Country --</option>
                                        @foreach (var c in countries)
                                        {
                                            <option value="@c.Id">@c.Name</option>
                                        }
                                    </InputSelect>
                                </div>

                                <div>
                                    <label class="block text-[11px] font-bold text-slate-500 mb-1">Atoll</label>

                                    <InputSelect Value="model.NewAtollID"
                                                 ValueChanged="@((int? val) => OnAtollChanged(val))"
                                                 ValueExpression="@(() => model.NewAtollID)"
                                                 class="w-full p-2 border border-slate-300 rounded-lg text-sm bg-white focus:ring-2 focus:ring-blue-500">
                                        <option value="">-- Select Atoll --</option>
                                        @foreach (var atoll in atolls)
                                        {
                                            <option value="@atoll.AtollId">@atoll.NameEnglish</option>
                                        }
                                    </InputSelect>
                                </div>

                                <div>
                                    <label class="block text-[11px] font-bold text-slate-500 mb-1">Island</label>

                                    <InputSelect Value="model.NewIslandID"
                                                 ValueChanged="@((int? val) => OnIslandChanged(val))"
                                                 ValueExpression="@(() => model.NewIslandID)"
                                                 disabled="@(model.NewAtollID == null)"
                                                 class="w-full p-2 border border-slate-300 rounded-lg text-sm bg-white focus:ring-2 focus:ring-blue-500 disabled:bg-slate-100 disabled:text-slate-400">
                                        <option value="">-- Select Island --</option>
                                        @foreach (var island in islands)
                                        {
                                            <option value="@island.IslandId">@island.NameEnglish</option>
                                        }
                                    </InputSelect>
                                </div>

                                <div>
                                    <label class="block text-[11px] font-bold text-slate-500 mb-1">Ward <span class="text-rose-500">*</span></label>

                                    <InputSelect @bind-Value="model.NewWardID"
                                                 disabled="@(model.NewIslandID == null)"
                                                 class="w-full p-2 border border-slate-300 rounded-lg text-sm bg-white focus:ring-2 focus:ring-blue-500 disabled:bg-slate-100 disabled:text-slate-400">
                                        <option value="">-- Select Ward --</option>
                                        @foreach (var ward in wards)
                                        {
                                            <option value="@ward.WardId">@ward.NameEnglish</option>
                                        }
                                    </InputSelect>
                                </div>

                                <div>
                                    <label class="block text-[11px] font-bold text-slate-500 mb-1">Post Code</label>
                                    <InputText @bind-Value="model.NewPostCode" class="w-full p-2 border border-slate-300 rounded-lg text-sm" />
                                </div>

                                <div>
                                    <label class="block text-[11px] font-bold text-slate-500 mb-1">Municipality No.</label>
                                    <InputText @bind-Value="model.NewMunicipalityNumber" class="w-full p-2 border border-slate-300 rounded-lg text-sm" />
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="absolute bottom-0 left-0 right-0 px-6 py-4 border-t border-slate-200 bg-slate-50 flex justify-between items-center rounded-b-xl z-10">
                    <div class="text-rose-500 text-xs font-bold max-w-md">
                        @if (!string.IsNullOrEmpty(addressErrorMessage))
                        {
                            <p>@addressErrorMessage</p>
                        }
                    </div>
                    <button type="submit" disabled="@isSubmitting" class="px-6 py-2.5 text-sm font-bold text-white bg-blue-600 rounded-lg hover:bg-blue-700 flex items-center gap-2">
                        @(isSubmitting ? "Saving..." : "Save Address & Continue")
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>
                </div>

            </EditForm>
        }

        @if (activeTab == "Contact")
        {
            <EditForm Model="@model" OnValidSubmit="SaveContactDetails" Context="contactContext">
                <div class="space-y-6 animate-in fade-in duration-300 pb-24">
                    <div class="p-6 bg-slate-50 rounded-lg border border-slate-200">
                        <h3 class="text-sm font-bold text-slate-800 mb-6 pb-2 border-b border-slate-200">Organisation Contact Details</h3>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                            @foreach (var contactField in model.DynamicContacts)
                            {
                                <div>
                                    <label class="block text-xs font-bold text-slate-500 mb-1">@contactField.TypeName</label>
                                    <InputText @bind-Value="contactField.Value"
                                               placeholder="@contactField.Format"
                                               class="w-full p-2.5 border border-slate-300 rounded-lg text-sm bg-white" />
                                </div>
                            }

                        </div>
                    </div>
                </div>

                <div class="absolute bottom-0 left-0 right-0 px-6 py-4 border-t border-slate-200 bg-slate-50 flex justify-end gap-3 rounded-b-xl z-10">
                    <button type="submit" disabled="@isSubmitting" class="px-6 py-2.5 text-sm font-bold text-white bg-emerald-600 rounded-lg hover:bg-emerald-700 flex items-center gap-2">
                        @(isSubmitting ? "Finalizing..." : "Complete Registration")
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    </button>
                </div>
            </EditForm>
        }

    </div>
</div>

@code {
    private CreateOrganisationDto model = new();
    private string activeTab = "Detail";
    private bool isSubmitting = false;
    private string addressErrorMessage = "";

    // Address Search Variables
    private string addressSearchQuery = "";
    private bool isSearchingAddresses = false;
    private List<AddressSearchResultDto> addressSearchResults = new();
    private AddressSearchResultDto? selectedRegisteredAddress = null;




    // NEW: Tracks if the core organisation was saved. 0 = Unsaved (Locks Tabs)
    private int createdOrganisationId = 0;
    private Organisation? activeOrganisationRecord;

    private string parentOrgSearchText = "";
    private List<DropdownItem> organisationTypes = new();
    private List<DropdownItem> countries = new();

    private List<Atoll> atolls = new();
    private List<Island> islands = new();
    private List<Ward> wards = new();
    private List<DropdownItem> parentOrganisations = new();
    private List<DropdownItem> addressLocationTypes = new();
    private List<DropdownItem> addressInstanceTypes = new();
    private List<DropdownItem> addressBaseTypes = new();

    // ==========================================
    // TOAST NOTIFICATION LOGIC
    // ==========================================
    private bool isToastVisible = false;
    private string toastMessage = "";
    private string toastType = "success"; // "success" or "error"

    private async Task ShowToast(string message, string type = "success")
    {
        toastMessage = message;
        toastType = type;
        isToastVisible = true;
        StateHasChanged();

        // Auto-hide after 4 seconds
        await Task.Delay(4000);
        isToastVisible = false;
        StateHasChanged();
    }


    protected override async Task OnInitializedAsync()
    {

        // Load your dropdowns
        organisationTypes = await DbContext.OrganisationTypes
            .Select(t => new DropdownItem { Id = t.OrganisationTypeId, Name = t.TypeName })
            .ToListAsync();

        countries = await DbContext.Countries
            .Select(c => new DropdownItem { Id = c.CountryId, Name = c.NameEnglish })
            .ToListAsync();


        atolls = await DbContext.Atolls
       .Select(c => new Atoll { AtollId = c.AtollId, NameEnglish = c.NameEnglish })
       .ToListAsync();

        islands = await DbContext.Islands
       .Select(c => new Island { IslandId = c.IslandId, NameEnglish = c.NameEnglish })
       .ToListAsync();

        wards = await DbContext.Wards
       .Select(c => new Ward { WardId = c.WardId, NameEnglish = c.NameEnglish })
       .ToListAsync();


        parentOrganisations = await DbContext.Organisations
            .Select(o => new DropdownItem { Id = o.BusinessEntityID, Name = o.OrganisationName ?? "", RegistrationNumber = o.RegistrationNumber ?? "" })
            .ToListAsync();

        // Fetch Address Base Types (e.g., Permanent, Current, Mailing)
        addressLocationTypes = await DbContext.AddressBaseTypes
            .Select(t => new DropdownItem { Id = t.AddressBaseTypeId, Name = t.TypeName })
            .OrderBy(t => t.Name)
            .ToListAsync();

        addressInstanceTypes = await DbContext.AddressInstanceTypes
          .Select(t => new DropdownItem { Id = t.AddressInstanceTypeId, Name = t.TypeName })
          .OrderBy(t => t.Name)
          .ToListAsync();

        var defaultCountry = countries.FirstOrDefault(c => c.Name.Equals("Maldives"));

        // var maldives = countries.FirstOrDefault(c => c.Name.Equals("Maldives"));
        if (defaultCountry != null)
        {
            model.NewCountryID = defaultCountry.Id;
        }


        // DYNAMICALLY BUILD THE CONTACT FORM
        // ==========================================
        var contactTypes = await DbContext.ContactInformationTypes
            .OrderBy(c => c.ContactInformationTypeId)
            .ToListAsync();

        model.DynamicContacts = contactTypes
            .Select(t => new HRM.DTOs.ContactField
                {
                    TypeID = t.ContactInformationTypeId,
                    TypeName = t.TypeName,
                    Format = t.Format
                })
            .ToList();

    }



    private async Task OnAtollChanged(int? selectedAtollId)
    {
        // Update the model manually
        model.NewAtollID = selectedAtollId;

        // Reset the Island selection and clear the list
        model.NewIslandID = null;
        islands.Clear();

        if (selectedAtollId.HasValue && selectedAtollId.Value > 0)
        {
            // Fetch islands for this specific Atoll
            islands = await DbContext.Islands
                .Where(i => i.AtollId == selectedAtollId.Value)
                .OrderBy(i => i.NameEnglish)
                .ToListAsync();
        }

        // Force UI refresh
        StateHasChanged();
    }

    private async Task OnIslandChanged(int? selectedIslandId)
    {
        model.NewIslandID = selectedIslandId;

        // Reset Ward
        model.NewWardID = null;
        wards.Clear();

        if (selectedIslandId.HasValue && selectedIslandId.Value > 0)
        {
            wards = await DbContext.Wards
                .Where(w => w.IslandId == selectedIslandId.Value)
                .OrderBy(w => w.NameEnglish)
                .ToListAsync();
        }

        StateHasChanged();
    }
