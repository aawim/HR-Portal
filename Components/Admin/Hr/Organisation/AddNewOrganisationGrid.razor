    // Triggered when the user types in the search box
    private async Task PerformAddressSearch()
    {
        if (string.IsNullOrWhiteSpace(addressSearchQuery) || addressSearchQuery.Length < 2)
        {
            addressSearchResults.Clear();
            return;
        }

        isSearchingAddresses = true;

        // Use Entity Framework to search the 4 columns
        addressSearchResults = await (from a in DbContext.AddressBases

                                          // Search condition checking all 4 columns
                                      where a.AddressLine1.Contains(addressSearchQuery) ||
                                            a.AddressLine2.Contains(addressSearchQuery) ||
                                            a.StreetNameEnglish.Contains(addressSearchQuery) ||
                                            a.PostCode.Contains(addressSearchQuery)

                                      // Join to get the Address Type Name
                                      join t in DbContext.AddressBaseTypes on a.AddressBaseTypeId equals t.AddressBaseTypeId into tJoin
                                      from t in tJoin.DefaultIfEmpty()

                                      select new AddressSearchResultDto
                                          {
                                              AddressBaseID = a.AddressBaseId,
                                              AddressType = t != null ? t.TypeName : "Unknown",
                                              Address = a.AddressLine1 + " " + a.StreetNameEnglish,
                                              HouseBuilding = a.HomeNameDhivehi ?? a.AddressLine2 ?? "",
                                              LocationType = "-" // Replace with actual LocationType join if you have that table
                                          })
                                      .Take(15) // Limit to 15 results for UI performance
                                      .ToListAsync();

        isSearchingAddresses = false;
    }

    // Triggered when the user clicks "Select" in the table
    private void SelectAddress(AddressSearchResultDto addr)
    {
        model.RegisteredAddressId = addr.AddressBaseID;
        selectedRegisteredAddress = addr;

        // Clear the search UI
        addressSearchResults.Clear();
        addressSearchQuery = "";
    }

    // Triggered if the user wants to clear their selection and search again
    private void ClearRegisteredAddress()
    {
        model.RegisteredAddressId = null;
        selectedRegisteredAddress = null;
    }

    // ---------------------------------------------------------
    // WIZARD STEP 3: SAVE CONTACTS
    // ---------------------------------------------------------
    private async Task SaveContactDetails()
    {
        isSubmitting = true;
        try
        {
            if (createdOrganisationId == 0)
            {
                await ShowToast("Error: Missing Organisation ID. Please go back to Step 1.", "error");
                isSubmitting = false; return;
            }

            var contactsToSave = new List<BussinessEntityContactInformation>();

            // Loop through our dynamically generated UI fields
            foreach (var field in model.DynamicContacts)
            {
                // Only process fields the user actually typed in
                if (!string.IsNullOrWhiteSpace(field.Value))
                {
                    // Check for duplicates
                    bool alreadyExists = await DbContext.BussinessEntityContactInformations.AnyAsync(c =>
                        c.BussinessEntityId == createdOrganisationId &&
                        c.ContactInformationTypeId == field.TypeID &&
                        c.Value == field.Value);

                    if (!alreadyExists)
                    {
                        contactsToSave.Add(new BussinessEntityContactInformation
                            {
                                BussinessEntityId = createdOrganisationId,
                                ContactInformationTypeId = field.TypeID,
                                Value = field.Value,
                                IsValid = true
                            });
                    }
                }
            }

            // Save all new contacts in one transaction
            if (contactsToSave.Any())
            {
                DbContext.BussinessEntityContactInformations.AddRange(contactsToSave);
                await DbContext.SaveChangesAsync();

                await ShowToast("Organisation fully registered with contacts!", "success");
            }
            else
            {
                await ShowToast("Wizard Complete! (No new contacts added)", "success");
            }

            // ==========================================
            // WIZARD COMPLETE: Add your redirect here!
            // ==========================================
            // NavigationManager.NavigateTo("/organisations");

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Contact Save Error: {ex.InnerException?.Message ?? ex.Message}");
            await ShowToast("An error occurred while saving contacts.", "error");
        }
        finally
        {
            isSubmitting = false;
        }
    }

