@using HRM.Components.Shared
@using HRM.DTOs
@using HRM.Models
@using HRM.Models.Archives
@using HRM.Services.Interfaces
@using Microsoft.EntityFrameworkCore

@inject IOperationLogService LogService
@inject HrmTeContext DbContext

<div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[60] transition-opacity duration-300 ease-in-out @(IsOpen ? "opacity-100 pointer-events-auto" : "opacity-0 pointer-events-none")"
@onclick="ClosePanel"></div>

<div class="fixed inset-y-0 right-0 z-[70] bg-white shadow-2xl flex flex-col transition-all duration-500 ease-in-out transform @(IsOpen ? "translate-x-0" : "translate-x-full") @(isExpanded ? "w-[95vw]" : "w-full max-w-5xl")">

    @if (Team != null)
    {
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 bg-slate-50 shrink-0">
            <div>
                <div class="flex items-center gap-3 mb-1">
                    <div class="w-8 h-8 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center shrink-0">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-800">@Team.Name</h3>
                </div>
                <p class="text-xs text-slate-500 font-medium ml-11">
                    @(string.IsNullOrWhiteSpace(Team.Name) ? "General Team" : Team.Name) 
                    @* • @(string.IsNullOrWhiteSpace(Team.DivisionName) ? "No Division" : Team.DivisionName) *@
                </p>
            </div>

            <div class="flex items-center gap-2">
                <button @onclick="ToggleExpand" title="@(isExpanded ? "Collapse Panel" : "Expand Panel")" class="text-slate-400 hover:text-indigo-600 p-2 rounded-full hover:bg-indigo-50 transition-colors">
                    @if (isExpanded)
                    {
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" transform="rotate(180 12 12)"></path></svg>
                    }
                    else
                    {
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path></svg>
                    }
                </button>
                <button @onclick="ClosePanel" title="Close Team Details" class="text-slate-400 hover:text-rose-500 p-2 rounded-full hover:bg-rose-50 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
        </div>

        <div class="flex flex-1 overflow-hidden">

            <div class="w-48 bg-slate-50 border-r border-slate-100 overflow-y-auto py-4 shrink-0">
                <nav class="flex flex-col gap-1 px-3">
                    @foreach (var tab in panelTabs)
                    {
                        <button @onclick="() => SelectTab(tab.Name)" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-bold transition-all @(activeTab == tab.Name ? "bg-white text-indigo-700 shadow-sm border border-slate-200" : "text-slate-500 hover:bg-slate-200/50 hover:text-slate-800 border border-transparent")">
                            @((MarkupString)tab.IconSvg)
                            @tab.Name
                        </button>
                    }
                </nav>
            </div>

            <div class="flex-1 bg-white overflow-y-auto p-6 custom-scrollbar">

                @if (activeTab == "Summary")
                {
                    <div class="space-y-6 animate-in fade-in duration-300">
                        <h4 class="text-lg font-bold text-slate-800">Team Summary</h4>
                        <p class="text-sm text-slate-500">Overview metrics and configuration details for this team.</p>
                    </div>
                    <div class="space-y-8 animate-in fade-in duration-300 pb-10">

                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div class="bg-indigo-50 p-5 rounded-xl border border-indigo-100 flex flex-col justify-center relative overflow-hidden">
                                <div class="absolute -right-4 -bottom-4 text-indigo-500/10">
                                    <svg class="w-24 h-24" fill="currentColor" viewBox="0 0 24 24"><path d="M12 4a4 4 0 100 8 4 4 0 000-8zM6 8a2 2 0 11-4 0 2 2 0 014 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM5.304 16.19a.844.844 0 01-.277-.71 5 5 0 019.947 0 .843.843 0 01-.277.71A6.975 6.975 0 0112 18a6.974 6.974 0 01-6.696-1.81zM19.745 15.66a8.964 8.964 0 00-2.023-2.023 5.002 5.002 0 012.277 4.293c.026.524-.265.986-.71 1.22a6.974 6.974 0 01-1.32.548 6.002 6.002 0 002.05-3.805l-.274-.233z"></path></svg>
                                </div>
                                <span class="text-[10px] font-bold text-indigo-600 uppercase tracking-wider mb-1 z-10">Currently Active</span>
                                <span class="text-4xl font-black text-indigo-800 z-10">@activeStaffCount</span>
                            </div>

                            <div class="bg-slate-50 p-5 rounded-xl border border-slate-200 flex flex-col justify-center relative overflow-hidden">
                                <span class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1 z-10">Former Staff</span>
                                <span class="text-4xl font-black text-slate-700 z-10">@pastStaffCount</span>
                            </div>

                            <div class="bg-slate-50 p-5 rounded-xl border border-slate-200 flex flex-col justify-center relative overflow-hidden">
                                <span class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1 z-10">Total Ever Assigned</span>
                                <span class="text-4xl font-black text-slate-700 z-10">@(activeStaffCount + pastStaffCount)</span>
                            </div>
                        </div>

                        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
                            <h5 class="text-sm font-bold text-slate-800 mb-6 border-b border-slate-100 pb-2">Staffing History Timeline</h5>

                            @if (isLoadingSummary)
                            {
                                <div class="flex justify-center items-center py-8 text-slate-400">
                                    <svg class="animate-spin h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                    Generating timeline...
                                </div>
                            }
                            else if (!timelineEvents.Any())
                            {
                                <div class="text-center py-8 text-slate-400 italic text-sm">No historical staffing data available.</div>
                            }
                            else
                            {
                                <div class="relative border-l-2 border-slate-100 ml-4 space-y-8 pb-4">
                                    @foreach (var ev in timelineEvents)
                                    {
                                        <div class="relative pl-6">
                                            <div class="absolute -left-[9px] top-1 w-4 h-4 rounded-full bg-white border-[3px] @(ev.ActiveStaffCount > 0 ? "border-indigo-500" : "border-slate-300")"></div>

                                            <div class="bg-slate-50 border border-slate-100 rounded-lg p-4 transition-all hover:shadow-sm">
                                                <div class="flex justify-between items-center mb-3">
                                                    <span class="font-black text-slate-700">@ev.MonthYear.ToString("MMMM yyyy")</span>
                                                    <span class="bg-white border border-slate-200 text-slate-700 text-xs font-bold px-3 py-1 rounded-full shadow-sm">
                                                        @ev.ActiveStaffCount Active Staff
                                                    </span>
                                                </div>

                                                <div class="flex gap-4 text-xs font-bold">
                                                    @if (ev.Joins > 0)
                                                    {
                                                        <span class="text-emerald-600 bg-emerald-50 px-2 py-1 rounded flex items-center gap-1">
                                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                                                            @ev.Joins Joined
                                                        </span>
                                                    }
                                                    @if (ev.Leaves > 0)
                                                    {
                                                        <span class="text-rose-600 bg-rose-50 px-2 py-1 rounded flex items-center gap-1">
                                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path></svg>
                                                            @ev.Leaves Left
                                                        </span>
                                                    }
                                                    @if (ev.Joins == 0 && ev.Leaves == 0 && ev == timelineEvents.Last())
                                                    {
                                                        <span class="text-slate-500 bg-slate-100 px-2 py-1 rounded">Team Created</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (activeTab == "Staffs")
                {
                    <div class="space-y-4 animate-in fade-in duration-300">
                        <div class="flex justify-between items-end border-b border-slate-100 pb-2">
                            <div>
                                <h4 class="text-lg font-bold text-slate-800">Assigned Staff</h4>
                                <p class="text-xs text-slate-500 mt-1">Manage employees currently assigned to this team.</p>
                            </div>
                            <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-bold shadow-sm transition-colors flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                                Assign Staff
                            </button>
                        </div>

                        <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-x-auto">
                            <table class="w-full text-left border-collapse whitespace-nowrap text-sm">
                                <thead class="bg-slate-50 border-b border-slate-200">
                                    <tr>
                                        <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs w-12">#</th>
                                        <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs">Name</th>
                                        <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs">Employee No.</th>
                                        <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs">Effective Start Date</th>
                                        <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100">
                                    @if (isLoadingStaff)
                                    {
                                        <tr>
                                            <td colspan="5" class="py-8 text-center text-slate-500">
                                                <div class="flex justify-center items-center gap-2">
                                                    <svg class="animate-spin h-5 w-5 text-indigo-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                                    Loading staff members...
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                    else if (!teamStaff.Any())
                                    {
                                        <tr>
                                            <td colspan="5" class="py-8 text-center text-slate-500 italic">No staff members assigned to this team yet.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @for (int i = 0; i < teamStaff.Count; i++)
                                        {
                                            var staff = teamStaff[i];
                                            <tr class="hover:bg-slate-50 transition-colors">
                                                <td class="py-3 px-4 text-slate-400 font-medium">@(i + 1)</td>
                                                <td class="py-3 px-4">
                                                    <div class="flex items-center gap-3">
                                                        <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center text-slate-500 font-bold text-xs shrink-0">
                                                            @(staff.Name.Substring(0, 1).ToUpper())
                                                        </div>
                                                        <span class="font-bold text-slate-700">@staff.Name</span>
                                                    </div>
                                                </td>
                                                <td class="py-3 px-4 font-mono text-slate-600">@staff.EmployeeNumber</td>
                                                <td class="py-3 px-4 text-slate-600">@(staff.EffectiveStartDate.ToString("dd MMM yyyy"))</td>
                                                <td class="py-3 px-4 text-center">
                                                    <div class="flex items-center justify-center gap-2">
                                                        <button title="View Staff Details" class="text-indigo-600 hover:text-indigo-800 font-bold text-xs bg-indigo-50 hover:bg-indigo-100 px-2 py-1.5 rounded transition-colors border border-indigo-100 flex items-center gap-1">
                                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                                            Detail
                                                        </button>
                                                        <button title="Edit Assignment" class="text-slate-600 hover:text-slate-800 font-bold text-xs bg-slate-100 hover:bg-slate-200 px-2 py-1.5 rounded transition-colors border border-slate-200 flex items-center gap-1">
                                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                                            Edit
                                                        </button>
                                                        <button title="Remove from Team" class="text-rose-600 hover:text-rose-800 font-bold text-xs bg-rose-50 hover:bg-rose-100 px-2 py-1.5 rounded transition-colors border border-rose-100 flex items-center gap-1">
                                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="space-y-4 pt-6">
                            <div class="flex justify-between items-end border-b border-slate-100 pb-2">
                                <div>
                                    <h4 class="text-lg font-bold text-slate-800">Former Staff</h4>
                                    <p class="text-xs text-slate-500 mt-1">Employees previously assigned to this team whose effective end date has passed.</p>
                                </div>
                            </div>

                            <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-x-auto">
                                <table class="w-full text-left border-collapse whitespace-nowrap text-sm">
                                    <thead class="bg-slate-50 border-b border-slate-200">
                                        <tr>
                                            <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs w-12">#</th>
                                            <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs">Name</th>
                                            <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs">Employee No.</th>
                                            <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs">Term Dates</th>
                                            <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs text-center">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-100 opacity-80">
                                        @if (isLoadingStaff)
                                        {
                                            <tr><td colspan="5" class="py-8 text-center text-slate-400">Loading history...</td></tr>
                                        }
                                        else if (!formerStaff.Any())
                                        {
                                            <tr><td colspan="5" class="py-8 text-center text-slate-400 italic">No former staff records found.</td></tr>
                                        }
                                        else
                                        {
                                            @for (int i = 0; i < formerStaff.Count; i++)
                                            {
                                                var staff = formerStaff[i];
                                                <tr class="hover:bg-slate-50 transition-colors grayscale-[50%]">
                                                    <td class="py-3 px-4 text-slate-400 font-medium">@(i + 1)</td>
                                                    <td class="py-3 px-4">
                                                        <div class="flex items-center gap-3">
                                                            <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 font-bold text-xs shrink-0">
                                                                @(staff.Name.Substring(0, 1).ToUpper())
                                                            </div>
                                                            <span class="font-bold text-slate-600">@staff.Name</span>
                                                        </div>
                                                    </td>
                                                    <td class="py-3 px-4 font-mono text-slate-500">@staff.EmployeeNumber</td>
                                                    <td class="py-3 px-4 text-slate-500 text-xs">
                                                        @staff.EffectiveStartDate.ToString("dd MMM yyyy")
                                                        <span class="mx-1 text-slate-300">→</span>
                                                        <span class="font-semibold text-rose-600">@(staff.EffectiveEndDate?.ToString("dd MMM yyyy") ?? "-")</span>
                                                    </td>
                                                    <td class="py-3 px-4 text-center">
                                                        <button title="View Staff Details" class="text-slate-500 hover:text-slate-800 font-bold text-xs bg-slate-100 hover:bg-slate-200 px-3 py-1.5 rounded transition-colors border border-slate-200">
                                                            Detail
                                                        </button>
                                                        <button title="Re-assign to Team" class="ml-2 text-emerald-600 hover:text-emerald-800 font-bold text-xs bg-emerald-50 hover:bg-emerald-100 px-3 py-1.5 rounded transition-colors border border-emerald-100">
                                                            Re-assign
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
                @* else if (activeTab == "Schedules")
                {
                    <div class="space-y-4 animate-in fade-in duration-300 pb-10">
                        <div class="flex justify-between items-end border-b border-slate-100 pb-2">
                            <div>
                                <h4 class="text-lg font-bold text-slate-800">Assigned Schedules</h4>
                                <p class="text-xs text-slate-500 mt-1">Manage working shifts and schedules applied to this team.</p>
                            </div>
                            <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-bold shadow-sm transition-colors flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                                Assign Schedule
                            </button>
                        </div>

                        <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-x-auto">
                            <table class="w-full text-left border-collapse whitespace-nowrap text-sm">
                                <thead class="bg-slate-50 border-b border-slate-200">
                                    <tr>
                                        <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs w-12">#</th>
                                        <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs">Schedule Name</th>
                                        <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs">Tags</th>
                                        <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs">Duration</th>
                                        <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs text-center">Status</th>
                                        <th class="py-3 px-4 font-bold text-slate-500 uppercase tracking-wider text-xs text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100">
                                    @if (isLoadingSchedules)
                                    {
                                        <tr>
                                            <td colspan="6" class="py-8 text-center text-slate-500">
                                                <div class="flex justify-center items-center gap-2">
                                                    <svg class="animate-spin h-5 w-5 text-indigo-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                                    Loading schedules...
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                    else if (!teamSchedules.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="py-8 text-center text-slate-500 italic">No schedules assigned to this team yet.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @for (int i = 0; i < teamSchedules.Count; i++)
                                        {
                                            var sched = teamSchedules[i];
                                            <tr class="hover:bg-slate-50 transition-colors @(sched.IsActive ? "" : "opacity-60")">
                                                <td class="py-3 px-4 text-slate-400 font-medium">@(i + 1)</td>
                                                <td class="py-3 px-4">
                                                    <span class="font-bold text-slate-700 block">@sched.Name</span>
                                                    @if (!string.IsNullOrWhiteSpace(sched.Description))
                                                    {
                                                        <span class="text-xs text-slate-500 block truncate max-w-[200px]">@sched.Description</span>
                                                    }
                                                </td>
                                                <td class="py-3 px-4 flex gap-1 items-center h-full pt-4">
                                                    @if (sched.IsGlobal)
                                                    {
                                                        <span class="bg-indigo-50 text-indigo-600 border border-indigo-100 px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">Global</span>
                                                    }
                                                    @if (sched.IsRamazan)
                                                    {
                                                        <span class="bg-amber-50 text-amber-600 border border-amber-100 px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">Ramadan</span>
                                                    }
                                                </td>
                                                <td class="py-3 px-4 text-slate-600 text-xs">
                                                    @if (sched.StartDate.HasValue || sched.EndDate.HasValue)
                                                    {
                                                        <span>@(sched.StartDate?.ToString("dd MMM yy") ?? "∞")</span>
