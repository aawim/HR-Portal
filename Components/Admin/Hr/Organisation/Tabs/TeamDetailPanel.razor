    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && Team != null)
        {
            if (activeTab != "Summary") activeTab = "Summary";
            await LoadSummaryData();
        }
    }

    private async Task SelectTab(string tabName)
    {
        activeTab = tabName;

        // Lazy load based on tab clicked
        if (tabName == "Staffs") await LoadTeamStaff();
        // if (tabName == "Schedules") await LoadTeamSchedules();
        // if (tabName == "Leave Sets") await LoadTeamLeaveSets();
    }

    private async Task ClosePanel()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(IsOpen);

        // Clean up state
        teamStaff.Clear();
        activeTab = "Summary";
    }

    // ==============================================
    // DATA LOADING METHODS (Assumes standard EF names)
    // NOTE: Change DbContext.TeamStaffs / TeamSchedules / TeamLeaveSets to your exact DbSet names!
    // ==============================================

    private async Task LoadSummaryData()
    {
        isLoadingSummary = true;
        try
        {
            if (Team == null || Team.TeamID == 0) return;

            var staffDates = await DbContext.TeamStaffs
                .Where(ts => ts.TeamId == Team.TeamID)
                .Select(ts => new { ts.StartDate, ts.EndDate })
                .ToListAsync();

            activeStaffCount = staffDates.Count(s => s.EndDate == null || s.EndDate > DateTime.Today);
            pastStaffCount = staffDates.Count(s => s.EndDate != null && s.EndDate <= DateTime.Today);

            var rawEvents = new List<RawEvent>();
            foreach (var s in staffDates)
            {
                rawEvents.Add(new RawEvent { Date = s.StartDate, Type = "Join" });
                if (s.EndDate <= DateTime.Today)
                {
                    rawEvents.Add(new RawEvent { Date = s.EndDate.GetValueOrDefault(), Type = "Leave" });
                }
            }

            var groupedByMonth = rawEvents
                .GroupBy(e => new { e.Date.Year, e.Date.Month })
                .OrderBy(g => g.Key.Year).ThenBy(g => g.Key.Month);

            int runningTotal = 0;
            timelineEvents.Clear();

            foreach (var group in groupedByMonth)
            {
                int joinsThisMonth = group.Count(e => e.Type == "Join");
                int leavesThisMonth = group.Count(e => e.Type == "Leave");

                runningTotal += joinsThisMonth;
                runningTotal -= leavesThisMonth;

                timelineEvents.Add(new TimelineEvent
                    {
                        MonthYear = new DateTime(group.Key.Year, group.Key.Month, 1),
                        Joins = joinsThisMonth,
                        Leaves = leavesThisMonth,
                        ActiveStaffCount = runningTotal
                    });
            }

            timelineEvents.Reverse();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading summary: {ex.Message}");
        }
        finally
        {
            isLoadingSummary = false;
        }
    }

    private async Task LoadTeamStaff()
    {
        isLoadingStaff = true;
        try
        {
            if (Team == null || Team.TeamID == 0) return;

            var currentTime = DateTime.Now;

            // 1. MIRROR SQL: INNER JOIN TeamStaffs + Individuals + Staffs
            var allRecords = await (from ts in DbContext.TeamStaffs
                                    join ind in DbContext.Individuals on ts.StaffId equals ind.BusinessEntityId
                                    join s in DbContext.Staffs on ind.BusinessEntityId equals s.IndividualId
                                    where ts.TeamId == Team.TeamID
                                    select new { ts, ind, s }).ToListAsync();

            // ==========================================
            // 2. ACTIVE STAFF
            // SQL CASE: WHEN ts.EndDate IS NULL OR ts.EndDate > GETDATE() THEN 'Current'
            // ==========================================
            var activeRecords = allRecords
                .Where(x => x.ts.EndDate == null || x.ts.EndDate > currentTime)
                .OrderBy(x => x.ts.StartDate) // Match your SQL ORDER BY
                .ToList();

            teamStaff = activeRecords.Select(x => new TeamStaffDto
                {
                    Id = x.ts.TeamStaffsId,
                    Name = $"{x.ind.FirstNameEnglish} {x.ind.MiddleNameEnglish} {x.ind.LastNameEnglish}".Replace("  ", " ").Trim(),
                    EmployeeNumber = x.s.EmployeeNumber, // Official ID from Staffs table
                    EffectiveStartDate = x.ts.StartDate,
                    EffectiveEndDate = x.ts.EndDate
                }).ToList();

            // ==========================================
            // 3. FORMER STAFF
            // SQL CASE: ELSE 'Former'
            // ==========================================
            var formerRecords = allRecords
                .Where(x => x.ts.EndDate != null && x.ts.EndDate <= currentTime)
                .OrderByDescending(x => x.ts.EndDate) // UX: Most recently left at the top
                .ToList();

            formerStaff = formerRecords.Select(x => new TeamStaffDto
                {
                    Id = x.ts.TeamStaffsId,
                    Name = $"{x.ind.FirstNameEnglish} {x.ind.MiddleNameEnglish} {x.ind.LastNameEnglish}".Replace("  ", " ").Trim(),
                    EmployeeNumber = x.s.EmployeeNumber,
                    EffectiveStartDate = x.ts.StartDate,
                    EffectiveEndDate = x.ts.EndDate
                }).ToList();

            // ==========================================
            // 4. DASHBOARD COUNTS (Fixing the row vs staff issue)
            // ==========================================
            // Extract unique Staff IDs using Distinct() so if a staff member
            // rejoined 3 times, they only count as 1 Active or 1 Former person.
            activeStaffCount = activeRecords.Select(x => x.ts.StaffId).Distinct().Count();
            int totalUniqueStaff = allRecords.Select(x => x.ts.StaffId).Distinct().Count();

            pastStaffCount = totalUniqueStaff - activeStaffCount;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading team staff: {ex.Message}");
        }
        finally
        {
            isLoadingStaff = false;
            StateHasChanged();
        }
    }

