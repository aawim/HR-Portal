    private bool isLoadingStaff = true;
    private List<GroupStaffDto> groupStaff = new();
    private List<GroupStaffDto> formerStaff = new();
 
    // --- NEW: Summary State ---
    private bool isLoadingSummary = true;
    private int activeStaffCount = 0;
    private int pastStaffCount = 0;
    private List<TimelineEvent> timelineEvents = new();
    

    // --- State Variables ---
    private bool isLoadingSchedules = true;
    private List<GroupScheduleDto> groupSchedules = new();



    protected override async Task OnParametersSetAsync()
    {
        // When the panel opens, reset tab to Summary. If Staffs is selected, load data.
        if (IsOpen && Group != null)
        {
            if (activeTab != "Summary") activeTab = "Summary";
            await LoadSummaryData();
        }
    }
    private async Task LoadSummaryData()
    {
        isLoadingSummary = true;
        try
        {
            if (Group == null || Group.GroupID == 0) return;

            // 1. Fetch only the dates from the DB (Very fast, safe from EF translation errors)
            var staffDates = await DbContext.GroupStaffs
                .Where(gs => gs.GroupId == Group.GroupID)
                .Select(gs => new { gs.EffectiveStartDate, gs.EffectiveEndDate })
                .ToListAsync();

            // 2. Calculate Top Metric Cards
            activeStaffCount = staffDates.Count(s => s.EffectiveEndDate == null || s.EffectiveEndDate > DateTime.Today);
            pastStaffCount = staffDates.Count(s => s.EffectiveEndDate != null && s.EffectiveEndDate <= DateTime.Today);

            // 3. Generate Timeline History in memory
            var rawEvents = new List<RawEvent>();

            foreach (var s in staffDates)
            {
                rawEvents.Add(new RawEvent
                    {
                        Date = s.EffectiveStartDate,
                        Type = "Join"
                    });

                if (s.EffectiveEndDate <= DateTime.Today)
                {
                    rawEvents.Add(new RawEvent
                        {
                            Date = s.EffectiveEndDate.GetValueOrDefault(),
                            Type = "Leave"
                        });
                }
            }

            // Group the events by Month and Year
            var groupedByMonth = rawEvents
                .GroupBy(e => new { e.Date.Year, e.Date.Month })
                .OrderBy(g => g.Key.Year).ThenBy(g => g.Key.Month);

            int runningTotal = 0;
            timelineEvents.Clear();

            // Calculate the running total chronologically
            foreach (var group in groupedByMonth)
            {
                int joinsThisMonth = group.Count(e => e.Type == "Join");
                int leavesThisMonth = group.Count(e => e.Type == "Leave");

                runningTotal += joinsThisMonth;
                runningTotal -= leavesThisMonth;

                timelineEvents.Add(new TimelineEvent
                    {
                        MonthYear = new DateTime(group.Key.Year, group.Key.Month, 1),
                        Joins = joinsThisMonth,
                        Leaves = leavesThisMonth,
                        ActiveStaffCount = runningTotal
                    });
            }

            // Reverse the list so the newest dates appear at the top of the UI
            timelineEvents.Reverse();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading summary: {ex.Message}");
        }
        finally
        {
            isLoadingSummary = false;
        }
    }
    private async Task SelectTab(string tabName)
    {
        activeTab = tabName;

        // Lazy load staff when the tab is clicked
        if (tabName == "Staffs"){await LoadGroupStaff();}
        if (tabName == "Schedules") await LoadGroupSchedules(); 
        if (tabName == "Leave Sets") await LoadGroupLeaveSets();
    }

    // --- The DB Query Method ---
    private async Task LoadGroupSchedules()
    {
        isLoadingSchedules = true;
        try
        {
            if (Group == null || Group.GroupID == 0) return;

            // 1. Safe query from DB without C# string manipulation
            var baseQuery = from gs in DbContext.GroupSchedules
                            where gs.GroupId == Group.GroupID
                            join s in DbContext.Schedules on gs.ScheduleId equals s.ScheduleId
                            select new { gs, s };

            var records = await baseQuery.ToListAsync();

            // 2. Map to DTO in memory, ordering by Active first, then by Start Date
            groupSchedules = records.Select(x => new GroupScheduleDto
            {
                GroupScheduleID = x.gs.GroupScheduleId,
                ScheduleID = x.s.ScheduleId,
                Name = x.s.Name ?? "Unnamed Schedule",
                Description = x.s.Description,
                IsActive = x.gs.IsActive ,
                IsGlobal = x.s.IsGlobal ,
                IsRamazan = x.s.IsRamazan ?? false,
                StartDate = x.s.StartDate,
                EndDate = x.s.EndDate
            })
            .OrderByDescending(s => s.IsActive)
            .ThenByDescending(s => s.StartDate)
            .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading schedules: {ex.Message}");
        }
        finally
        {
            isLoadingSchedules = false;
            StateHasChanged();
        }
    }


    private async Task LoadGroupStaff()
    {
        isLoadingStaff = true;
        try
        {
            if (Group == null || Group.GroupID == 0) return;

            // 1. Create a base query to handle the JOIN securely in SQL
            var baseQuery = from gs in DbContext.GroupStaffs
                            where gs.GroupId == Group.GroupID
                            join ind in DbContext.Individuals on gs.StaffIndividualId equals ind.BusinessEntityId
                            select new { gs, ind };

            // 2. Fetch Active Staff securely from the database
            var activeRecords = await baseQuery
                .Where(x => x.gs.EffectiveEndDate == null || x.gs.EffectiveEndDate > DateTime.Today)
                .OrderByDescending(x => x.gs.EffectiveStartDate)
                .ToListAsync();

            // Safely map Active Staff to C# objects in memory
            groupStaff = activeRecords.Select(x => new GroupStaffDto
                {
                    Id = x.gs.GroupStaffId,
                    Name = $"{x.ind.FirstNameEnglish} {x.ind.MiddleNameEnglish} {x.ind.LastNameEnglish}".Replace("  ", " ").Trim(),
                    EmployeeNumber = "ID-" + x.ind.BusinessEntityId.ToString(),
                    EffectiveStartDate = x.gs.EffectiveStartDate,
                    EffectiveEndDate = x.gs.EffectiveEndDate
                }).ToList();


            // 3. Fetch Former Staff securely from the database
            var formerRecords = await baseQuery
                .Where(x => x.gs.EffectiveEndDate != null && x.gs.EffectiveEndDate <= DateTime.Today)
                .OrderByDescending(x => x.gs.EffectiveEndDate)
                .ToListAsync();

            // Safely map Former Staff to C# objects in memory
            formerStaff = formerRecords.Select(x => new GroupStaffDto
                {
                    Id = x.gs.GroupStaffId,
                    Name = $"{x.ind.FirstNameEnglish} {x.ind.MiddleNameEnglish} {x.ind.LastNameEnglish}".Replace("  ", " ").Trim(),
                    EmployeeNumber = "ID-" + x.ind.BusinessEntityId.ToString(),
                    EffectiveStartDate = x.gs.EffectiveStartDate,
                    EffectiveEndDate = x.gs.EffectiveEndDate
                }).ToList();

        }
        catch (Exception ex)
        {
            // If it fails again, this will let you see exactly why in your output/console
            Console.WriteLine($"Error loading group staff: {ex.Message}");
        }
        finally
        {
            isLoadingStaff = false;
            StateHasChanged(); // Force the UI to refresh after loading!
        }
    }

    // --- The DB Query Method for Leave Sets ---
    // --- 1. Load the Table Data (Now includes related Leave Types) ---
    private async Task LoadGroupLeaveSets()
    {
        isLoadingLeaveSets = true;
        try
        {
            if (Group == null || Group.GroupID == 0) return;

            // Step 1: Fetch the base Leave Sets
            var records = await (from gls in DbContext.GroupLeaveSets
                                 where gls.GroupId == Group.GroupID
                                 join ls in DbContext.LeaveSets on gls.LeaveSetId equals ls.LeaveSetId
                                 select new
                                 {
                                     GroupLeaveSetId = gls.GroupLeaveSetId,
                                     LeaveSetId = ls.LeaveSetId,
                                     Name = ls.Name,
                                     IsPublic = ls.IsPublic,
                                     IsGlobal = ls.IsGlobal,
                                     IsValid = gls.IsValid
                                 }).ToListAsync();

            if (!records.Any())
            {
                groupLeaveSets = new List<GroupLeaveSetDto>();
                return;
            }

            // Step 2: Fetch Leave Types using strict SQL JOINs instead of .Contains(list)!
            // This forces EF Core to use SQL joins rather than generating buggy parameters.
            var leaveTypesData = await (from gls in DbContext.GroupLeaveSets
                                        where gls.GroupId == Group.GroupID
                                        join lslt in DbContext.LeaveSetLeaveTypes on gls.LeaveSetId equals lslt.LeaveSetId
                                        where lslt.IsValid == true
                                        join lt in DbContext.LeaveTypes on lslt.LeaveTypeId equals lt.LeaveTypeId
                                        select new
                                        {
                                            LeaveSetId = lslt.LeaveSetId,
                                            TypeName = lt.Name
                                        }).ToListAsync();

            // Group the leave types by their LeaveSetId in memory
            var leaveTypesLookup = leaveTypesData
                .GroupBy(x => x.LeaveSetId)
                .ToDictionary(g => g.Key, g => g.Select(x => x.TypeName).ToList());

            // Step 3: Map the raw data to your DTOs
            groupLeaveSets = records.Select(x => new GroupLeaveSetDto
                {
                    GroupLeaveSetID = x.GroupLeaveSetId,
                    LeaveSetID = x.LeaveSetId,
                    Name = x.Name ?? "Unnamed Leave Set",
                    IsPublic = x.IsPublic,
                    IsGlobal = x.IsGlobal,
                    IsValid = x.IsValid,
                    IncludedLeaveTypes = leaveTypesLookup.ContainsKey(x.LeaveSetId)
                                         ? leaveTypesLookup[x.LeaveSetId]
                                         : new List<string>()
                })
            .OrderByDescending(ls => ls.IsValid)
            .ThenBy(ls => ls.Name)
            .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading leave sets: {ex.Message}");
        }
        finally
        {
            isLoadingLeaveSets = false;
            StateHasChanged();
        }
    }

    // --- 2. Open Panel & Fetch Dropdown ---
    private async Task OpenAssignLeaveSetPanel()
    {
        isFetchingDropdown = true;
        showAssignLeavePanel = true;
        selectedNewLeaveSetId = 0;
        availableLeaveSets.Clear();

        try
        {
            if (Group == null || Group.GroupID == 0) return;

            var groupEntity = await DbContext.Groups.FirstOrDefaultAsync(g => g.GroupId == Group.GroupID);
            if (groupEntity == null) return;

            int orgId = groupEntity.BusinessEntityOrganisationId;
            if (orgId == 0) return;

            var alreadyAssignedIDs = groupLeaveSets.Select(x => x.LeaveSetID).ToList();

            // STEP 1: Fetch ALL leave sets for this organization (100% safe, no .Contains here)
            var allOrgLeaveSets = await DbContext.LeaveSets
                .Where(ls => ls.OrganisationId == orgId)
                .OrderBy(ls => ls.Name)
                .ToListAsync(); // <-- SQL Server finishes its job right here.

            // STEP 2: Filter the list in C# memory
            // Because this happens after .ToListAsync(), it uses C#, not SQL!
            if (alreadyAssignedIDs.Any())
            {
                availableLeaveSets = allOrgLeaveSets
                    .Where(ls => !alreadyAssignedIDs.Contains(ls.LeaveSetId))
                    .ToList();
            }
            else
            {
                availableLeaveSets = allOrgLeaveSets;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dropdown: {ex.Message}");
        }
        finally
        {
            isFetchingDropdown = false;
            StateHasChanged();
        }
    }

    private void CloseAssignLeaveSetPanel()
    {
        showAssignLeavePanel = false;
    }

    // --- 3. Save Assignment ---
    private async Task SubmitAssignLeaveSet()
    {
        if (selectedNewLeaveSetId == 0 || Group == null) return;

        isSubmittingLeaveSet = true;
        try
        {
            int newLogId = await LogService.CreateLogAsync(SharedConfig.OperationLogActionTypes.GROUP_LEAVE_SET_CREATE, "Assigned Leave Set ID 12 to Group 3");
            var newAssignment = new GroupLeaveSet
                {
                // Note the simple 'd' to match your Entity Model
                    GroupId = Group.GroupID,
                    LeaveSetId = selectedNewLeaveSetId,
                    IsValid = true,

                // 🛑 CRITICAL FIX: Because OperationLogId is an 'int' and not 'int?',
                // it is REQUIRED by the database. You MUST pass a valid ID here.
                // Replace '1' with however you normally track the current user/session log in your app.
                    OperationLogId = 1
                };

            DbContext.GroupLeaveSets.Add(newAssignment);
            await DbContext.SaveChangesAsync();

            // Refresh the table and close panel
            await LoadGroupLeaveSets();
            showAssignLeavePanel = false;
        }
        catch (Exception ex)
        {
            // PRO TIP: Using 'InnerException' reveals the ACTUAL SQL error instead of a generic EF error
            string errorMsg = ex.InnerException != null ? ex.InnerException.Message : ex.Message;
            Console.WriteLine($"❌ Error assigning leave set: {errorMsg}");
        }
        finally
        {
            isSubmittingLeaveSet = false;
            StateHasChanged();
        }
    }


