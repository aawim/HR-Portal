@page "/admin/work-planning/generator-test"

@using HRM.DTOs.WorkPlanning
@using HRM.WorkPlanning.Abstractions

@inject IWorkPlanningTestService TestService

<PageTitle>Work Planning Generator Test</PageTitle>

<div class="max-w-4xl mx-auto p-6">

    <div class="bg-white border border-slate-200 rounded-xl shadow-sm">

        <div class="px-6 py-4 border-b border-slate-200">
            <h1 class="text-lg font-semibold text-slate-800">
                Work Planning Generator Test
            </h1>

            <p class="text-sm text-slate-500 mt-1">
                Generate a standard office assignment from the configured
                work template.
            </p>
        </div>

        <div class="p-6 space-y-5">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">
                        Organisation ID
                    </label>

                    <InputNumber @bind-Value="OrganisationId"
                                 class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">
                        Individual ID
                    </label>

                    <InputNumber @bind-Value="IndividualId"
                                 class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">
                        Operation Log ID
                    </label>

                    <InputNumber @bind-Value="OperationLogId"
                                 class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">
                        Work Date
                    </label>

                    <InputDate @bind-Value="WorkDate"
                               class="w-full rounded-lg border border-slate-300 px-3 py-2" />
                </div>

            </div>

            <button type="button"
                    disabled="@IsGenerating"
                    @onclick="GenerateAsync"
                    class="inline-flex items-center justify-center rounded-lg
                           bg-blue-600 px-4 py-2 text-sm font-medium text-white
                           hover:bg-blue-700 disabled:opacity-50
                           disabled:cursor-not-allowed">

                @if (IsGenerating)
                {
                    <span>Generating...</span>
                }
                else
                {
                    <span>Generate Work Plan</span>
                }

            </button>

            @if (Result is not null)
            {
                <div class="@GetResultCssClass()">

                    <div class="font-semibold">
                        @(Result.Success ? "Success" : "Generation Failed")
                    </div>

                    <div class="mt-1 text-sm">
                        @Result.Message
                    </div>

                    @if (Result.WorkPlanId.HasValue)
                    {
                        <dl class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-5 text-sm">

                            <div>
                                <dt class="text-slate-500">Work Plan ID</dt>
                                <dd class="font-medium text-slate-800">
                                    @Result.WorkPlanId
                                </dd>
                            </div>

                            <div>
                                <dt class="text-slate-500">
                                    Work Assignment ID
                                </dt>
                                <dd class="font-medium text-slate-800">
                                    @Result.WorkAssignmentId
                                </dd>
                            </div>

                            <div>
                                <dt class="text-slate-500">Template</dt>
                                <dd class="font-medium text-slate-800">
                                    @Result.TemplateName
                                </dd>
                            </div>

                            <div>
                                <dt class="text-slate-500">Assignment</dt>
                                <dd class="font-medium text-slate-800">
                                    @Result.AssignmentTitle
                                </dd>
                            </div>

                            <div>
                                <dt class="text-slate-500">Start</dt>
                                <dd class="font-medium text-slate-800">
                                    @Result.StartDateTime?.ToString(
                                             "dd MMM yyyy HH:mm")
                                </dd>
                            </div>

                            <div>
                                <dt class="text-slate-500">End</dt>
                                <dd class="font-medium text-slate-800">
                                    @Result.EndDateTime?.ToString(
                                             "dd MMM yyyy HH:mm")
                                </dd>
                            </div>

                            <div>
                                <dt class="text-slate-500">Segments</dt>
                                <dd class="font-medium text-slate-800">
                                    @Result.SegmentCount
                                </dd>
                            </div>

                            <div>
                                <dt class="text-slate-500">Owners</dt>
                                <dd class="font-medium text-slate-800">
                                    @Result.OwnerCount
                                </dd>
                            </div>

                        </dl>
                    }
                </div>
            }

        </div>
    </div>
</div>

@code {
    private int OrganisationId { get; set; }

    private int IndividualId { get; set; }

    private int OperationLogId { get; set; }

    private DateTime WorkDate { get; set; } =
        DateTime.Today.AddDays(1);

    private bool IsGenerating { get; set; }

    private WorkPlanTestResult? Result { get; set; }

    private async Task GenerateAsync()
    {
        Result = null;

        if (OrganisationId <= 0)
        {
            Result = Failure("Enter a valid organisation ID.");
            return;
        }

        if (IndividualId <= 0)
        {
            Result = Failure("Enter a valid individual ID.");
            return;
        }

        if (OperationLogId <= 0)
        {
            Result = Failure("Enter a valid operation log ID.");
            return;
        }

        try
        {
            IsGenerating = true;

            Result =
                await TestService.GenerateStandardOfficePlanAsync(
                    OrganisationId,
                    IndividualId,
                    OperationLogId,
                    WorkDate);
        }
        finally
        {
            IsGenerating = false;
        }
    }

    private static WorkPlanTestResult Failure(string message)
    {
        return new WorkPlanTestResult
            {
                Success = false,
                Message = message
            };
    }

    private string GetResultCssClass()
    {
        const string common =
            "rounded-lg border p-4";

        return Result?.Success == true
            ? $"{common} border-green-200 bg-green-50 text-green-800"
            : $"{common} border-red-200 bg-red-50 text-red-800";
    }
}