    private static TimeOnly? ParseTimeOnly(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        if (TimeOnly.TryParse(value, out var parsedTime))
            return parsedTime;

        if (TimeSpan.TryParse(value, out var parsedSpan))
            return TimeOnly.FromTimeSpan(parsedSpan);

        return null;
    }

    private static string FormatTime(TimeOnly? value)
    {
        return value?.ToString("HH:mm") ?? string.Empty;
    }

    private static string FormatPresetTime(TimeSpan? value)
    {
        return value?.ToString(@"hh\:mm") ?? string.Empty;
    }

    private static string GetTimeDescription( WorkTemplateDto template)
    {
        if (!template.DefaultStartTime.HasValue ||
            !template.DefaultEndTime.HasValue)
        {
            return "Flexible schedule";
        }

        var crossesMidnight =
            template.DefaultEndTime.Value <=
            template.DefaultStartTime.Value;

        var description =
            $"{template.DefaultStartTime.Value:HH\\:mm} - " +
            $"{template.DefaultEndTime.Value:HH\\:mm}";

        return crossesMidnight
            ? $"{description} · Next day"
            : description;
    }

