    private static string FormatMinutes(int totalMinutes)
    {
        if (totalMinutes <= 0)
            return "0m";

        var hours = totalMinutes / 60;
        var minutes = totalMinutes % 60;

        if (hours > 0 && minutes > 0)
            return $"{hours}h {minutes}m";

        if (hours > 0)
            return $"{hours}h";

        return $"{minutes}m";
    }

    private string GetSegmentPeriod( WorkTemplateSegmentDto segment)
    {
        if (!editModel.DefaultStartTime.HasValue)
        {
            return $"Minute {segment.OffsetMinutes} - " +
                   $"minute {segment.OffsetMinutes + segment.DurationMinutes}";
        }

        var templateStart =
            editModel.DefaultStartTime.Value.ToTimeSpan();

        var segmentStart =
            templateStart.Add(
                TimeSpan.FromMinutes(segment.OffsetMinutes));

        var segmentEnd =
            segmentStart.Add(
                TimeSpan.FromMinutes(segment.DurationMinutes));

        return $"{FormatClockTime(segmentStart)} - " +
               $"{FormatClockTime(segmentEnd)}";
    }

    private string GetEditModelPeriod()
    {
        if (!editModel.DefaultStartTime.HasValue)
        {
            var end =
                segmentEditModel.OffsetMinutes +
                segmentEditModel.DurationMinutes;

            return $"Minute {segmentEditModel.OffsetMinutes} " +
                   $"to minute {end}";
        }

        var templateStart =
            editModel.DefaultStartTime.Value.ToTimeSpan();

        var segmentStart =
            templateStart.Add(
                TimeSpan.FromMinutes(
                    segmentEditModel.OffsetMinutes));

        var segmentEnd =
            segmentStart.Add(
                TimeSpan.FromMinutes(
                    segmentEditModel.DurationMinutes));

        return $"{FormatClockTime(segmentStart)} - " +
               $"{FormatClockTime(segmentEnd)}";
    }

    private static string FormatClockTime(TimeSpan time)
    {
        var dayNumber =
            (int)Math.Floor(time.TotalDays);

        var normalisedTime =
            TimeSpan.FromMinutes(time.TotalMinutes % 1440);

        if (normalisedTime < TimeSpan.Zero)
        {
            normalisedTime =
                normalisedTime.Add(TimeSpan.FromDays(1));
        }

        var formatted =
            $"{normalisedTime.Hours:00}:" +
            $"{normalisedTime.Minutes:00}";

        return dayNumber > 0
            ? $"{formatted} (+{dayNumber} day)"
            : formatted;
    }

    private int GetTotalSegmentMinutes()
    {
        return segments
            .Where(x => x.IsActive)
            .Sum(x => x.DurationMinutes);
    }



    private async Task SaveSegmentAsync()
    {

 

        if (editModel.WorkTemplateId <= 0)
        {
            ToastService.Error(
                "Save or select a work template first.");

            return;
        }

        if (segmentEditModel.WorkSegmentTypeId <= 0)
        {
            ToastService.Error(
                "Please select a segment type.");

            return;
        }

        if (string.IsNullOrWhiteSpace(segmentEditModel.Name))
        {
            ToastService.Error(
                "Segment name is required.");

            return;
        }

        if (segmentEditModel.SequenceNumber <= 0)
        {
            ToastService.Error(
                "Sequence number must be greater than zero.");

            return;
        }

        if (segmentEditModel.OffsetHours < 0 ||
            segmentEditModel.OffsetMinutePart < 0 ||
            segmentEditModel.OffsetMinutePart > 59)
        {
            ToastService.Error(
                "Offset minutes must be between 0 and 59.");

            return;
        }

        if (segmentEditModel.DurationHours < 0 ||
            segmentEditModel.DurationMinutePart < 0 ||
            segmentEditModel.DurationMinutePart > 59)
        {
            ToastService.Error(
                "Duration minutes must be between 0 and 59.");

            return;
        }

        if (segmentEditModel.DurationMinutes <= 0)
        {
            ToastService.Error(
                "Segment duration must be greater than zero.");

            return;
        }

        if (segmentEditModel.GraceBeforeMinutes < 0 ||
            segmentEditModel.GraceAfterMinutes < 0)
        {
            ToastService.Error(
                "Grace periods cannot be negative.");

            return;
        }

        try
        {
            isSavingSegment = true;

            var workTemplateId = editModel.WorkTemplateId;

            var dto = new SaveWorkTemplateSegmentDto
                {
                    WorkTemplateSegmentId =
                        segmentEditModel.WorkTemplateSegmentId,

                    WorkTemplateId =
                        workTemplateId,

                    WorkSegmentTypeId =
                        segmentEditModel.WorkSegmentTypeId,

                    Name =
                        segmentEditModel.Name.Trim(),

                    Description =
                        string.IsNullOrWhiteSpace(
                            segmentEditModel.Description)
                            ? null
                            : segmentEditModel.Description.Trim(),

                    SequenceNumber =
                        segmentEditModel.SequenceNumber,

                    OffsetMinutes =
                        segmentEditModel.OffsetMinutes,

                    DurationMinutes =
                        segmentEditModel.DurationMinutes,

                    GraceBeforeMinutes =
                        segmentEditModel.GraceBeforeMinutes,

                    GraceAfterMinutes =
                        segmentEditModel.GraceAfterMinutes,

                    IsMandatory =
                        segmentEditModel.IsMandatory,

                    RequiresAttendance =
                        segmentEditModel.RequiresAttendance,

                    RequiresLocationValidation =
                        segmentEditModel.RequiresLocationValidation,

                    RequiresDeviceValidation =
                        segmentEditModel.RequiresDeviceValidation,

                    IsActive =
                        segmentEditModel.IsActive,

     

                    IsPaid = segmentEditModel.IsPaid
     



                };

            ServiceResult result;

            if (segmentEditModel.WorkTemplateSegmentId > 0)
            {
                result =
                    await WorkTemplateService
                        .UpdateSegmentAsync(dto);
            }
            else
            {
                result =
                    await WorkTemplateService.CreateSegmentAsync(dto);
            }

            if (!result.Success)
            {
                ToastService.Error(result.Message);
                return;
            }

            ToastService.Success(
                string.IsNullOrWhiteSpace(result.Message)
                    ? "Segment saved successfully."
                    : result.Message);

            showSegmentPanel = false;
            isEditingSegment = false;

            segmentEditModel =
                CreateEmptySegmentEditModel();

            await LoadSegmentsAsync(workTemplateId);

            await LoadTemplatesAsync();
        }
        catch (Exception ex)
        {
            ToastService.Error(
                $"Unable to save segment: {ex.Message}");
        }
        finally
        {
            isSavingSegment = false;
        }
    }

