                                                        <span class="rounded-md bg-violet-50 px-2
                                                                     py-1 text-xs font-medium
                                                                     text-violet-700">
                                                            Location
                                                        </span>
                                                    }

                                                    @if (segment.RequiresDeviceValidation)
                                                    {
                                                        <span class="rounded-md bg-cyan-50 px-2
                                                                     py-1 text-xs font-medium
                                                                     text-cyan-700">
