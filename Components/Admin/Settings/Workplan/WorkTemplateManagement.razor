<!-- Segment Add/Edit Panel -->
<RightSidePanel @bind-IsOpen="showSegmentPanel"
Title="@SegmentPanelTitle"
Description="Configure the segment timing and validation rules."
Size="RightSidePanel.PanelSize.Medium"
ContentWidth="max-w-2xl"
OnClose="CloseSegmentPanel">

    <ChildContent>
        <EditForm Model="@segmentEditModel"
        OnValidSubmit="SaveSegmentAsync"
        id="work-template-segment-form">

            <DataAnnotationsValidator />

            <div class="space-y-6">
                <ValidationSummary class="rounded-lg border border-red-200
                                                  bg-red-50 p-3 text-sm
                                                  text-red-700" />

                <section>
                    <div class="mb-4">
                        <h3 class="text-sm font-semibold text-slate-900">
                            Segment Details
                        </h3>
                        <p class="mt-1 text-xs text-slate-500">
                            Give the segment a name and select its type.
                        </p>
                    </div>

                    <div class="space-y-4">
                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Segment Name
                                <span class="text-red-500">*</span>
                            </label>

                            <InputText class="w-full rounded-lg border border-slate-300
                                                      px-3 py-2 text-sm outline-none
                                                      transition focus:border-blue-500
                                                      focus:ring-2 focus:ring-blue-100"
                            placeholder="For example, Morning Work"
                            @bind-Value="segmentEditModel.Name" />

                            <ValidationMessage For="@(() => segmentEditModel.Name)"
                            class="mt-1 block text-xs text-red-600" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Segment Type
                                <span class="text-red-500">*</span>
                            </label>

                            <InputSelect class="w-full rounded-lg border
                                                        border-slate-300 px-3 py-2
                                                        text-sm outline-none transition
                                                        focus:border-blue-500
                                                        focus:ring-2 focus:ring-blue-100"
                            @bind-Value="segmentEditModel.WorkSegmentTypeId">
                                <option value="0">Select segment type</option>

                                @foreach (var type in segmentTypes)
                                {
                                    <option value="@type.WorkSegmentTypeId">
                                        @type.Name
                                    </option>
                                }
                            </InputSelect>

                            <ValidationMessage For="@(() => segmentEditModel.WorkSegmentTypeId)"
                            class="mt-1 block text-xs text-red-600" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Description
                            </label>

                            <InputTextArea class="min-h-[90px] w-full
                                                  rounded-lg border border-slate-300
                                                  px-3 py-2 text-sm outline-none
                                                  transition focus:border-blue-500
                                                  focus:ring-2 focus:ring-blue-100"
                            placeholder="Optional description..."
                            @bind-Value="segmentEditModel.Description" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Sequence Number
                            </label>

                            <InputNumber class="w-full rounded-lg border
                                                        border-slate-300 px-3 py-2
                                                        text-sm outline-none transition
                                                        focus:border-blue-500
                                                        focus:ring-2 focus:ring-blue-100"
                            @bind-Value="segmentEditModel.SequenceNumber" />
                        </div>
                    </div>
                </section>

                <hr class="border-slate-200" />

                <section>
                    <div class="mb-4">
                        <h3 class="text-sm font-semibold text-slate-900">
                            Timing
                        </h3>

                        <p class="mt-1 text-xs text-slate-500">
                            Offset is measured from the template start time.
                        </p>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Offset Hours
                            </label>

                            <InputNumber class="w-full rounded-lg border
                                                        border-slate-300 px-3 py-2
                                                        text-sm outline-none transition
                                                        focus:border-blue-500
                                                        focus:ring-2 focus:ring-blue-100"
                            @bind-Value="segmentEditModel.OffsetHours" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Offset Minutes
                            </label>

                            <InputNumber class="w-full rounded-lg border
                                                        border-slate-300 px-3 py-2
                                                        text-sm outline-none transition
                                                        focus:border-blue-500
                                                        focus:ring-2 focus:ring-blue-100"
                            @bind-Value="segmentEditModel.OffsetMinutePart" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Duration Hours
                            </label>

                            <InputNumber class="w-full rounded-lg border
                                                        border-slate-300 px-3 py-2
                                                        text-sm outline-none transition
                                                        focus:border-blue-500
                                                        focus:ring-2 focus:ring-blue-100"
                            @bind-Value="segmentEditModel.DurationHours" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Duration Minutes
                            </label>

                            <InputNumber class="w-full rounded-lg border
                                                        border-slate-300 px-3 py-2
                                                        text-sm outline-none transition
                                                        focus:border-blue-500
                                                        focus:ring-2 focus:ring-blue-100"
                            @bind-Value="segmentEditModel.DurationMinutes" />
                        </div>
                    </div>

                    <div class="mt-4 rounded-lg border border-blue-200
                                bg-blue-50 p-3 text-sm text-blue-700">
                        Preview: @GetEditModelPeriod()
                    </div>
                </section>

                <hr class="border-slate-200" />

                <section>
                    <div class="mb-4">
                        <h3 class="text-sm font-semibold text-slate-900">
                            Grace Periods
                        </h3>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Grace Before (minutes)
                            </label>

                            <InputNumber class="w-full rounded-lg border
                                                        border-slate-300 px-3 py-2
                                                        text-sm outline-none transition
                                                        focus:border-blue-500
                                                        focus:ring-2 focus:ring-blue-100"
                            @bind-Value="segmentEditModel.GraceBeforeMinutes" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Grace After (minutes)
                            </label>

                            <InputNumber class="w-full rounded-lg border
                                                        border-slate-300 px-3 py-2
                                                        text-sm outline-none transition
                                                        focus:border-blue-500
                                                        focus:ring-2 focus:ring-blue-100"
                            @bind-Value="segmentEditModel.GraceAfterMinutes" />
                        </div>
                    </div>
                </section>

                <hr class="border-slate-200" />

                <section>
                    <div class="mb-4">
                        <h3 class="text-sm font-semibold text-slate-900">
                            Rules
                        </h3>
                    </div>

                    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                        <ToggleOption Title="Mandatory Segment"
                        Description="The segment must be included."
                        @bind-Value="segmentEditModel.IsMandatory" />

                        <ToggleOption Title="Attendance Required"
                        Description="Attendance is recorded for this segment."
                        @bind-Value="segmentEditModel.RequiresAttendance" />

                        <ToggleOption Title="Location Validation"
                        Description="Validate the employee location."
                        @bind-Value="segmentEditModel.RequiresLocationValidation" />

                        <ToggleOption Title="Device Validation"
                        Description="Validate the employee device."
                        @bind-Value="segmentEditModel.RequiresDeviceValidation" />

                        <ToggleOption Title="Active Segment"
                        Description="Make this segment active."
                        @bind-Value="segmentEditModel.IsActive" />
                    </div>
                </section>
            </div>
        </EditForm>
    </ChildContent>

    <FooterContent>
        <div class="flex flex-col-reverse gap-3 sm:flex-row
                    sm:items-center sm:justify-end">
            <button type="button"
            class="rounded-lg border border-slate-300 bg-white
                           px-5 py-2 text-sm font-medium text-slate-700
                           transition hover:bg-slate-50
                           disabled:cursor-not-allowed disabled:opacity-50"
            disabled="@isSavingSegment"
            @onclick="CloseSegmentPanel">
                Cancel
            </button>

            <button type="submit"
            form="work-template-segment-form"
            class="rounded-lg bg-blue-600 px-5 py-2 text-sm
                           font-medium text-white transition hover:bg-blue-700
                           disabled:cursor-not-allowed disabled:bg-slate-300"
            disabled="@isSavingSegment">
                @SegmentSaveButtonText
            </button>
        </div>
    </FooterContent>
</RightSidePanel>

@code {
    private bool isLoading;
    private bool isSaving;
    private bool isCreating;
    private bool showInactive = true;
    private bool showTemplatePanel;

    private string templateSearch = string.Empty;
    private string presetSearch = string.Empty;

    private List<WorkTemplateDto> templates = new();
    private WorkTemplateDto? selectedTemplate;
    private UpdateWorkTemplateDto editModel = CreateEmptyEditModel();

    private List<WorkTemplateSegmentDto> segments = new();
    private List<WorkSegmentTypeDto> segmentTypes = new();

    private WorkTemplateSegmentEditViewModel segmentEditModel = CreateEmptySegmentEditModel();
 

    private bool showSegmentPanel;
    private bool isEditingSegment;
    private bool isSavingSegment;
    private bool isLoadingSegments;

    private bool CanManageSegments => 
        !isCreating &&
        selectedTemplate is not null &&
        editModel.WorkTemplateId > 0;

    private string PanelTitle =>
        isCreating ? "Create Work Template" : "Edit Work Template";

    private string PanelDescription =>
        isCreating
            ? "Configure a reusable shift, duty or work schedule."
            : "Update the selected template's schedule and validation settings.";

    private string SaveButtonText =>
        isSaving
            ? "Saving..."
            : isCreating
                ? "Create Template"
                : "Save Changes";

    private string SegmentPanelTitle =>
        isEditingSegment ? "Edit Segment" : "Add Segment";

    // private string SegmentSaveButtonText =>
    //     isSavingSegment
    //         ? "Saving..."
    //         : isEditingSegment
    //             ? "Update Segment"
    //             : "Add Segment";

    private bool CrossesMidnight =>
        editModel.DefaultStartTime.HasValue &&
        editModel.DefaultEndTime.HasValue &&
        editModel.DefaultEndTime.Value <= editModel.DefaultStartTime.Value;

    
          
    private string SegmentSaveButtonText
    {
        get
        {
            if (isSavingSegment)
                return "Saving...";

            if (isEditingSegment)
                return "Update Segment";

            return "Create Segment";
        }
    }

    private readonly List<WorkTemplatePresetDto> presets =
    [
        new()
        {
            Name = "Morning Shift",
            Description = "Standard daytime shift with attendance and checkout.",
            WorkTemplateTypeId = 1,
            TemplateType = "RegularShift",
            DefaultStartTime = new TimeSpan(8, 0, 0),
            DefaultEndTime = new TimeSpan(14, 0, 0),
            RequiresAttendance = true,
            RequiresCheckOut = true,
            Icon = "☀️",
            IsActive = true
        },
        new()
        {
            Name = "Evening Shift",
            Description = "Standard evening work schedule.",
            WorkTemplateTypeId = 3,
            TemplateType = "RegularShift",
            DefaultStartTime = new TimeSpan(14, 0, 0),
            DefaultEndTime = new TimeSpan(20, 0, 0),
            RequiresAttendance = true,
            RequiresCheckOut = true,
            Icon = "🌆",
            IsActive = true
        },
        new()
        {
            Name = "Night Shift",
            Description = "Overnight shift that ends on the following day.",
            WorkTemplateTypeId = 3,
            TemplateType = "RegularShift",
            DefaultStartTime = new TimeSpan(20, 0, 0),
            DefaultEndTime = new TimeSpan(8, 0, 0),
            RequiresAttendance = true,
            RequiresCheckOut = true,
            Icon = "🌙",
            IsActive = true
        },
        new()
        {
            Name = "Temporary Duty",
            Description = "Short-term duty that can overlap a normal shift.",
            WorkTemplateTypeId = 4,
            TemplateType = "TemporaryDuty",
            RequiresAttendance = true,
            RequiresCheckOut = true,
            AllowsOverlap = true,
            Icon = "🛠️",
            IsActive = true
        },
        new()
        {
            Name = "Product Launch Duty",
            Description = "Temporary paid duty for product-launch support.",
            WorkTemplateTypeId = 5,
            TemplateType = "SpecialEvent",
            RequiresAttendance = true,
            RequiresCheckOut = true,
            AllowsOverlap = true,
            Icon = "🚀",
            IsActive = true
        },
        new()
        {
            Name = "On-call Duty",
            Description = "Flexible duty activated when the employee is required.",
            WorkTemplateTypeId = 6,
            TemplateType = "OnCall",
            RequiresAttendance = true,
            RequiresCheckOut = true,
            AllowsOverlap = true,
            Icon = "📞",
            IsActive = true
        }
    ];

    private List<WorkTemplateDto> FilteredTemplates =>
        templates
            .Where(x => showInactive || x.IsActive)
            .Where(x =>
                string.IsNullOrWhiteSpace(templateSearch) ||
                x.Name.Contains(templateSearch, StringComparison.OrdinalIgnoreCase) ||
                (x.Description?.Contains(
                    templateSearch,
                    StringComparison.OrdinalIgnoreCase) ?? false) ||
                GetTemplateTypeName(x.TemplateType).Contains(
                    templateSearch,
                    StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(x => x.IsActive)
            .ThenBy(x => x.Name)
            .ToList();

    private List<WorkTemplatePresetDto> FilteredPresets =>
        presets
            .Where(x =>
                string.IsNullOrWhiteSpace(presetSearch) ||
                x.Name.Contains(presetSearch, StringComparison.OrdinalIgnoreCase) ||
                x.Description.Contains(
                    presetSearch,
                    StringComparison.OrdinalIgnoreCase))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadTemplatesAsync();
        await LoadSegmentTypesAsync();
    }

    private async Task LoadTemplatesAsync()
    {
        try
        {
            isLoading = true;

            templates = await WorkTemplateService.GetAllAsync(
                includeInactive: true);
        }
        catch (Exception ex)
        {
            templates.Clear();
            ToastService.Error(
                $"Unable to load work templates: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadSegmentTypesAsync()
    {
        try
        {
            segmentTypes =
                await WorkTemplateService.GetAllSegmentTypesAsync();
        }
        catch (Exception ex)
        {
            segmentTypes.Clear();

            ToastService.Error(
                $"Unable to load segment types: {ex.Message}");
        }
    }

    private async Task SelectTemplateAsync(WorkTemplateDto template)
    {
        if (template is null)
            return;

        selectedTemplate = template;
        isCreating = false;

        editModel = new UpdateWorkTemplateDto
        {
            WorkTemplateId = template.WorkTemplateId,
            Name = template.Name,
            Description = template.Description,
            WorkTemplateTypeId = template.WorkTemplateTypeId,
            DefaultStartTime = template.DefaultStartTime,
            DefaultEndTime = template.DefaultEndTime,
            TemplateType = template.TemplateType,
            RequiresAttendance = template.RequiresAttendance,
            RequiresCheckOut = template.RequiresCheckOut,
            RequiresLocationValidation = template.RequiresLocationValidation,
            RequiresDeviceValidation = template.RequiresDeviceValidation,
            AllowsOverlap = template.AllowsOverlap,
            IsValid = template.IsValid,
            IsActive = template.IsActive
        };

        segments.Clear();
        showTemplatePanel = true;

        await LoadSegmentsAsync(template.WorkTemplateId);
    }

    private void StartNewTemplate()
    {
        selectedTemplate = null;
        isCreating = true;
        segments.Clear();
        segmentEditModel = CreateEmptySegmentEditModel();
        editModel = CreateEmptyEditModel();
        showTemplatePanel = true;
    }

    private void ApplyPreset(WorkTemplatePresetDto preset)
    {
        selectedTemplate = null;
        isCreating = true;
        segments.Clear();
        segmentEditModel = CreateEmptySegmentEditModel();

        editModel = new UpdateWorkTemplateDto
        {
            WorkTemplateId = 0,
            Name = preset.Name,
            Description = preset.Description,
            TemplateType = preset.TemplateType,
            WorkTemplateTypeId = preset.WorkTemplateTypeId,
            DefaultStartTime = preset.DefaultStartTime.HasValue
                ? TimeOnly.FromTimeSpan(preset.DefaultStartTime.Value)
                : null,
            DefaultEndTime = preset.DefaultEndTime.HasValue
                ? TimeOnly.FromTimeSpan(preset.DefaultEndTime.Value)
                : null,
            RequiresAttendance = preset.RequiresAttendance,
            RequiresCheckOut = preset.RequiresCheckOut,
            RequiresLocationValidation = false,
            RequiresDeviceValidation = false,
            AllowsOverlap = preset.AllowsOverlap,
            IsValid = true,
            IsActive = preset.IsActive
        };

        showTemplatePanel = true;
    }

    private async Task SaveTemplateAsync()
    {
        if (isSaving)
            return;

        if (!ValidateTimes())
            return;

        try
        {
            isSaving = true;

            if (isCreating)
            {
                var createDto = new CreateWorkTemplateDto
                {
                    Name = editModel.Name.Trim(),
                    WorkTemplateTypeId = editModel.WorkTemplateTypeId,
                    Description = editModel.Description?.Trim(),
                    DefaultStartTime = editModel.DefaultStartTime,
                    DefaultEndTime = editModel.DefaultEndTime,
                    TemplateType = editModel.TemplateType,
                    RequiresAttendance = editModel.RequiresAttendance,
                    RequiresCheckOut = editModel.RequiresCheckOut,
                    RequiresLocationValidation =
                        editModel.RequiresLocationValidation,
                    RequiresDeviceValidation =
                        editModel.RequiresDeviceValidation,
                    AllowsOverlap = editModel.AllowsOverlap,
                    IsValid = editModel.IsValid,
                    IsActive = editModel.IsActive
                };

                var result = await WorkTemplateService.CreateAsync(createDto);

                if (!result.Success)
                {
                    ToastService.Error(result.Message);
                    return;
                }

                ToastService.Success(
                    string.IsNullOrWhiteSpace(result.Message)
                        ? "Work template created successfully."
                        : result.Message);

                await LoadTemplatesAsync();

                /*
                 * Since the current ServiceResult does not expose the newly
                 * created ID, close the create panel. Select the new template
                 * from the list to add its segments.
                 */
                CloseTemplatePanel();
                return;
            }

            var updateResult =
                await WorkTemplateService.UpdateAsync(editModel);

            if (!updateResult.Success)
            {
                ToastService.Error(updateResult.Message);
                return;
            }

            ToastService.Success(
                string.IsNullOrWhiteSpace(updateResult.Message)
                    ? "Work template updated successfully."
                    : updateResult.Message);

            await LoadTemplatesAsync();

            var refreshedTemplate = templates.FirstOrDefault(
                x => x.WorkTemplateId == editModel.WorkTemplateId);

            if (refreshedTemplate is not null)
                selectedTemplate = refreshedTemplate;
        }
        catch (Exception ex)
        {
            ToastService.Error(
                $"Unable to save the template: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ArchiveTemplateAsync()
    {
        if (selectedTemplate is null || isSaving)
            return;

        try
        {
            isSaving = true;

            var result = await WorkTemplateService.ArchiveAsync(
                selectedTemplate.WorkTemplateId);

            if (!result.Success)
            {
                ToastService.Error(result.Message);
                return;
            }

            ToastService.Success(
                string.IsNullOrWhiteSpace(result.Message)
                    ? "Work template archived successfully."
                    : result.Message);

            await LoadTemplatesAsync();
            CloseTemplatePanel();
        }
        catch (Exception ex)
        {
            ToastService.Error(
                $"Unable to archive the template: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CloseTemplatePanel()
    {
        if (isSaving || isSavingSegment)
            return;

        showSegmentPanel = false;
        showTemplatePanel = false;
        ResetEditor();
    }

    private Task HandleTemplatePanelClosed()
    {
        if (!isSaving && !isSavingSegment)
            ResetEditor();

        return Task.CompletedTask;
    }

    private void ResetEditor()
    {
        selectedTemplate = null;
        isCreating = false;
        segments.Clear();
        isLoadingSegments = false;
        isEditingSegment = false;
        segmentEditModel = CreateEmptySegmentEditModel();
        editModel = CreateEmptyEditModel();
    }

    private void OnStartTimeChanged(ChangeEventArgs args)
    {
        editModel.DefaultStartTime =
            ParseTimeOnly(args.Value?.ToString());
    }

    private void OnEndTimeChanged(ChangeEventArgs args)
    {
        editModel.DefaultEndTime =
            ParseTimeOnly(args.Value?.ToString());
    }

    private bool ValidateTimes()
    {
        var onlyOneTimeProvided =
            editModel.DefaultStartTime.HasValue !=
            editModel.DefaultEndTime.HasValue;

        if (onlyOneTimeProvided)
        {
            ToastService.Error(
                "Both the default start time and end time must be provided.");

            return false;
        }

        return true;
    }

    private async Task LoadSegmentsAsync(int workTemplateId)
    {
        if (workTemplateId <= 0)
        {
            segments.Clear();
            return;
        }

        try
        {
            isLoadingSegments = true;

            segments = await WorkTemplateService.GetSegmentsAsync(workTemplateId);
        }
        catch (Exception ex)
        {
            segments.Clear();

            ToastService.Error(
                $"Unable to load segments: {ex.Message}");
        }
        finally
        {
            isLoadingSegments = false;
        }
    }

    private void OpenAddSegmentPanel()
    {
        if (!CanManageSegments || selectedTemplate is null)
        {
            ToastService.Error(
                "Save or select a work template before adding segments.");

            return;
        }

        isEditingSegment = false;

        var nextSequence = segments.Any()
            ? segments.Max(x => x.SequenceNumber) + 1
            : 1;

        var nextOffset = segments.Any()
            ? segments.Max(x => x.OffsetMinutes + x.DurationMinutes)
            : 0;

        segmentEditModel = CreateEmptySegmentEditModel();

        segmentEditModel.WorkTemplateId =
            selectedTemplate.WorkTemplateId;

        segmentEditModel.SequenceNumber = nextSequence;
        segmentEditModel.OffsetHours = nextOffset / 60;
        segmentEditModel.OffsetMinutePart = nextOffset % 60;

        showSegmentPanel = true;
    }

    private void OpenEditSegmentPanel(WorkTemplateSegmentDto segment)
    {
        if (segment is null)
            return;

        isEditingSegment = true;

        segmentEditModel = new WorkTemplateSegmentEditViewModel
        {
            WorkTemplateSegmentId = segment.WorkTemplateSegmentId,
            WorkTemplateId = segment.WorkTemplateId,
            WorkSegmentTypeId = segment.WorkSegmentTypeId,
            Name = segment.Name,
            Description = segment.Description,
            SequenceNumber = segment.SequenceNumber,
            OffsetHours = segment.OffsetMinutes / 60,
            OffsetMinutePart = segment.OffsetMinutes % 60,
            DurationHours = segment.DurationMinutes / 60,
            DurationMinutePart = segment.DurationMinutes % 60,
            GraceBeforeMinutes = segment.GraceBeforeMinutes,
            GraceAfterMinutes = segment.GraceAfterMinutes,
            IsMandatory = segment.IsMandatory,
            RequiresAttendance = segment.RequiresAttendance,
            RequiresLocationValidation = segment.RequiresLocationValidation,
            RequiresDeviceValidation = segment.RequiresDeviceValidation,
            IsActive = segment.IsActive,
            IsPaid = segment.IsPaid,
 
        };

        showSegmentPanel = true;
    }

    private Task CloseSegmentPanel()
    {
        if (isSavingSegment)
            return Task.CompletedTask;

        showSegmentPanel = false;
        isEditingSegment = false;
        segmentEditModel = CreateEmptySegmentEditModel();

        return Task.CompletedTask;
    }

   

    private bool ValidateSegmentEditModel()
    {
        if (segmentEditModel.WorkTemplateId <= 0)
        {
            ToastService.Error(
                "A valid work template is required.");

            return false;
        }

        if (segmentEditModel.WorkSegmentTypeId <= 0)
        {
            ToastService.Error(
                "Please select a segment type.");

            return false;
        }

        if (string.IsNullOrWhiteSpace(segmentEditModel.Name))
        {
            ToastService.Error(
                "Segment name is required.");

            return false;
        }

        if (segmentEditModel.SequenceNumber <= 0)
        {
            ToastService.Error(
                "Sequence number must be greater than zero.");

            return false;
        }

        if (segmentEditModel.OffsetHours < 0 ||
            segmentEditModel.OffsetMinutePart is < 0 or > 59)
        {
            ToastService.Error(
                "Offset minutes must be between 0 and 59.");

            return false;
        }

        if (segmentEditModel.DurationHours < 0 ||
            segmentEditModel.DurationMinutePart is < 0 or > 59)
        {
            ToastService.Error(
                "Duration minutes must be between 0 and 59.");

            return false;
        }

        if (segmentEditModel.DurationMinutes <= 0)
        {
            ToastService.Error(
                "Segment duration must be greater than zero.");

            return false;
        }

        if (segmentEditModel.GraceBeforeMinutes < 0 ||
            segmentEditModel.GraceAfterMinutes < 0)
        {
            ToastService.Error(
                "Grace periods cannot be negative.");

            return false;
        }

        return true;
    }

