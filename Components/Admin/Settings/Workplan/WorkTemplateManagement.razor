@page "/admin/work-planning/templates"

@using HRM.DTOs
@using HRM.DTOs.WorkPlanning
@using HRM.Models.WorkPlanning
@using HRM.Services
@using HRM.Services.Interfaces
@using HRM.Components.Shared

@inject IWorkTemplateService WorkTemplateService
@inject ToastService ToastService
@inject IOperationLogService OperationLogService

<PageTitle>Work Templates</PageTitle>

<div class="space-y-6">

    <!-- Page Header -->
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">Work Templates</h1>
            <p class="mt-1 text-sm text-slate-500">
                Configure reusable shifts, duties and work schedules.
            </p>
        </div>

        <button type="button"
        class="inline-flex items-center justify-center gap-2 rounded-lg
                       bg-blue-600 px-4 py-2 text-sm font-medium text-white
                       shadow-sm transition hover:bg-blue-700"
        @onclick="StartNewTemplate">
            <span class="text-lg leading-none">+</span>
            New Template
        </button>
    </div>

    @if (isLoading)
    {
        <div class="flex min-h-[500px] items-center justify-center
                    rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="text-center">
                <div class="mx-auto h-8 w-8 animate-spin rounded-full
                            border-4 border-slate-200 border-t-blue-600">
                </div>

                <p class="mt-3 text-sm text-slate-500">
                    Loading work templates...
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 gap-2 xl:grid-cols-12">

            <!-- Existing Templates -->
            <div class="xl:col-span-9">
                <div class="overflow-hidden rounded-xl border border-slate-200
                            bg-white shadow-sm">

                    <div class="flex flex-col gap-2 border-b border-slate-100
                                px-5 py-4 sm:flex-row sm:items-center
                                sm:justify-between">
                        <div>
                            <h2 class="font-semibold text-slate-800">
                                Existing Templates
                            </h2>

                            <p class="mt-1 text-xs text-slate-500">
                                @FilteredTemplates.Count template(s)
                            </p>
                        </div>

                        <label class="flex cursor-pointer items-center gap-2">
                            <InputCheckbox @bind-Value="showInactive"
                            class="h-4 w-4 rounded border-slate-300
                                                  text-blue-600 focus:ring-blue-500" />

                            <span class="text-xs text-slate-600">
                                Show inactive templates
                            </span>
                        </label>
                    </div>

                    <div class="border-b border-slate-100 p-4">
                        <div class="relative">
                            <span class="pointer-events-none absolute inset-y-0 left-0
                                         flex items-center pl-3 text-slate-400">
                                <svg class="h-5 w-5"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.8">
                                    <circle cx="11" cy="11" r="7"></circle>
                                    <path d="m20 20-3.5-3.5"></path>
                                </svg>
                            </span>

                            <input type="text"
                            class="w-full rounded-lg border border-slate-300
                                          py-2 pl-10 pr-3 text-sm outline-none
                                          transition focus:border-blue-500
                                          focus:ring-2 focus:ring-blue-100"
                            placeholder="Search templates..."
                            @bind="templateSearch"
                            @bind:event="oninput" />
                        </div>
                    </div>

                    @if (!FilteredTemplates.Any())
                    {
                        <div class="flex min-h-[450px] flex-col items-center
                                    justify-center px-6 text-center">
                            <div class="mb-4 flex h-16 w-16 items-center
                                        justify-center rounded-full bg-slate-100
                                        text-3xl">
                                📋
                            </div>

                            <p class="font-medium text-slate-700">
                                No templates found
                            </p>

                            <p class="mt-1 max-w-sm text-sm text-slate-400">
                                Create a work template or change the current
                                search and inactive filters.
                            </p>

                            <button type="button"
                            class="mt-5 rounded-lg bg-blue-600 px-4 py-2
                                           text-sm font-medium text-white
                                           transition hover:bg-blue-700"
                            @onclick="StartNewTemplate">
                                Create Template
                            </button>
                        </div>
                    }
                    else
                    {
                        <!-- Desktop Table -->
                        <div class="hidden overflow-x-auto md:block">
                            <table class="min-w-full divide-y divide-slate-200">
                                <thead class="bg-slate-50">
                                    <tr>
                                        <th class="px-5 py-3 text-left text-xs font-semibold
                                                   uppercase tracking-wide text-slate-500">
                                            Template
                                        </th>
                                        <th class="px-5 py-3 text-left text-xs font-semibold
                                                   uppercase tracking-wide text-slate-500">
                                            Type
                                        </th>
                                        <th class="px-5 py-3 text-left text-xs font-semibold
                                                   uppercase tracking-wide text-slate-500">
                                            Default Schedule
                                        </th>
                                        <th class="px-5 py-3 text-left text-xs font-semibold
                                                   uppercase tracking-wide text-slate-500">
                                            Segments
                                        </th>
                                        <th class="px-5 py-3 text-left text-xs font-semibold
                                                   uppercase tracking-wide text-slate-500">
                                            Status
                                        </th>
                                        <th class="px-5 py-3 text-right text-xs font-semibold
                                                   uppercase tracking-wide text-slate-500">
                                            Action
                                        </th>
                                    </tr>
                                </thead>

                                <tbody class="divide-y divide-slate-100 bg-white">
                                    @foreach (var template in FilteredTemplates)
                                    {
                                        <tr class="transition hover:bg-slate-50">
                                            <td class="px-5 py-4">
                                                <div class="flex items-start gap-3">
                                                    <div class="flex h-10 w-10 shrink-0
                                                                items-center justify-center
                                                                rounded-lg bg-slate-100 text-xl">
                                                        @GetTemplateIcon(template.TemplateType)
                                                    </div>

                                                    <div class="min-w-0">
                                                        <button type="button"
                                                        class="text-left font-semibold
                                                                       text-slate-800
                                                                       hover:text-blue-600"
                                                        @onclick="() => SelectTemplateAsync(template)">
                                                            @template.Name
                                                        </button>

                                                        @if (!string.IsNullOrWhiteSpace(template.Description))
                                                        {
                                                            <p class="mt-1 max-w-sm truncate
                                                                      text-xs text-slate-500">
                                                                @template.Description
                                                            </p>
                                                        }
                                                    </div>
                                                </div>
                                            </td>

                                            <td class="px-5 py-4 text-sm text-slate-600">
                                                @GetTemplateTypeName(template.TemplateType)
                                            </td>

                                            <td class="px-5 py-4 text-sm text-slate-600">
                                                @GetTimeDescription(template)
                                            </td>

                                            <td class="px-5 py-4 text-sm text-slate-600">
                                                @template.SegmentCount
                                            </td>

                                            <td class="px-5 py-4">
                                                @if (template.IsActive)
                                                {
                                                    <span class="inline-flex rounded-full
                                                                 bg-green-100 px-2.5 py-1
                                                                 text-xs font-medium
                                                                 text-green-700">
                                                        Active
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="inline-flex rounded-full
                                                                 bg-red-100 px-2.5 py-1
                                                                 text-xs font-medium
                                                                 text-red-700">
                                                        Inactive
                                                    </span>
                                                }
                                            </td>

                                            <td class="px-5 py-4 text-right">
                                                <button type="button"
                                                class="rounded-lg border border-slate-300
                                                               bg-white px-3 py-1.5 text-xs
                                                               font-medium text-slate-700
                                                               transition hover:border-blue-300
                                                               hover:bg-blue-50
                                                               hover:text-blue-700"
                                                @onclick="() => SelectTemplateAsync(template)">
                                                    View / Edit
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Mobile Cards -->
                        <div class="divide-y divide-slate-100 md:hidden">
                            @foreach (var template in FilteredTemplates)
                            {
                                <button type="button"
                                class="w-full p-4 text-left transition
                                               hover:bg-slate-50"
                                @onclick="() => SelectTemplateAsync(template)">
                                    <div class="flex items-start gap-3">
                                        <div class="flex h-10 w-10 shrink-0
                                                    items-center justify-center
                                                    rounded-lg bg-slate-100 text-xl">
                                            @GetTemplateIcon(template.TemplateType)
                                        </div>

                                        <div class="min-w-0 flex-1">
                                            <div class="flex items-start justify-between gap-3">
                                                <p class="font-semibold text-slate-800">
                                                    @template.Name
                                                </p>

                                                @if (template.IsActive)
                                                {
                                                    <span class="shrink-0 rounded-full
                                                                 bg-green-100 px-2 py-1
                                                                 text-[11px] font-medium
                                                                 text-green-700">
                                                        Active
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="shrink-0 rounded-full
                                                                 bg-red-100 px-2 py-1
                                                                 text-[11px] font-medium
                                                                 text-red-700">
                                                        Inactive
                                                    </span>
                                                }
                                            </div>

                                            <p class="mt-1 text-xs text-slate-500">
                                                @GetTemplateTypeName(template.TemplateType)
                                            </p>

                                            <div class="mt-2 flex flex-wrap gap-x-4
                                                        gap-y-1 text-xs text-slate-400">
                                                <span>@GetTimeDescription(template)</span>
                                                <span>@template.SegmentCount segment(s)</span>
                                            </div>
                                        </div>
                                    </div>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Quick Templates -->
            <div class="xl:col-span-3">
                <div class="flex h-full flex-col overflow-hidden rounded-xl
                            border border-slate-200 bg-white shadow-sm">

                    <div class="border-b border-slate-100 px-4 py-4">
                        <h2 class="font-semibold text-slate-800">
                            Quick Templates
                        </h2>

                        <p class="mt-1 text-xs text-slate-500">
                            Select a preset and customize it before saving.
                        </p>
                    </div>

                    <div class="border-b border-slate-100 p-4">
                        <input type="text"
                        class="w-full rounded-lg border border-slate-300
                                      px-3 py-2 text-sm outline-none transition
                                      focus:border-blue-500 focus:ring-2
                                      focus:ring-blue-100"
                        placeholder="Search quick templates..."
                        @bind="presetSearch"
                        @bind:event="oninput" />
                    </div>

                    <div class="max-h-[620px] flex-1 space-y-3 overflow-y-auto p-3">
                        @if (!FilteredPresets.Any())
                        {
                            <div class="py-12 text-center">
                                <p class="text-sm font-medium text-slate-600">
                                    No quick templates found
                                </p>

                                <p class="mt-1 text-xs text-slate-400">
                                    Change the quick-template search.
                                </p>
                            </div>
                        }
                        else
                        {
                            @foreach (var preset in FilteredPresets)
                            {
                                <button type="button"
                                class="w-full rounded-lg border
                                               border-slate-200 p-3 text-left
                                               transition hover:border-blue-300
                                               hover:bg-blue-50"
                                @onclick="() => ApplyPreset(preset)">
                                    <div class="flex items-start gap-3">
                                        <div class="flex h-11 w-11 shrink-0
                                                    items-center justify-center
                                                    rounded-lg bg-slate-100 text-2xl">
                                            @preset.Icon
                                        </div>

                                        <div class="min-w-0">
                                            <p class="font-semibold text-slate-800">
                                                @preset.Name
                                            </p>

                                            <p class="mt-1 text-xs leading-5 text-slate-500">
                                                @preset.Description
                                            </p>

                                            @if (preset.DefaultStartTime.HasValue &&
                                                preset.DefaultEndTime.HasValue)
                                            {
                                                <p class="mt-2 text-xs font-medium text-blue-600">
                                                    @FormatPresetTime(preset.DefaultStartTime)
                                                    -
                                                    @FormatPresetTime(preset.DefaultEndTime)
                                                </p>
                                            }
                                        </div>
                                    </div>
                                </button>
                            }
                        }
                    </div>

                    <div class="border-t border-slate-100 bg-slate-50 p-4">
                        <p class="text-xs leading-5 text-slate-500">
                            A preset does not save immediately. Its settings
                            open in the side panel for review.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Template Create/Edit Panel -->
<RightSidePanel @bind-IsOpen="showTemplatePanel"
Title="@PanelTitle"
Description="@PanelDescription"
Size="RightSidePanel.PanelSize.ExtraLarge"
ContentWidth="max-w-4xl"
OnClose="HandleTemplatePanelClosed">

    <ChildContent>
        <EditForm Model="@editModel"
        OnValidSubmit="SaveTemplateAsync"
        id="work-template-form">

            <DataAnnotationsValidator />

            <div class="space-y-6">
                <ValidationSummary class="rounded-lg border border-red-200
                                                  bg-red-50 p-3 text-sm
                                                  text-red-700" />

                <!-- General Details -->
                <section>
                    <div class="mb-4">
                        <h3 class="text-sm font-semibold text-slate-900">
                            General Details
                        </h3>

                        <p class="mt-1 text-xs text-slate-500">
                            Define the name, purpose and category of the template.
                        </p>
                    </div>

                    <div class="space-y-4">
                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Template Name
                                <span class="text-red-500">*</span>
                            </label>

                            <InputText class="w-full rounded-lg border
                                                      border-slate-300 px-3 py-2
                                                      text-sm outline-none transition
                                                      focus:border-blue-500
                                                      focus:ring-2
                                                      focus:ring-blue-100"
                            placeholder="For example, Morning Shift"
                            @bind-Value="editModel.Name" />

                            <ValidationMessage For="@(() => editModel.Name)"
                            class="mt-1 block text-xs text-red-600" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Description
                            </label>

                            <InputTextArea class="min-h-[110px] w-full
                                                  rounded-lg border border-slate-300
                                                  px-3 py-2 text-sm outline-none
                                                  transition focus:border-blue-500
                                                  focus:ring-2 focus:ring-blue-100"
                            placeholder="Describe the purpose of this template..."
                            @bind-Value="editModel.Description" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Template Type
                            </label>

                            <InputSelect class="w-full rounded-lg border
                                                        border-slate-300 px-3 py-2
                                                        text-sm outline-none transition
                                                        focus:border-blue-500
                                                        focus:ring-2
                                                        focus:ring-blue-100"
                            @bind-Value="editModel.TemplateType">
                                <option value="RegularShift">Regular Shift</option>
                                <option value="TemporaryDuty">Temporary Duty</option>
                                <option value="SpecialEvent">Special Event</option>
                                <option value="OnCall">On-call Duty</option>
                                <option value="Training">Training</option>
                            </InputSelect>
                        </div>
                    </div>
                </section>

                <hr class="border-slate-200" />

                <!-- Default Schedule -->
                <section>
                    <div class="mb-4">
                        <h3 class="text-sm font-semibold text-slate-900">
                            Default Schedule
                        </h3>

                        <p class="mt-1 text-xs text-slate-500">
                            Leave both fields empty when the schedule is flexible.
                        </p>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Default Start Time
                            </label>

                            <input type="time"
                            class="w-full rounded-lg border border-slate-300
                                          px-3 py-2 text-sm outline-none transition
                                          focus:border-blue-500 focus:ring-2
                                          focus:ring-blue-100"
                            value="@FormatTime(editModel.DefaultStartTime)"
                            @onchange="OnStartTimeChanged" />
                        </div>

                        <div>
                            <label class="mb-2 block text-sm font-medium text-slate-700">
                                Default End Time
                            </label>

                            <input type="time"
                            class="w-full rounded-lg border border-slate-300
                                          px-3 py-2 text-sm outline-none transition
                                          focus:border-blue-500 focus:ring-2
                                          focus:ring-blue-100"
                            value="@FormatTime(editModel.DefaultEndTime)"
                            @onchange="OnEndTimeChanged" />
                        </div>
                    </div>

                    @if (CrossesMidnight)
                    {
                        <div class="mt-3 rounded-lg border border-blue-200
                                    bg-blue-50 px-3 py-2 text-xs text-blue-700">
                            This schedule ends on the following day.
                        </div>
                    }
                </section>

                <hr class="border-slate-200" />

                <!-- Attendance and Validation -->
                <section>
                    <div class="mb-4">
                        <h3 class="text-sm font-semibold text-slate-900">
                            Attendance and Validation
                        </h3>

                        <p class="mt-1 text-xs text-slate-500">
                            These settings become the defaults for work plans
                            and employee assignments.
                        </p>
                    </div>

                    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                        <ToggleOption Title="Attendance Required"
                        Description="Employees must record attendance."
                        @bind-Value="editModel.RequiresAttendance" />

                        <ToggleOption Title="Checkout Required"
                        Description="Employees must complete checkout."
                        @bind-Value="editModel.RequiresCheckOut" />

                        <ToggleOption Title="Location Validation"
                        Description="Validate the employee's work location."
                        @bind-Value="editModel.RequiresLocationValidation" />

                        <ToggleOption Title="Device Validation"
                        Description="Validate the registered employee device."
                        @bind-Value="editModel.RequiresDeviceValidation" />

                        <ToggleOption Title="Allow Schedule Overlap"
                        Description="Allow overlap with another assignment."
                        @bind-Value="editModel.AllowsOverlap" />

                        <ToggleOption Title="Active Template"
                        Description="Make this template available for planning."
                        @bind-Value="editModel.IsActive" />
                    </div>
                </section>

                <!-- Segments -->
                <section class="border-t border-slate-200 pt-6">
                    <div class="flex flex-col gap-4 sm:flex-row
                                sm:items-center sm:justify-between">
                        <div>
                            <h3 class="text-base font-semibold text-slate-900">
                                Template Segments
                            </h3>

                            <p class="mt-1 text-sm text-slate-500">
                                Define work periods, breaks and attendance rules
                                relative to the template start time.
                            </p>
                        </div>

                        <button type="button"
                        disabled="@(!CanManageSegments)"
                        @onclick="OpenAddSegmentPanel"
                        class="inline-flex items-center justify-center gap-2
                                       rounded-lg bg-blue-600 px-4 py-2 text-sm
                                       font-medium text-white transition
                                       hover:bg-blue-700 disabled:cursor-not-allowed
                                       disabled:opacity-50">
                            <svg xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            class="h-5 w-5">
                                <path stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M12 4.5v15m7.5-7.5h-15" />
                            </svg>

                            Add Segment
                        </button>
                    </div>

                    @if (!CanManageSegments)
                    {
                        <div class="mt-5 rounded-xl border border-amber-200
                                    bg-amber-50 p-4">
                            <div class="flex gap-3">
                                <div class="mt-0.5 text-amber-600">
                                    <svg xmlns="http://www.w3.org/2000/svg"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke-width="1.5"
                                    stroke="currentColor"
                                    class="h-5 w-5">
                                        <path stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M12 9v3.75m9-.75a9 9 0 11-18 0
                                                 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
                                    </svg>
                                </div>

                                <div>
                                    <p class="text-sm font-medium text-amber-800">
                                        Save the template first
                                    </p>

                                    <p class="mt-1 text-sm text-amber-700">
                                        Segments can be added after the work template
                                        has been created.
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                    else if (isLoadingSegments)
                    {
                        <div class="mt-5 rounded-xl border border-slate-200
                                    bg-white p-8 text-center">
                            <p class="text-sm text-slate-500">
                                Loading segments...
                            </p>
                        </div>
                    }
                    else if (!segments.Any())
                    {
                        <div class="mt-5 rounded-xl border-2 border-dashed
                                    border-slate-200 bg-slate-50/50 px-6
                                    py-10 text-center">
                            <div class="mx-auto flex h-12 w-12 items-center
                                        justify-center rounded-full bg-blue-50
                                        text-blue-600">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="h-6 w-6">
                                    <path stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M6.75 3v2.25m10.5-2.25v2.25M3.75
                                             18.75V7.5A2.25 2.25 0 016 5.25h12A2.25
                                             2.25 0 0120.25 7.5v11.25M3.75
                                             18.75A2.25 2.25 0 006 21h12a2.25
                                             2.25 0 002.25-2.25M3.75
                                             18.75v-7.5A2.25 2.25 0 016
                                             9h12a2.25 2.25 0 012.25 2.25v7.5" />
                                </svg>
                            </div>

                            <h4 class="mt-4 text-sm font-semibold text-slate-900">
                                No segments configured
                            </h4>

                            <p class="mx-auto mt-1 max-w-sm text-sm text-slate-500">
                                Add the first work, break, lunch or other segment
                                to this template.
                            </p>

                            <button type="button"
                            @onclick="OpenAddSegmentPanel"
                            class="mt-5 rounded-lg border border-blue-200
                                           bg-blue-50 px-4 py-2 text-sm
                                           font-medium text-blue-700 transition
                                           hover:bg-blue-100">
                                Add First Segment
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="mt-5 space-y-3">
                            @foreach (var segment in segments.OrderBy(x => x.SequenceNumber))
                            {
                                <div class="group rounded-xl border border-slate-200
                                            bg-white p-4 transition
                                            hover:border-blue-200 hover:shadow-sm">
                                    <div class="flex items-start justify-between gap-4">
                                        <div class="flex min-w-0 flex-1 gap-3">
                                            <div class="flex h-9 w-9 shrink-0 items-center
                                                        justify-center rounded-lg bg-slate-100
                                                        text-sm font-semibold text-slate-600">
                                                @segment.SequenceNumber
                                            </div>

                                            <div class="min-w-0 flex-1">
                                                <div class="flex flex-wrap items-center gap-2">
                                                    <h4 class="truncate text-sm font-semibold
                                                               text-slate-900">
                                                        @segment.Name
                                                    </h4>

                                                    <span class="rounded-full bg-blue-50 px-2
                                                                 py-0.5 text-xs font-medium
                                                                 text-blue-700">
                                                        @segment.WorkSegmentTypeName
                                                    </span>

                                                    @if (segment.IsMandatory)
                                                    {
                                                        <span class="rounded-full bg-rose-50 px-2
                                                                     py-0.5 text-xs font-medium
                                                                     text-rose-700">
                                                            Mandatory
