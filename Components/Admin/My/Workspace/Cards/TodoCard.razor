@using HRM.Components.Cards
<BaseCard Title="My To Do">

    <div class="divide-y divide-slate-100">

        <button class="w-full text-left px-4 py-3 hover:bg-slate-50 transition">

            <div class="flex justify-between items-start">

                <div>

                    <div class="text-sm font-medium text-slate-800">
                        Approve Annual Leave
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        Ahmed Ali • Annual Leave • 3 days
                    </div>

                </div>

                <span class="px-2 py-1 rounded-full bg-red-100 text-red-600 text-xs">
                    High
                </span>

            </div>

        </button>

        <button class="w-full text-left px-4 py-3 hover:bg-slate-50 transition">

            <div class="flex justify-between items-start">

                <div>

                    <div class="text-sm font-medium text-slate-800">
                        Review Attendance Exceptions
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        2 team members require review.
                    </div>

                </div>

                <span class="px-2 py-1 rounded-full bg-amber-100 text-amber-700 text-xs">
                    Medium
                </span>

            </div>

        </button>

        <button class="w-full text-left px-4 py-3 hover:bg-slate-50 transition">

            <div class="flex justify-between items-start">

                <div>

                    <div class="text-sm font-medium text-slate-800">
                        Approve Overtime Request
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        Mohamed Hassan • 4 hours
                    </div>

                </div>

                <span class="px-2 py-1 rounded-full bg-blue-100 text-blue-700 text-xs">
                    Normal
                </span>

            </div>

        </button>

        <button class="w-full text-left px-4 py-3 hover:bg-slate-50 transition">

            <div class="flex justify-between items-start">

                <div>

                    <div class="text-sm font-medium text-slate-800">
                        Complete Performance Review
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        Due by 15 July 2026
                    </div>

                </div>

                <span class="px-2 py-1 rounded-full bg-violet-100 text-violet-700 text-xs">
                    Upcoming
                </span>

            </div>

        </button>

    </div>

    <div class="border-t border-slate-100 p-3 text-center">

        <button class="text-sm font-medium text-blue-600 hover:text-blue-700">
            View All Tasks
        </button>

    </div>

</BaseCard>