@using HRM.Components.Cards
<BaseCard Title="Pending Leave Requests">

    <div class="divide-y divide-slate-100">

        <button class="w-full text-left px-4 py-3 hover:bg-slate-50 transition">

            <div class="flex justify-between items-start">

                <div>

                    <div class="text-sm font-medium text-slate-800">
                        Ahmed Ali
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        Annual Leave • 14 Jul - 16 Jul (3 Days)
                    </div>

                </div>

                <span class="px-2 py-1 rounded-full bg-amber-100 text-amber-700 text-xs">
                    Pending
                </span>

            </div>

        </button>

        <button class="w-full text-left px-4 py-3 hover:bg-slate-50 transition">

            <div class="flex justify-between items-start">

                <div>

                    <div class="text-sm font-medium text-slate-800">
                        Mariyam Hassan
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        Medical Leave • Today (1 Day)
                    </div>

                </div>

                <span class="px-2 py-1 rounded-full bg-amber-100 text-amber-700 text-xs">
                    Pending
                </span>

            </div>

        </button>

        <button class="w-full text-left px-4 py-3 hover:bg-slate-50 transition">

            <div class="flex justify-between items-start">

                <div>

                    <div class="text-sm font-medium text-slate-800">
                        Mohamed Ibrahim
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        Casual Leave • 18 Jul (1 Day)
                    </div>

                </div>

                <span class="px-2 py-1 rounded-full bg-red-100 text-red-600 text-xs">
                    Urgent
                </span>

            </div>

        </button>

        <button class="w-full text-left px-4 py-3 hover:bg-slate-50 transition">

            <div class="flex justify-between items-start">

                <div>

                    <div class="text-sm font-medium text-slate-800">
                        Ibrahim Rasheed
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        Maternity Leave • 1 Aug - 30 Sep
                    </div>

                </div>

                <span class="px-2 py-1 rounded-full bg-blue-100 text-blue-700 text-xs">
                    Waiting
                </span>

            </div>

        </button>

    </div>

    <div class="border-t border-slate-100 px-4 py-3 flex justify-between items-center">

        <span class="text-xs text-slate-500">
            4 pending requests
        </span>

        <button class="text-sm font-medium text-blue-600 hover:text-blue-700">
            View All
        </button>

    </div>

</BaseCard>