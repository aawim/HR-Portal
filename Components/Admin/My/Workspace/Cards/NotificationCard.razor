@using HRM.Components.Cards

<BaseCard Title="@Title">

    <div class="divide-y divide-slate-100">

        <button class="w-full text-left px-4 py-3 hover:bg-slate-50 transition">

            <div class="flex items-start gap-3">

                <div class="mt-1 h-2.5 w-2.5 rounded-full bg-red-500"></div>

                <div class="flex-1">

                    <div class="text-sm font-medium text-slate-800">
                        Leave Request Pending Approval
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        Ahmed Ali submitted an Annual Leave request awaiting your approval.
                    </div>

                    <div class="text-xs text-slate-400 mt-2">
                        15 minutes ago
                    </div>

                </div>

            </div>

        </button>

        <button class="w-full text-left px-4 py-3 hover:bg-slate-50 transition">

            <div class="flex items-start gap-3">

                <div class="mt-1 h-2.5 w-2.5 rounded-full bg-amber-500"></div>

                <div class="flex-1">

                    <div class="text-sm font-medium text-slate-800">
                        Attendance Exception
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        2 team members have missing check-out records today.
                    </div>

                    <div class="text-xs text-slate-400 mt-2">
                        1 hour ago
                    </div>

                </div>

            </div>

        </button>

        <button class="w-full text-left px-4 py-3 hover:bg-slate-50 transition">

            <div class="flex items-start gap-3">

                <div class="mt-1 h-2.5 w-2.5 rounded-full bg-blue-500"></div>

                <div class="flex-1">

                    <div class="text-sm font-medium text-slate-800">
                        New Document Uploaded
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        HR has published the updated Employee Handbook.
                    </div>

                    <div class="text-xs text-slate-400 mt-2">
                        Yesterday
                    </div>

                </div>

            </div>

        </button>

        <button class="w-full text-left px-4 py-3 hover:bg-slate-50 transition">

            <div class="flex items-start gap-3">

                <div class="mt-1 h-2.5 w-2.5 rounded-full bg-green-500"></div>

                <div class="flex-1">

                    <div class="text-sm font-medium text-slate-800">
                        Overtime Approved
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        Your overtime request for 8 July has been approved.
                    </div>

                    <div class="text-xs text-slate-400 mt-2">
                        2 days ago
                    </div>

                </div>

            </div>

        </button>

    </div>

    <div class="border-t border-slate-100 p-3 text-center">

        <button class="text-sm text-blue-600 hover:text-blue-700 font-medium">
            View All Notifications
        </button>

    </div>

</BaseCard>


@code{


    [Parameter] public string Title { get; set; } = "";
}