@using HRM.Components.Cards
<BaseCard Title="Calendar">

    <div class="p-4">

        <!-- Month -->
        <div class="flex items-center justify-between mb-4">

            <button class="text-slate-400 hover:text-slate-700">
                ◀
            </button>

            <div class="text-sm font-semibold text-slate-800">
                July 2026
            </div>

            <button class="text-slate-400 hover:text-slate-700">
                ▶
            </button>

        </div>

        <!-- Week Days -->
        <div class="grid grid-cols-7 text-center text-xs font-medium text-slate-500 mb-2">

            <div>Sun</div>
            <div>Mon</div>
            <div>Tue</div>
            <div>Wed</div>
            <div>Thu</div>
            <div>Fri</div>
            <div>Sat</div>

        </div>

        <!-- Calendar -->
        <div class="grid grid-cols-7 gap-1 text-sm">

            @for (int i = 1; i <= 31; i++)
            {
                <button class="aspect-square rounded-lg hover:bg-slate-100 text-slate-700">

                    @if (i == 12)
                    {
                        <span class="flex items-center justify-center w-full h-full rounded-lg bg-blue-600 text-white">
                            @i
                        </span>
                    }
                    else if (i == 15 || i == 18)
                    {
                        <span class="relative flex items-center justify-center w-full h-full">

                            @i

                            <span class="absolute bottom-1 w-1.5 h-1.5 rounded-full bg-red-500"></span>

                        </span>
                    }
                    else
                    {
                        @i
                    }

                </button>
            }

        </div>

    </div>

    <div class="border-t border-slate-100">

        <div class="px-4 py-3">

            <div class="text-xs font-semibold uppercase text-slate-500 mb-2">
                Upcoming
            </div>

            <div class="space-y-2">

                <div class="flex justify-between text-sm">
                    <span>Annual Leave - Ahmed Ali</span>
                    <span class="text-slate-500">14 Jul</span>
                </div>

                <div class="flex justify-between text-sm">
                    <span>Public Holiday</span>
                    <span class="text-slate-500">26 Jul</span>
                </div>

                <div class="flex justify-between text-sm">
                    <span>Birthday - Mariyam</span>
                    <span class="text-slate-500">28 Jul</span>
                </div>

            </div>

        </div>

    </div>

</BaseCard>