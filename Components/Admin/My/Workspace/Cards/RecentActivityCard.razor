@using HRM.Components.Cards

<BaseCard Title="Recent Activity">

    <div class="divide-y divide-slate-100">

        <div class="px-4 py-3">

            <div class="flex items-start gap-3">

                <div class="mt-1 h-2.5 w-2.5 rounded-full bg-green-500"></div>

                <div class="flex-1">

                    <div class="text-sm text-slate-800">
                        <span class="font-medium">Ahmed Ali</span> checked in.
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        Today • 08:02 AM
                    </div>

                </div>

            </div>

        </div>

        <div class="px-4 py-3">

            <div class="flex items-start gap-3">

                <div class="mt-1 h-2.5 w-2.5 rounded-full bg-blue-500"></div>

                <div class="flex-1">

                    <div class="text-sm text-slate-800">
                        <span class="font-medium">Fatimath Hassan</span> submitted an Annual Leave request.
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        Today • 09:35 AM
                    </div>

                </div>

            </div>

        </div>

        <div class="px-4 py-3">

            <div class="flex items-start gap-3">

                <div class="mt-1 h-2.5 w-2.5 rounded-full bg-amber-500"></div>

                <div class="flex-1">

                    <div class="text-sm text-slate-800">
                        <span class="font-medium">Mohamed Shareef</span> requested 2 hours of overtime.
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        Yesterday • 05:10 PM
                    </div>

                </div>

            </div>

        </div>

        <div class="px-4 py-3">

            <div class="flex items-start gap-3">

                <div class="mt-1 h-2.5 w-2.5 rounded-full bg-red-500"></div>

                <div class="flex-1">

                    <div class="text-sm text-slate-800">
                        <span class="font-medium">Ali Rasheed</span> missed check-out.
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        Yesterday • 06:02 PM
                    </div>

                </div>

            </div>

        </div>

        <div class="px-4 py-3">

            <div class="flex items-start gap-3">

                <div class="mt-1 h-2.5 w-2.5 rounded-full bg-violet-500"></div>

                <div class="flex-1">

                    <div class="text-sm text-slate-800">
                        Employee Handbook was updated.
                    </div>

                    <div class="text-xs text-slate-500 mt-1">
                        2 days ago
                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="border-t border-slate-100 p-3 text-center">

        <button class="text-sm font-medium text-blue-600 hover:text-blue-700">
            View Activity History
        </button>

    </div>

</BaseCard>