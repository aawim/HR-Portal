    private static int GetAssignmentPercentage(
        WorkAssignmentGroupDto group)
    {
        if (group.RequiredStaffCount <= 0)
            return 0;

        var percentage =
            (int)Math.Round(
                group.AssignedStaffCount * 100d /
                group.RequiredStaffCount);

        return Math.Clamp(
            percentage,
            0,
            100);
    }

