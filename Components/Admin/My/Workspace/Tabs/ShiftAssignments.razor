@page "/admin/work-planning/assignments"

@using HRM.WorkPlanning.Abstractions
@using HRM.Services.Interfaces
@using HRM.DTOs.WorkPlanning

@inject IWorkAssignmentManagementService AssignmentManagementService

<PageTitle>Work Assignments</PageTitle>

<div class="min-h-screen bg-slate-50 p-4 md:p-6">

    <div class="mx-auto max-w-7xl">

        <!-- Page Header -->
        <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">

            <div>
                <h1 class="text-2xl font-bold text-slate-900">
                    Work Assignments
                </h1>

                <p class="mt-1 text-sm text-slate-500">
                    View and assign work plans to department employees.
                </p>
            </div>

            <button type="button"
                    class="inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700 disabled:cursor-not-allowed disabled:opacity-60"
                    disabled="@IsLoadingLookups"
                    @onclick="OpenBulkAssignmentModal">

                <span class="text-lg leading-none">+</span>
                Assign Employees
            </button>

        </div>

        <!-- Messages -->
        @if (!string.IsNullOrWhiteSpace(SuccessMessage))
        {
            <div class="mb-4 flex items-start justify-between rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">

                <span>@SuccessMessage</span>

                <button type="button"
                        class="ml-4 font-semibold"
                        @onclick="ClearMessages">
                    ×
                </button>

            </div>
        }

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="mb-4 flex items-start justify-between rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">

                <span>@ErrorMessage</span>

                <button type="button"
                        class="ml-4 font-semibold"
                        @onclick="ClearMessages">
                    ×
                </button>

            </div>
        }

        <!-- Summary Cards -->
        <div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">

            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <p class="text-sm font-medium text-slate-500">
                    Assignment Groups
                </p>

                <p class="mt-2 text-3xl font-bold text-slate-900">
                    @AssignmentGroups.Count
                </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <p class="text-sm font-medium text-slate-500">
                    Total Assignments
                </p>

                <p class="mt-2 text-3xl font-bold text-slate-900">
                    @TotalAssignments
                </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <p class="text-sm font-medium text-slate-500">
                    Assigned
                </p>

                <p class="mt-2 text-3xl font-bold text-emerald-600">
                    @TotalAssigned
                </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <p class="text-sm font-medium text-slate-500">
                    Not Assigned
                </p>

                <p class="mt-2 text-3xl font-bold text-amber-600">
                    @TotalUnassigned
                </p>
            </div>

        </div>

        <!-- Filters -->
        <div class="mb-6 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">

            <div class="mb-4 flex items-center justify-between">
                <h2 class="text-base font-semibold text-slate-900">
                    Filters
                </h2>

                <button type="button"
                        class="text-sm font-medium text-slate-500 hover:text-slate-800"
                        @onclick="ResetFiltersAsync">
                    Reset
                </button>
            </div>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-5">

                <div>
                    <label class="mb-1.5 block text-sm font-medium text-slate-700">
                        From date
                    </label>

                    <InputDate @bind-Value="Filter.FromDate"
                               class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
                </div>

                <div>
                    <label class="mb-1.5 block text-sm font-medium text-slate-700">
                        To date
                    </label>

                    <InputDate @bind-Value="Filter.ToDate"
                               class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
                </div>

                <div>
                    <label class="mb-1.5 block text-sm font-medium text-slate-700">
                        Department
                    </label>

                    <InputSelect @bind-Value="Filter.OrganisationStructureId"
                                 class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100">

                        <option value="">All departments</option>

                        @foreach (var department in Departments)
                        {
                            <option value="@department.OrganisationStructureId">
                                @department.DepartmentName
                            </option>
                        }

                    </InputSelect>
                </div>

                <div>
                    <label class="mb-1.5 block text-sm font-medium text-slate-700">
                        Work plan
                    </label>

                    <InputSelect @bind-Value="Filter.WorkPlanId"
                                 class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100">

                        <option value="">All work plans</option>

                        @foreach (var workPlan in WorkPlans)
                        {
                            <option value="@workPlan.WorkPlanId">
                                @GetWorkPlanDisplayText(workPlan)
                            </option>
                        }

                    </InputSelect>
                </div>

                <div>
                    <label class="mb-1.5 block text-sm font-medium text-slate-700">
                        Search
                    </label>

                    <InputText @bind-Value="Filter.SearchText"
                               placeholder="Assignment or department..."
                               class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
                </div>

            </div>

            <div class="mt-4 flex justify-end">

                <button type="button"
                        disabled="@IsLoadingAssignments"
                        class="inline-flex min-w-28 items-center justify-center rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700 disabled:cursor-not-allowed disabled:opacity-60"
                        @onclick="LoadAssignmentsAsync">

                    @if (IsLoadingAssignments)
                    {
                        <span>Loading...</span>
                    }
                    else
                    {
                        <span>Apply Filters</span>
                    }

                </button>

            </div>

        </div>

        <!-- Assignment Table -->
        <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">

            <div class="border-b border-slate-200 px-5 py-4">
                <h2 class="text-base font-semibold text-slate-900">
                    Assignment Schedule
                </h2>
            </div>

            @if (IsLoadingAssignments)
            {
                <div class="flex min-h-64 items-center justify-center">

                    <div class="text-center">
                        <div class="mx-auto h-8 w-8 animate-spin rounded-full border-4 border-slate-200 border-t-blue-600"></div>

                        <p class="mt-3 text-sm text-slate-500">
                            Loading assignments...
                        </p>
                    </div>

                </div>
            }
            else if (AssignmentGroups.Count == 0)
            {
                <div class="flex min-h-64 items-center justify-center px-6">

                    <div class="text-center">
                        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-xl">
                            📋
                        </div>

                        <h3 class="mt-3 font-semibold text-slate-900">
                            No work assignments found
                        </h3>

                        <p class="mt-1 text-sm text-slate-500">
                            Change the filters or assign employees to a work plan.
                        </p>
                    </div>

                </div>
            }
            else
            {
                <div class="overflow-x-auto">

                    <table class="min-w-full divide-y divide-slate-200">

                        <thead class="bg-slate-50">
                            <tr>
                                <th class="w-12 px-4 py-3"></th>

                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                                    Date
                                </th>

                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                                    Assignment
                                </th>

                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                                    Department
                                </th>

                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                                    Time
                                </th>

                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                                    Assigned
                                </th>

                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                                    Status
                                </th>

                                <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">
                                    Actions
                                </th>
                            </tr>
                        </thead>

                        <tbody class="divide-y divide-slate-100 bg-white">

                            @foreach (var group in AssignmentGroups)
                            {
                                <tr class="hover:bg-slate-50">

                                    <td class="px-4 py-4">

                                        <button type="button"
                                                title="View assigned employees"
                                                class="flex h-8 w-8 items-center justify-center rounded-lg border border-slate-200 text-slate-600 transition hover:bg-slate-100"
                                                @onclick="() => ToggleGroupAsync(group)">

                                            @if (IsExpanded(group))
                                            {
                                                <span>−</span>
                                            }
                                            else
                                            {
                                                <span>+</span>
                                            }

                                        </button>

                                    </td>

                                    <td class="whitespace-nowrap px-4 py-4 text-sm text-slate-700">
                                        @group.ScheduledStart.ToString("dd MMM yyyy")
                                    </td>

                                    <td class="px-4 py-4">

                                        <p class="text-sm font-semibold text-slate-900">
                                            @group.AssignmentName
                                        </p>

                                        @if (group.WorkPlanId == 1)
                                        {
                                            <p class="mt-0.5 text-xs text-slate-500">
                                                Plan ID: @group.WorkPlanId
                                            </p>
                                        }

                                    </td>

                                    <td class="px-4 py-4 text-sm text-slate-700">
                                        @group.DepartmentName
                                    </td>

                                    <td class="whitespace-nowrap px-4 py-4 text-sm text-slate-700">

                                        <div>
                                            @group.ScheduledStart.ToString("HH:mm")
                                            -
                                            @group.ScheduledEnd.ToString("HH:mm")
                                        </div>

                                        @if (group.ScheduledStart.Date != group.ScheduledEnd.Date)
                                        {
                                            <div class="mt-0.5 text-xs text-slate-500">
                                                Ends @group.ScheduledEnd.ToString("dd MMM")
                                            </div>
                                        }

                                    </td>

                                    <td class="px-4 py-4">

                                        <div class="min-w-32">

                                            <div class="mb-1 flex items-center justify-between text-xs">
                                                <span class="font-medium text-slate-700">
                                                    @group.AssignedStaffCount /
                                                    @group.RequiredStaffCount
                                                </span>

                                                <span class="text-slate-500">
                                                    @GetAssignmentPercentage(group)%
                                                </span>
                                            </div>

                                            <div class="h-2 overflow-hidden rounded-full bg-slate-100">

                                                <div class="h-full rounded-full bg-blue-600"
                                                     style="@($"width: {GetAssignmentPercentage(group)}%;")">
                                                </div>

                                            </div>

                                        </div>

                                    </td>

                                    <td class="px-4 py-4">
                                        <span class="@GetStatusCss(group.AssignmentStatus)">
                                            @group.AssignmentStatus
                                        </span>
                                    </td>

                                    <td class="px-4 py-4 text-right">

                                        <button type="button"
                                                class="rounded-lg border border-blue-200 bg-blue-50 px-3 py-2 text-xs font-semibold text-blue-700 transition hover:bg-blue-100"
                                                @onclick="() => OpenAddEmployeesModalAsync(group)">
                                            Add Staff
                                        </button>

                                    </td>

                                </tr>

                                @if (IsExpanded(group))
                                {
                                    <tr>
                                        <td colspan="8"
                                            class="bg-slate-50 px-6 py-5">

                                            @if (LoadingGroupId == group.GroupId)
                                            {
                                                <div class="py-6 text-center text-sm text-slate-500">
                                                    Loading employees...
                                                </div>
                                            }
                                            else if (group.Employees == null ||
                                            group.Employees.Count == 0)
                                            {
                                                <div class="rounded-lg border border-dashed border-slate-300 bg-white px-5 py-8 text-center">

                                                    <p class="text-sm font-medium text-slate-700">
                                                        No assigned employees
                                                    </p>

                                                    <p class="mt-1 text-xs text-slate-500">
                                                        Use Add Staff to assign employees.
                                                    </p>

                                                </div>
                                            }
                                            else
                                            {
                                                <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">

                                                    <table class="min-w-full divide-y divide-slate-200">

                                                        <thead class="bg-slate-50">
                                                            <tr>
                                                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">
                                                                    Employee
                                                                </th>

                                                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">
                                                                    Position
                                                                </th>

                                                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">
                                                                    Ownership
                                                                </th>

                                                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-500">
                                                                    Assignment status
                                                                </th>
                                                            </tr>
                                                        </thead>

                                                        <tbody class="divide-y divide-slate-100">

                                                            @foreach (var employee in group.Employees)
                                                            {
                                                                <tr>
                                                                    <td class="px-4 py-3">

                                                                        <p class="text-sm font-semibold text-slate-900">
                                                                            @employee.EmployeeName
                                                                        </p>

                                                                        <p class="text-xs text-slate-500">
                                                                            Individual ID:
                                                                            @employee.IndividualId
                                                                        </p>

                                                                    </td>

                                                                    <td class="px-4 py-3 text-sm text-slate-700">
                                                                        @employee.JobTitle
                                                                    </td>

                                                                    <td class="px-4 py-3">

                                                                        @if (employee.HasCurrentOwner)
                                                                        {
                                                                            <span class="inline-flex rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-700">
                                                                                Current owner
                                                                            </span>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-600">
                                                                                Not assigned
                                                                            </span>
                                                                        }

                                                                    </td>

                                                                    <td class="px-4 py-3 text-sm text-slate-700">
                                                                        @employee.AssignmentState
                                                                    </td>
                                                                </tr>
                                                            }

                                                        </tbody>

                                                    </table>

                                                </div>
                                            }

                                        </td>
                                    </tr>
                                }
                            }

                        </tbody>

                    </table>

                </div>
            }

        </div>

    </div>

</div>

<!-- Bulk Assignment Modal -->
@if (ShowBulkAssignmentModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 p-4">

        <div class="max-h-[92vh] w-full max-w-4xl overflow-hidden rounded-2xl bg-white shadow-2xl">

            <div class="flex items-center justify-between border-b border-slate-200 px-6 py-4">

                <div>
                    <h2 class="text-lg font-bold text-slate-900">
                        Assign Employees
                    </h2>

                    <p class="mt-1 text-sm text-slate-500">
                        Create one work assignment for each selected employee.
                    </p>
                </div>

                <button type="button"
                        disabled="@IsSavingAssignment"
                        class="flex h-9 w-9 items-center justify-center rounded-lg text-xl text-slate-500 hover:bg-slate-100"
                        @onclick="CloseBulkAssignmentModal">
                    ×
                </button>

            </div>

            <div class="max-h-[calc(92vh-145px)] overflow-y-auto p-6">

                @if (!string.IsNullOrWhiteSpace(ModalErrorMessage))
                {
                    <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                        @ModalErrorMessage
                    </div>
                }

                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700">
                            Department <span class="text-red-500">*</span>
                        </label>

                        <InputSelect @bind-Value="BulkRequest.OrganisationStructureId"
                                     @bind-Value:after="OnDepartmentChangedAsync"
                                     disabled="@IsSavingAssignment"
                                     class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm">

                            <option value="0">
                                Select department
                            </option>

                            @foreach (var department in Departments)
                            {
                                <option value="@department.OrganisationStructureId">
                                    @department.DepartmentName
                                </option>
                            }

                        </InputSelect>
                    </div>

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700">
                            Work plan
                        </label>

                        <InputSelect @bind-Value="BulkRequest.WorkPlanId"
                                     disabled="@IsSavingAssignment"
                                     class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm">

                            <option value="">
                                Select work plan
                            </option>

                            @foreach (var workPlan in WorkPlans)
                            {
                                <option value="@workPlan.WorkPlanId">
                                    @GetWorkPlanDisplayText(workPlan)
                                </option>
                            }

                        </InputSelect>
                    </div>

                    <div class="md:col-span-2">
                        <label class="mb-1.5 block text-sm font-medium text-slate-700">
                            Assignment name <span class="text-red-500">*</span>
                        </label>

                        <InputText @bind-Value="BulkRequest.AssignmentName"
                                   disabled="@IsSavingAssignment"
                                   placeholder="For example: Morning Reception Duty"
                                   class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm" />
                    </div>

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700">
                            Start date and time <span class="text-red-500">*</span>
                        </label>

                        <input type="datetime-local"
                               value="@ToDateTimeLocalValue(BulkRequest.ScheduledStart)"
                               @onchange="OnBulkStartChanged"
                               disabled="@IsSavingAssignment"
                               class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm" />
                    </div>

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-slate-700">
                            End date and time <span class="text-red-500">*</span>
                        </label>

                        <input type="datetime-local"
                               value="@ToDateTimeLocalValue(BulkRequest.ScheduledEnd)"
                               @onchange="OnBulkEndChanged"
                               disabled="@IsSavingAssignment"
                               class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm" />
                    </div>

                    <div class="md:col-span-2">
                        <label class="mb-1.5 block text-sm font-medium text-slate-700">
                            Remarks
                        </label>

                        <InputTextArea @bind-Value="BulkRequest.Remarks"
                                       disabled="@IsSavingAssignment"
                                       rows="3"
                                       placeholder="Optional remarks..."
                                       class="w-full resize-none rounded-lg border border-slate-300 px-3 py-2.5 text-sm" />
                    </div>

                </div>

                <!-- Employee Selection -->
                <div class="mt-6">

                    <div class="mb-3 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">

                        <div>
                            <h3 class="font-semibold text-slate-900">
                                Department Employees
                            </h3>

                            <p class="mt-0.5 text-sm text-slate-500">
                                @SelectedEmployeeCount employee(s) selected
                            </p>
                        </div>

                        @if (DepartmentStaff.Count > 0)
                        {
                            <div class="flex gap-2">

                                <button type="button"
                                        disabled="@IsSavingAssignment"
                                        class="rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50"
                                        @onclick="SelectAllEmployees">
                                    Select all
                                </button>

                                <button type="button"
                                        disabled="@IsSavingAssignment"
                                        class="rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50"
                                        @onclick="ClearEmployeeSelection">
                                    Clear
                                </button>

                            </div>
                        }

                    </div>

                    @if (IsLoadingDepartmentStaff)
                    {
                        <div class="rounded-lg border border-slate-200 px-4 py-8 text-center text-sm text-slate-500">
                            Loading department employees...
                        </div>
                    }
                    else if (BulkRequest.OrganisationStructureId <= 0)
                    {
                        <div class="rounded-lg border border-dashed border-slate-300 bg-slate-50 px-4 py-8 text-center text-sm text-slate-500">
                            Select a department to load employees.
                        </div>
                    }
                    else if (DepartmentStaff.Count == 0)
                    {
                        <div class="rounded-lg border border-dashed border-slate-300 bg-slate-50 px-4 py-8 text-center text-sm text-slate-500">
                            No active employees were found in this department.
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <input type="text"
                                   @bind="EmployeeSearchText"
                                   @bind:event="oninput"
                                   placeholder="Search employees..."
                                   class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm" />
                        </div>

                        <div class="max-h-80 overflow-y-auto rounded-lg border border-slate-200">

                            @foreach (var employee in FilteredDepartmentStaff)
                            {
                                <label class="flex cursor-pointer items-center gap-3 border-b border-slate-100 px-4 py-3 last:border-b-0 hover:bg-slate-50">

                                    <input type="checkbox"
                                           checked="@employee.IsSelected"
                                           disabled="@IsSavingAssignment"
                                           @onchange="eventArgs => ChangeEmployeeSelection(employee, eventArgs)"
                                           class="h-4 w-4 rounded border-slate-300 text-blue-600" />

                                    <div class="min-w-0 flex-1">

                                        <p class="truncate text-sm font-semibold text-slate-900">
                                            @employee.EmployeeName
                                        </p>

                                        <p class="truncate text-xs text-slate-500">
                                            @employee.JobTitle
                                        </p>

                                    </div>

                                    <span class="text-xs text-slate-400">
                                        Job @employee.JobId
                                    </span>

                                </label>
                            }

                        </div>
                    }

                </div>

            </div>

            <div class="flex items-center justify-end gap-3 border-t border-slate-200 bg-slate-50 px-6 py-4">

                <button type="button"
                        disabled="@IsSavingAssignment"
                        class="rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 disabled:opacity-60"
                        @onclick="CloseBulkAssignmentModal">
                    Cancel
                </button>

                <button type="button"
                        disabled="@IsSavingAssignment"
                        class="min-w-36 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 disabled:cursor-not-allowed disabled:opacity-60"
                        @onclick="SaveBulkAssignmentAsync">

                    @if (IsSavingAssignment)
                    {
                        <span>Assigning...</span>
                    }
                    else
                    {
                        <span>Assign Employees</span>
                    }

                </button>

            </div>

        </div>

    </div>
}

@code {

