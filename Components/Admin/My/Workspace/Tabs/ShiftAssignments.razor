    private string EmployeeSearchText { get; set; } =
        string.Empty;

    private string SuccessMessage { get; set; } =
        string.Empty;

    private string ErrorMessage { get; set; } =
        string.Empty;

    private string ModalErrorMessage { get; set; } =
        string.Empty;

    private int TotalAssignments =>
        AssignmentGroups.Sum(x => x.RequiredStaffCount);

    private int TotalAssigned =>
        AssignmentGroups.Sum(x => x.AssignedStaffCount);

    private int TotalUnassigned =>
        Math.Max(0, TotalAssignments - TotalAssigned);

    private int SelectedEmployeeCount =>
        DepartmentStaff.Count(x => x.IsSelected);

    private IEnumerable<EligibleAssignmentStaffDto>
        FilteredDepartmentStaff
    {
        get
        {
            if (string.IsNullOrWhiteSpace(EmployeeSearchText))
                return DepartmentStaff;

            var search =
                EmployeeSearchText.Trim();

            /*
            * This is an in-memory search, so using
                 * StringComparison is valid here.
                 *
                 * Do not use StringComparison inside an EF query.
                 */
            return DepartmentStaff.Where(x =>
                (!string.IsNullOrWhiteSpace(x.EmployeeName) &&
                 x.EmployeeName.Contains(
                     search,
                     StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrWhiteSpace(x.JobTitle) &&
                 x.JobTitle.Contains(
                     search,
                     StringComparison.OrdinalIgnoreCase)));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupsAsync();
        await LoadAssignmentsAsync();
    }

    private async Task LoadLookupsAsync()
    {
        IsLoadingLookups = true;
        ClearMessages();

        try
        {
            var departmentTask =
                AssignmentManagementService
                    .GetDepartmentsAsync();

            var workPlanTask =
                AssignmentManagementService
                    .GetWorkPlansAsync();

            await Task.WhenAll(
                departmentTask,
                workPlanTask);

            Departments =
                await departmentTask;

            WorkPlans =
                await workPlanTask;
        }
        catch (Exception exception)
        {
            ErrorMessage =
                $"Unable to load assignment lookups: " +
                $"{exception.GetBaseException().Message}";
        }
        finally
        {
            IsLoadingLookups = false;
        }
    }

    private async Task LoadAssignmentsAsync()
    {
        ClearMessages();

        if (Filter.ToDate.Date < Filter.FromDate.Date)
        {
            ErrorMessage =
                "The to date cannot be before the from date.";

            return;
        }

        IsLoadingAssignments = true;

        try
        {
            AssignmentGroups =
                await AssignmentManagementService
                    .GetAssignmentsAsync(Filter);

            ExpandedGroupIds.Clear();
        }
        catch (Exception exception)
        {
            ErrorMessage =
                $"Unable to load assignments: " +
                $"{exception.GetBaseException().Message}";
        }
        finally
        {
            IsLoadingAssignments = false;
        }
    }

    private async Task ToggleGroupAsync(
        WorkAssignmentGroupDto group)
    {
        if (ExpandedGroupIds.Contains(group.GroupId))
        {
            ExpandedGroupIds.Remove(group.GroupId);
            return;
        }

        ExpandedGroupIds.Add(group.GroupId);

        if (group.Employees != null &&
            group.Employees.Count > 0)
        {
            return;
        }

        LoadingGroupId =
            group.GroupId;

        try
        {
            group.Employees =
                await AssignmentManagementService
                    .GetAssignmentEmployeesAsync(
                        group.OrganisationStructureId,
                        group.WorkPlanId,
                        group.AssignmentName,
                        group.ScheduledStart,
                        group.ScheduledEnd);
        }
        catch (Exception exception)
        {
            ErrorMessage =
                $"Unable to load assigned employees: " +
                $"{exception.GetBaseException().Message}";
        }
        finally
        {
            LoadingGroupId = null;
        }
    }

    private bool IsExpanded(
        WorkAssignmentGroupDto group)
    {
        return ExpandedGroupIds.Contains(
            group.GroupId);
    }

    private void OpenBulkAssignmentModal()
    {
        ClearMessages();

        ModalErrorMessage =
            string.Empty;

        EmployeeSearchText =
            string.Empty;

        DepartmentStaff.Clear();

        BulkRequest =
            CreateDefaultBulkRequest();

        ShowBulkAssignmentModal =
            true;
    }

    private async Task OpenAddEmployeesModalAsync(
        WorkAssignmentGroupDto group)
    {
        ClearMessages();

        ModalErrorMessage =
            string.Empty;

        EmployeeSearchText =
            string.Empty;

        BulkRequest =
            new BulkDepartmentAssignmentRequest
                {
                    OrganisationStructureId =
                        group.OrganisationStructureId,

                    WorkPlanId =
                        group.WorkPlanId,

                    AssignmentName =
                        group.AssignmentName,

                    ScheduledStart =
                        group.ScheduledStart,

                    ScheduledEnd =
                        group.ScheduledEnd,

                    SelectedIndividualIds =
                        new List<int>()
                };

        ShowBulkAssignmentModal =
            true;

        await LoadDepartmentStaffAsync();
    }

    private void CloseBulkAssignmentModal()
    {
        if (IsSavingAssignment)
            return;

        ShowBulkAssignmentModal =
            false;

        ModalErrorMessage =
            string.Empty;

        EmployeeSearchText =
            string.Empty;

        DepartmentStaff.Clear();
    }

    private async Task OnDepartmentChangedAsync()
    {
        BulkRequest.SelectedIndividualIds.Clear();

        EmployeeSearchText =
            string.Empty;

        DepartmentStaff.Clear();

        if (BulkRequest.OrganisationStructureId <= 0)
            return;

        await LoadDepartmentStaffAsync();
    }

    private async Task LoadDepartmentStaffAsync()
    {
        if (BulkRequest.OrganisationStructureId <= 0)
            return;

        IsLoadingDepartmentStaff = true;
        ModalErrorMessage = string.Empty;

        try
        {
            DepartmentStaff =
                await AssignmentManagementService
                    .GetDepartmentStaffAsync(
                        BulkRequest.OrganisationStructureId);

            foreach (var employee in DepartmentStaff)
            {
                employee.IsSelected = false;
            }
        }
        catch (Exception exception)
        {
            ModalErrorMessage =
                $"Unable to load department employees: " +
                $"{exception.GetBaseException().Message}";
        }
        finally
        {
            IsLoadingDepartmentStaff = false;
        }
    }

    private void ChangeEmployeeSelection(
        EligibleAssignmentStaffDto employee,
        ChangeEventArgs eventArgs)
    {
        employee.IsSelected =
            eventArgs.Value is bool value && value;
    }

    private void SelectAllEmployees()
    {
        foreach (var employee in FilteredDepartmentStaff)
        {
            employee.IsSelected = true;
        }
    }

    private void ClearEmployeeSelection()
    {
        foreach (var employee in DepartmentStaff)
        {
            employee.IsSelected = false;
        }
    }

    private async Task SaveBulkAssignmentAsync()
    {
        ModalErrorMessage =
            string.Empty;

        BulkRequest.SelectedIndividualIds =
            DepartmentStaff
                .Where(x => x.IsSelected)
                .Select(x => x.IndividualId)
                .Distinct()
                .ToList();

        var validationMessage =
            ValidateBulkRequest();

        if (!string.IsNullOrWhiteSpace(validationMessage))
        {
            ModalErrorMessage =
                validationMessage;

            return;
        }

        IsSavingAssignment = true;

        try
        {
            /*
            * AssignedByUserId is intentionally not set here.
                 *
                 * WorkAssignmentManagementService should obtain the
                 * authenticated user using IUserAccessService.
                 */
            var result =
                await AssignmentManagementService
                    .AssignDepartmentAsync(BulkRequest);

            if (!result.Success)
            {
                ModalErrorMessage =
                    result.Message;

                if (result.Warnings.Count > 0)
                {
                    ModalErrorMessage +=
                        " " +
                        string.Join(
                            " ",
                            result.Warnings);
                }

                return;
            }

            ShowBulkAssignmentModal =
                false;

            SuccessMessage =
                result.Message;

            if (result.Warnings.Count > 0)
            {
                SuccessMessage +=
                    " " +
                    string.Join(
                        " ",
                        result.Warnings);
            }

            await LoadAssignmentsAsync();
        }
        catch (Exception exception)
        {
            ModalErrorMessage =
                $"Unable to assign employees: " +
                $"{exception.GetBaseException().Message}";
        }
        finally
        {
            IsSavingAssignment = false;
        }
    }

    private string? ValidateBulkRequest()
    {
        if (BulkRequest.OrganisationStructureId <= 0)
            return "Select a department.";

        if (BulkRequest.WorkPlanId is null ||
            BulkRequest.WorkPlanId <= 0)
        {
            return "Select a work plan.";
        }

        if (string.IsNullOrWhiteSpace(
                BulkRequest.AssignmentName))
        {
            return "Enter an assignment name.";
        }

        if (BulkRequest.ScheduledStart == default)
            return "Enter the scheduled start date and time.";

        if (BulkRequest.ScheduledEnd == default)
            return "Enter the scheduled end date and time.";

        if (BulkRequest.ScheduledEnd <=
            BulkRequest.ScheduledStart)
        {
            return "The scheduled end must be after the scheduled start.";
        }

        if (BulkRequest.SelectedIndividualIds.Count == 0)
            return "Select at least one employee.";

        return null;
    }

