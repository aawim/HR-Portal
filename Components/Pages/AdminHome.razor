@page "/admin"
@using Microsoft.AspNetCore.Components.Authorization
@using HRM.Models
@using HRM.Services
@using System.Linq
@inherits LayoutComponentBase
 
@inject AttendanceLogService AttendanceLogService

@rendermode RenderMode.InteractiveServer

<PageTitle>Dashboard - HR Portal</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="h-full">
 

            <div class="h-full pb-10">

                <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-6 gap-4">
                    <div>
                        <h1 class="text-2xl font-bold text-slate-800">Organisation Overview</h1>
                        <p class="text-slate-500 text-sm mt-1">Real-time metrics for staff, attendance, and department health.</p>
                    </div>

                    <div class="flex items-center gap-3">
                        <div class="bg-white px-4 py-2 border border-slate-200 rounded-lg shadow-sm text-sm font-bold text-slate-700 flex items-center gap-2">
                            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            @DateTime.Today.ToString("dddd, dd MMMM yyyy")
                        </div>
                        <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-bold transition-colors shadow-sm flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                            Export Report
                        </button>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">

                    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 flex items-center gap-4">
                        <div class="bg-blue-50 p-3 rounded-lg text-blue-600">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                        </div>
                        <div>
                            <p class="text-slate-500 text-xs font-bold uppercase tracking-wider">Total Headcount</p>
                            <h3 class="text-2xl font-black text-slate-800">@TotalStaff</h3>
                            <p class="text-emerald-600 text-xs font-semibold mt-1">↑ 2 new this month</p>
                        </div>
                    </div>

                    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 flex items-center gap-4">
                        <div class="bg-emerald-50 p-3 rounded-lg text-emerald-600">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <div>
                            <p class="text-slate-500 text-xs font-bold uppercase tracking-wider">Present Today</p>
                            <div class="flex items-baseline gap-2">
                                <h3 class="text-2xl font-black text-slate-800">@PresentToday</h3>
                                <span class="text-sm text-slate-400 font-medium">/ @TotalStaff</span>
                            </div>
                            <p class="text-slate-500 text-xs font-medium mt-1">@Math.Round(((double)PresentToday / TotalStaff) * 100)% Attendance Rate</p>
                        </div>
                    </div>

                    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 flex items-center gap-4">
                        <div class="bg-amber-50 p-3 rounded-lg text-amber-600">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
                        </div>
                        <div>
                            <p class="text-slate-500 text-xs font-bold uppercase tracking-wider">On Leave / OOO</p>
                            <h3 class="text-2xl font-black text-slate-800">@StaffOnLeave</h3>
                            <p class="text-amber-600 text-xs font-semibold mt-1">Across @LeaveDepartmentsCount departments</p>
                        </div>
                    </div>

                    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 flex items-center gap-4">
                        <div class="bg-rose-50 p-3 rounded-lg text-rose-600">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                        </div>
                        <div>
                            <p class="text-slate-500 text-xs font-bold uppercase tracking-wider">Pending Approvals</p>
                            <h3 class="text-2xl font-black text-rose-700">@TotalPendingRequests</h3>
                            <p class="text-rose-600 text-xs font-semibold mt-1">Requires immediate action</p>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-6">

                    <div class="lg:col-span-8 bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                        <div class="p-5 border-b border-slate-100 flex justify-between items-center">
                            <h2 class="text-base font-bold text-slate-800">Pending Request Breakdown</h2>
                            <button class="text-blue-600 text-sm font-bold hover:underline">View All Requests</button>
                        </div>

                        <div class="p-5 grid grid-cols-2 md:grid-cols-3 gap-4">
                            @foreach (var category in RequestCategories)
                            {
                                <div class="border border-slate-100 rounded-lg p-4 hover:border-blue-200 hover:shadow-sm transition-all cursor-pointer">
                                    <div class="flex justify-between items-start mb-2">
                                        <span class="p-2 rounded-md @category.ColorClass">
                                            @((MarkupString)category.IconSvg)
                                        </span>
                                        <span class="text-xl font-black text-slate-800">@category.Count</span>
                                    </div>
                                    <h4 class="text-sm font-bold text-slate-700">@category.Title</h4>
                                    <p class="text-xs text-slate-500 mt-1">@category.Description</p>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="lg:col-span-4 bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden flex flex-col">
                        <div class="p-5 border-b border-slate-100">
                            <h2 class="text-base font-bold text-slate-800">Global Task Status</h2>
                        </div>
                        <div class="p-5 flex-1 flex flex-col justify-center items-center">

                            <div class="relative w-40 h-40 mb-6">
                                <svg class="w-full h-full transform -rotate-90" viewBox="0 0 36 36">
                                    <path class="text-slate-100" stroke-width="3" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                    <path class="text-blue-600" stroke-dasharray="@TaskCompletionPercentage, 100" stroke-width="3" stroke-linecap="round" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                </svg>
                                <div class="absolute inset-0 flex flex-col items-center justify-center">
                                    <span class="text-3xl font-black text-slate-800">@TaskCompletionPercentage%</span>
                                    <span class="text-[10px] uppercase font-bold text-slate-400">Completed</span>
                                </div>
                            </div>

                            <div class="w-full space-y-3">
                                <div class="flex justify-between text-sm">
                                    <span class="flex items-center gap-2 text-slate-600"><span class="w-3 h-3 rounded-full bg-blue-600"></span> Completed</span>
                                    <span class="font-bold text-slate-800">@CompletedTasks</span>
                                </div>
                                <div class="flex justify-between text-sm">
                                    <span class="flex items-center gap-2 text-slate-600"><span class="w-3 h-3 rounded-full bg-amber-400"></span> In Progress</span>
                                    <span class="font-bold text-slate-800">@InProgressTasks</span>
                                </div>
                                <div class="flex justify-between text-sm">
                                    <span class="flex items-center gap-2 text-slate-600"><span class="w-3 h-3 rounded-full bg-slate-200"></span> Pending / Blocked</span>
                                    <span class="font-bold text-slate-800">@BlockedTasks</span>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="p-5 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                        <h2 class="text-base font-bold text-slate-800">Department & Team Status</h2>
                        <div class="flex gap-2">
                            <input type="text" placeholder="Search departments..." class="text-sm px-3 py-1.5 border border-slate-200 rounded-md focus:outline-none focus:border-blue-500" />
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse whitespace-nowrap">
                            <thead>
                                <tr class="bg-white border-b border-slate-100 text-slate-400 text-xs uppercase tracking-wider font-bold">
                                    <th class="px-5 py-4">Department / Team</th>
                                    <th class="px-5 py-4">Supervisor Head</th>
                                    <th class="px-5 py-4 text-center">Staff Count</th>
                                    <th class="px-5 py-4">Task Backlog</th>
                                    <th class="px-5 py-4">Attendance Rate</th>
                                    <th class="px-5 py-4">Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-50 text-sm">
                                @foreach (var dept in Departments)
                                {
                                    <tr class="hover:bg-slate-50 transition-colors">
                                        <td class="px-5 py-4">
                                            <p class="font-bold text-slate-800">@dept.Name</p>
                                            <p class="text-xs text-slate-500">@dept.SubTeams Teams</p>
                                        </td>
                                        <td class="px-5 py-4">
                                            <div class="flex items-center gap-3">
                                                <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center text-slate-600 font-bold text-xs">
                                                    @dept.SupervisorInitials
                                                </div>
                                                <span class="font-medium text-slate-700">@dept.SupervisorName</span>
                                            </div>
                                        </td>
                                        <td class="px-5 py-4 text-center">
                                            <span class="bg-slate-100 text-slate-700 px-3 py-1 rounded-full text-xs font-bold">@dept.StaffCount</span>
                                        </td>
                                        <td class="px-5 py-4">
                                            <div class="w-full bg-slate-100 rounded-full h-2 mt-2 max-w-[120px]">
                                                <div class="bg-blue-600 h-2 rounded-full" style="width: @(dept.TaskCompletionRate)%"></div>
                                            </div>
                                            <p class="text-[10px] text-slate-500 font-medium mt-1">@dept.PendingTasks Pending</p>
                                        </td>
                                        <td class="px-5 py-4 font-semibold text-slate-700">
                                            @dept.AttendanceRate%
                                        </td>
                                        <td class="px-5 py-4">
                                            @if (dept.Status == "Healthy")
                                            {
                                                <span class="text-emerald-600 bg-emerald-50 border border-emerald-100 px-2 py-1 rounded text-[10px] font-bold uppercase">Healthy</span>
                                            }
                                            else if (dept.Status == "Warning")
                                            {
                                                <span class="text-amber-600 bg-amber-50 border border-amber-100 px-2 py-1 rounded text-[10px] font-bold uppercase">High Leave/Backlog</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        <div class="p-6 text-center mt-12">
            <p class="text-slate-500 text-lg">
                Please log in to view the dashboard.
            </p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }
    private string UserName = "User";
    private HrmTeContext DbContext = new HrmTeContext();
    User authUser = new User();
    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
   
                    LoadMockData();
        }

     }

    // Top Level KPIs
    private int TotalStaff = 245;
    private int PresentToday = 212;
    private int StaffOnLeave = 28;
    private int LeaveDepartmentsCount = 6;
    private int TotalPendingRequests = 47;

    // Task Ring Chart Data
    private int CompletedTasks = 420;
    private int InProgressTasks = 85;
    private int BlockedTasks = 45;
    private int TaskCompletionPercentage => (int)Math.Round((double)CompletedTasks / (CompletedTasks + InProgressTasks + BlockedTasks) * 100);

    // Request Breakdown Cards
    private List<RequestCategory> RequestCategories = new();

    // Departments Table Data
    private List<DepartmentOverview> Departments = new();

 
    private void LoadMockData()
    {
        // 1. Load Categories
        RequestCategories = new List<RequestCategory>
        {
            new RequestCategory {
                Title = "Annual Leaves", Count = 12, Description = "Standard paid time off", ColorClass = "bg-indigo-100 text-indigo-600",
                IconSvg = "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'></path></svg>"
            },
            new RequestCategory {
                Title = "Sick & Medical", Count = 8, Description = "Requires medical certificate review", ColorClass = "bg-rose-100 text-rose-600",
                IconSvg = "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z'></path></svg>"
            },
            new RequestCategory {
                Title = "Maternity/Paternity", Count = 3, Description = "Long-term leave planning", ColorClass = "bg-purple-100 text-purple-600",
                IconSvg = "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z'></path></svg>"
            },
            new RequestCategory {
                Title = "Out of Office (Duty)", Count = 15, Description = "Client visits & field work", ColorClass = "bg-emerald-100 text-emerald-600",
                IconSvg = "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'></path></svg>"
            },
            new RequestCategory {
                Title = "Item Requisitions", Count = 6, Description = "Hardware & stationary requests", ColorClass = "bg-amber-100 text-amber-600",
                IconSvg = "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4'></path></svg>"
            },
            new RequestCategory {
                Title = "Attendance Overrides", Count = 3, Description = "Missed punches & adjustments", ColorClass = "bg-slate-100 text-slate-600",
                IconSvg = "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'></path></svg>"
            }
        };

        // 2. Load Department Data
        Departments = new List<DepartmentOverview>
        {
            new DepartmentOverview { Name = "Engineering", SubTeams = 4, SupervisorName = "Ahmed Niyaz", SupervisorInitials = "AN", StaffCount = 45, PendingTasks = 12, TaskCompletionRate = 85, AttendanceRate = 96, Status = "Healthy" },
            new DepartmentOverview { Name = "Sales & Marketing", SubTeams = 2, SupervisorName = "Fathimath Ali", SupervisorInitials = "FA", StaffCount = 28, PendingTasks = 34, TaskCompletionRate = 45, AttendanceRate = 82, Status = "Warning" },
            new DepartmentOverview { Name = "Human Resources", SubTeams = 1, SupervisorName = "Ibrahim Shiyam", SupervisorInitials = "IS", StaffCount = 8, PendingTasks = 5, TaskCompletionRate = 92, AttendanceRate = 100, Status = "Healthy" },
            new DepartmentOverview { Name = "Customer Support", SubTeams = 3, SupervisorName = "Mariyam Hassan", SupervisorInitials = "MH", StaffCount = 65, PendingTasks = 89, TaskCompletionRate = 60, AttendanceRate = 88, Status = "Warning" },
            new DepartmentOverview { Name = "Finance & Legal", SubTeams = 2, SupervisorName = "Hussain Manik", SupervisorInitials = "HM", StaffCount = 14, PendingTasks = 3, TaskCompletionRate = 95, AttendanceRate = 98, Status = "Healthy" }
        };
    }

    // View Models
    public class RequestCategory
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public int Count { get; set; }
        public string ColorClass { get; set; } = "";
        public string IconSvg { get; set; } = "";
    }

    public class DepartmentOverview
    {
        public string Name { get; set; } = "";
        public int SubTeams { get; set; }
        public string SupervisorName { get; set; } = "";
        public string SupervisorInitials { get; set; } = "";
        public int StaffCount { get; set; }
        public int PendingTasks { get; set; }
        public int TaskCompletionRate { get; set; }
        public int AttendanceRate { get; set; }
        public string Status { get; set; } = "";
    }
 
}