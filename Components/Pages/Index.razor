                    </div>

                    <!-- Security Footnote badge -->
                    <div class="rounded-xl border border-dashed border-gray-300 p-4 flex items-center gap-3 bg-gray-50/50">
                        <div class="h-2 w-2 rounded-full bg-blue-600"></div>
                        <p class="text-xs text-gray-500">Safeguarding user security with native biometric multi-factor authentication.</p>
                    </div>
                </div>
            </div>

        </div>


    </NotAuthorized>

</AuthorizeView>

@code{

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }
    private AttendanceLogDto? TodayCheckIn;
    private AttendanceLogDto? TodayCheckOut;

    private bool loading = true;

    private bool isProcessing;

    private string UserName = "";

    private List<JobLeaveType>? leaveBalances;

    private List<AttendanceLogDto>? weeklyLogs;

    private List<AttendanceLogDto>? unevenLogs;

    private List<JobDto>? jobHistory;

    private ActiveJobDto? activeJob;

    private AttendanceLogDto? todayCheckIn;

    private AttendanceLogDto? todayCheckOut;

    private List<Leaf>? leaveRequests;




    protected override async Task OnInitializedAsync()
    {

       var auth = await AuthState!;

        if (!auth.User.Identity?.IsAuthenticated ?? true)
        {
            // User isn't authenticated yet.
            return;
        }
        await RefreshDashboardAsync();
        await LoadAttendance();

        loading = false;
    }

    // protected override async Task OnAfterRenderAsync(bool firstRender)
    // {
    //     if (firstRender)
    //     {
    //         var auth = await AuthState!;

    //         Console.WriteLine($"Authenticated: {auth.User.Identity?.IsAuthenticated}");

    //         foreach (var claim in auth.User.Claims)
    //         {
    //             Console.WriteLine($"{claim.Type} = {claim.Value}");
    //         }
    //     }
    // }


    private async Task RefreshDashboardAsync()
    {
        if (AuthState == null)
            return;

        var auth = await AuthState;

        if (!auth.User.Identity!.IsAuthenticated)
            return;

        UserName = auth.User.Identity.Name ?? "";

        await Task.WhenAll(
            LoadAttendance(),
            LoadLeaveBalances(),
            LoadUnevenLogs(),
            LoadJobHistory()
        );

        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAttendance()
    {
        var context = await _access.GetContextAsync();
         weeklyLogs = await AttendanceService.GetMyWeeklyAttendanceAsync();

        if (weeklyLogs == null)
            return;

        var today = weeklyLogs
            .Where(x => x.Date.Date == DateTime.Today)
            .OrderBy(x => x.Date)
            .ToList();

        var result = await AttendanceService.GetTodayStatusAsync(context.IndividualId);
        todayCheckIn = today.FirstOrDefault(x => x.InOutModeID == 1);
        todayCheckOut = today.FirstOrDefault(x => x.InOutModeID == 2);

        TodayCheckIn = result.checkIn;
        TodayCheckOut = result.checkOut;

        StateHasChanged(); // IMPORTANT

    }

    private async Task LoadLeaveBalances()
    {
        leaveBalances = await LeaveService.GetMyLeaveBalancesAsync();
    }

    private async Task LoadUnevenLogs()
    {
        unevenLogs = await AttendanceService.GetMyUnevenLogsAsync();

    }

    private async Task LoadJobHistory()
    {

        jobHistory = await JobService.GetMyJobHistoryAsync();
    }

    private async Task LoadActiveJob()
    {

        activeJob = await JobService.GetMyActiveJobAsync();
    }

}