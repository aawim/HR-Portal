<div class="bg-white rounded-xl border border-slate-200 shadow-sm">


    <!-- Header -->
    <div class="flex items-center justify-between px-4 py-3 border-b border-slate-100">


        <div>
            <h3 class="text-sm font-semibold text-slate-800">
                Leave Calendar
            </h3>

            <p class="text-xs text-slate-500">
                Check your availability
            </p>
        </div>


        <div class="flex items-center gap-1">

            <button @onclick="PreviousMonth"
                    class="w-7 h-7 rounded-md hover:bg-slate-100">
                <i class="fas fa-chevron-left text-xs"></i>
            </button>


            <span class="text-sm font-semibold text-slate-700">
                @CurrentMonth.ToString("MMMM yyyy")
            </span>


            <button @onclick="NextMonth"
                    class="w-7 h-7 rounded-md hover:bg-slate-100">
                <i class="fas fa-chevron-right text-xs"></i>
            </button>

        </div>


    </div>



    <!-- Calendar -->
    <div class="p-1">


        <!-- Week Names -->
        <div class="grid grid-cols-7 text-center mb-2">

            @foreach (var day in WeekDays)
            {
                <span class="text-xs font-medium text-slate-400">
                    @day
                </span>
            }

        </div>



        <!-- Dates -->
        <div class="grid grid-cols-7 gap-1">


            @foreach (var day in CalendarDays)
            {

                @if (day == null)
                {
                    <div></div>
                }
                else
                {

                    <div class="@GetDayClass(day.Value)"
                         title="@GetTooltip(day.Value)">

                        @day.Value.Day

                    </div>

                }

            }


        </div>



    </div>



    <!-- Legend -->
    <div class="flex gap-4 px-4 pb-4 text-xs">


        <div class="flex items-center gap-1">

            <span class="w-3 h-3 rounded bg-blue-500"></span>

            Leave

        </div>


        <div class="flex items-center gap-1">

            <span class="w-3 h-3 rounded bg-red-200"></span>

            Weekend

        </div>


        <div class="flex items-center gap-1">

            <span class="w-3 h-3 rounded bg-green-500"></span>

            Today

        </div>


    </div>


</div>



@code {


    private DateTime CurrentMonth = DateTime.Today;


    private List<string> WeekDays =
        [
        "Sun",
        "Mon",
        "Tue",
        "Wed",
        "Thu",
        "Fri",
        "Sat"
    ];



    // Dummy leave dates
    private List<DateTime> LeaveDates =
        [
        DateTime.Today.AddDays(5),
        DateTime.Today.AddDays(6),
        DateTime.Today.AddDays(7)
    ];



    private List<DateTime?> CalendarDays =>
        GenerateCalendar();



    private List<DateTime?> GenerateCalendar()
    {

        var result = new List<DateTime?>();


        var firstDay =
            new DateTime(
                CurrentMonth.Year,
                CurrentMonth.Month,
                1);


        int empty =
            (int)firstDay.DayOfWeek;


        for (int i = 0; i < empty; i++)
        {
            result.Add(null);
        }



        int days =
            DateTime.DaysInMonth(
                CurrentMonth.Year,
                CurrentMonth.Month);



        for (int i = 1; i <= days; i++)
        {
            result.Add(
                new DateTime(
                    CurrentMonth.Year,
                    CurrentMonth.Month,
                    i));
        }


        return result;

    }



    private void PreviousMonth()
    {
        CurrentMonth =
            CurrentMonth.AddMonths(-1);
    }



    private void NextMonth()
    {
        CurrentMonth =
            CurrentMonth.AddMonths(1);
    }



    private string GetDayClass(DateTime day)
    {

        string css =
            "h-8 flex items-center justify-center rounded-md text-xs cursor-pointer ";


        if (day.Date == DateTime.Today)
        {
            return css +
                   "bg-green-500 text-white font-semibold";
        }


        if (LeaveDates.Contains(day.Date))
        {
            return css +
                   "bg-blue-500 text-white";
        }


        if (day.DayOfWeek == DayOfWeek.Friday ||
           day.DayOfWeek == DayOfWeek.Saturday)
        {
            return css +
                   "bg-red-100 text-red-600";
        }



        return css +
               "hover:bg-slate-100 text-slate-700";

    }



    private string GetTooltip(DateTime day)
    {

        if (LeaveDates.Contains(day.Date))
            return "Existing Leave";


        if (day.DayOfWeek == DayOfWeek.Friday ||
           day.DayOfWeek == DayOfWeek.Saturday)
            return "Weekend";


        return day.ToString("dd MMM yyyy");

    }


}