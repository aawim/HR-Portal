@using HRM.Models
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 flex flex-col items-center relative overflow-hidden">
                    
                        <div class="absolute top-0 left-0 w-full h-24 bg-gradient-to-r from-blue-500 to-blue-600 opacity-10"></div>
                        <img src="https://i.pravatar.cc/150?img=32" alt="Profile" class="w-20 h-20 rounded-full border-4 border-white shadow-md z-10" />
                        <h2 class="text-lg font-bold text-slate-800 mt-3">@UserName</h2>
                        <p class="text-sm text-blue-600 font-medium mb-4">Senior HR Specialist</p>

                        <div class="w-full space-y-2 text-sm">
                            <div class="flex justify-between border-b border-slate-50 pb-1">
                                <span class="text-slate-500">Emp Number</span>
                                <span class="font-medium text-slate-700">300030002</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-50 pb-1">
                                <span class="text-slate-500">SAP Number</span>
                                <span class="font-medium text-slate-700">20040-5023</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-50 pb-1">
                                <span class="text-slate-500">Department</span>
                                <span class="font-medium text-slate-700">HR & Admin</span>
                            </div>
                            <div class="flex justify-between pb-1">
                                <span class="text-slate-500">Status</span>
                                <span class="font-medium text-emerald-500 bg-emerald-50 px-2 py-0.5 rounded-full text-xs">Active</span>
                            </div>
                        </div>
                    </div>
                 
 

@code {

    [Parameter]
    public string UserName { get; set; } = "John Doe";

}
