@using HRM.DTOs.Attendance
@using HRM.Models

<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-3">

    <div class="flex justify-between items-center mb-2">
        <h3 class="font-semibold text-slate-800">
            Attendance Summary
        </h3>
    </div>

    <div class="grid grid-cols-7 gap-2">

        @if (WeeklyLogs != null)
        {
            @for (int i = 6; i >= 0; i--)
            {
                var day = DateTime.Today.AddDays(-i);

                var dayLogs = WeeklyLogs?
                .Where(x => x.Date.Date == day.Date)
                .OrderBy(x => x.Date)
                .ToList();

                var checkIn = dayLogs?
                .FirstOrDefault(x => x.InOutModeID == 1);

                var checkOut = dayLogs?
                .LastOrDefault(x => x.InOutModeID == 2);

                bool isPresent = checkIn != null;

                bool isLate =
                checkIn != null &&
                checkIn.Date.TimeOfDay > new TimeSpan(8, 0, 0);

                <div class="flex flex-col items-center">

                    <!-- Day box -->
                    <div class="
                        w-full h-24 rounded-lg flex flex-col items-center justify-center text-center text-s
                        @(isPresent
                            ? (isLate ? "bg-amber-500 text-white" : "bg-green-500 text-white")
                            : "bg-red-500 text-white")
                            ">

                        <div class="text-[15px] opacity-90 mb-1">
                            @day.ToString("dd MMM yyyy")
                        </div>


                        @if (isPresent)
                        {
                            <div class="font-semibold">
                                @checkIn!.Date.ToString("HH:mm")
                            </div>

                            <div class="text-[15px] opacity-90">
                                @if (checkOut != null)
                                {
                                    @checkOut.Date.ToString("HH:mm")
                                }
                                else
                                {
                                    <span>--</span>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="text-[18px]">Absent</span>
                            <span>--</span>
                        }

                    </div>

                    <!-- Day label -->
                    <span class="text-xs mt-2 text-slate-600">
                        @day.ToString("ddd")
                    </span>

                </div>
            }

        }

    </div>

</div>

@code {

    [Parameter]
    public List<AttendanceLogDto>? WeeklyLogs { get; set; }

}