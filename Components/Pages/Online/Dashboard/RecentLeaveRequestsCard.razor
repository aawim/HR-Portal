@using HRM.Models
@using HRM.Services
@using HRM.Components.Shared
@using HRM.Services.Interfaces
@using HRM.Helpers

@inject ToastService ToastService
@inject ILeaveService LeaveService



<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4">

    <div class="flex justify-between items-center mb-4">
        <div>
            <h3 class="text-lg font-semibold text-slate-800">
                Recent Leave Requests
            </h3>
            <p class="text-sm text-slate-500">
                Your latest leave applications
            </p>
        </div>

        <i class="fas fa-calendar-alt text-blue-600 text-xl"></i>
    </div>

    @if (IsLoading)
    {
        <div class="py-6 text-center text-slate-500">
            Loading leave requests...
        </div>
    }
    else if (LeaveRequests == null || !LeaveRequests.Any())
    {
        <div class="py-6 text-center text-slate-500">
            No leave requests found.
        </div>
    }
    else
    {
        <div class="overflow-x-auto">

            <table class="min-w-full divide-y divide-slate-200">

                <thead class="bg-slate-50">
                    <tr>

                        <th class="px-3 py-3 text-left text-xs font-semibold uppercase">
                            Type
                        </th>

                        <th class="px-3 py-3 text-left text-xs font-semibold uppercase">
                            From
                        </th>

                        <th class="px-3 py-3 text-left text-xs font-semibold uppercase">
                            To
                        </th>

                        <th class="px-3 py-3 text-center text-xs font-semibold uppercase">
                            Days
                        </th>

                        <th class="px-3 py-3 text-center text-xs font-semibold uppercase">
                            Status
                        </th>

                        <th class="px-3 py-3 text-center text-xs font-semibold uppercase">
                            Action
                        </th>

                    </tr>
                </thead>

                <tbody class="divide-y divide-slate-100">

                    @foreach (var leave in LeaveRequests.Take(5))
                    {
                        <tr class="hover:bg-slate-50">

                            <td class="px-3 py-3">
                                @leave.LeaveType.Name
                            </td>

                            <td class="px-3 py-3">
                                @leave.FromDate.ToString("dd MMM yyyy")
                            </td>

                            <td class="px-3 py-3">
                                @leave.ToDate.ToString("dd MMM yyyy")
                            </td>

                            <td class="px-3 py-3 text-center">
                                @leave.Duration
                            </td>

                            <td class="px-3 py-3 text-center">

                                @switch (leave.LeaveState.LeaveStateId)
                                {
                                    case 1: // Incomplete
                                        <span class="px-2 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-700">
                                            @leave.LeaveState.StateName
                                        </span>
                                        break;

                                    case 2: // Pending Verification
                                        <span class="px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700">
                                            @leave.LeaveState.StateName
                                        </span>
                                        break;

                                    case 3: // Pending Approval
                                        <span class="px-2 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-700">
                                            @leave.LeaveState.StateName
                                        </span>
                                        break;

                                    case 4: // Approved
                                        <span class="px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">
                                            @leave.LeaveState.StateName
                                        </span>
                                        break;

                                    case 5: // Rejected
                                        <span class="px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-700">
                                            @leave.LeaveState.StateName
                                        </span>
                                        break;

                                    case 6: // Cancelled
                                        <span class="px-2 py-1 rounded-full text-xs font-medium bg-slate-200 text-slate-700">
                                            @leave.LeaveState.StateName
                                        </span>
                                        break;

                                    case 7: // Pending HR Head Approval
                                        <span class="px-2 py-1 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">
                                            @leave.LeaveState.StateName
                                        </span>
                                        break;

                                    case 8: // Pending HOD Approval
                                        <span class="px-2 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-700">
                                            @leave.LeaveState.StateName
                                        </span>
                                        break;

                                    default:
                                        <span class="px-2 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-700">
                                            @leave.LeaveState.StateName
                                        </span>
                                        break;
                                }

                            </td>

                            <td class="px-3 py-3 text-center gap-2">

                               
                                    <button class="px-3 py-1 rounded-md text-xs
                                       bg-slate-200 text-slate-500
                                       hover:bg-slate-300 text-slate-700"
                                    @onclick="() => OpenCancelDialog(leave.LeaveId)">
                                        <i class="fas fa-times me-1"></i>
                                        Cancel
                                    </button>
                                @if (LeaveHelper.CanCancel(leave.LeaveState.LeaveStateId))
                                { }
                                <button class="px-3 py-1 rounded-md text-xs
                                       bg-green-200 text-green-700
                                       hover:bg-green-300 text-green-700"
                                @onclick="() => ShowDetail(leave.LeaveId)">
                                    <i class="fas fa-times me-1"></i>
                                    View
                                </button>


                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }

</div>
@if (ShowCancelConfirm)
{
    <ConfirmDialog ActionType="ConfirmAction.Cancel"
    Title="Cancel Leave Request"
    Message="Are you sure you want to cancel this leave request?"
    ConfirmText="Yes, Cancel"
    OnConfirm="ConfirmCancelLeave"
    OnCancel="CloseCancelDialog" />
}


@code {



    [Parameter]
    public bool IsLoading { get; set; }

    private List<Leaf>? LeaveRequests;
    private bool ShowCancelConfirm;
    private int SelectedLeaveId;


    protected override async Task OnInitializedAsync()
    {

        LeaveRequests = await LeaveService.GetMyLeaveRequestsAsync();
        IsLoading = false;

    }


    private void OpenCancelDialog(int leaveId)
    {
        SelectedLeaveId = leaveId;
        ShowCancelConfirm = true;
    }

    private void CloseCancelDialog()
    {
        ShowCancelConfirm = false;
    }

    private async Task ConfirmCancelLeave()
    {
        ShowCancelConfirm = false;

        var result = await LeaveService
            .CancelLeaveAsync(SelectedLeaveId);


        if (!result.Success)
        {
            ToastService.Warning(result.Message);
            return;
        }

        ToastService.Success("Leave cancelled successfully.");

        await InvokeAsync(StateHasChanged);



        LeaveRequests = await LeaveService.GetMyLeaveRequestsAsync();
    }

    private async Task CancelLeave(int leaveId)
    {
        var result = await LeaveService.CancelLeaveAsync(leaveId);

        if (!result.Success)
        {
            ToastService.Warning(result.Message);
            return;
        }

        ToastService.Success("Leave cancelled successfully.");

        await InvokeAsync(StateHasChanged);



        LeaveRequests = await LeaveService.GetMyLeaveRequestsAsync();
    }

    private async Task ShowDetail(int leaveId)
    {
        var result = await LeaveService.ShowDetailLeaveAsync(leaveId);

        if (!result.Success)
        {
            //ToastService.ShowWarning(result.Message);
            return;
        }


        LeaveRequests = await LeaveService.GetMyLeaveRequestsAsync();

        StateHasChanged();
    }

    

}