@using HRM.DTOs.Attendance
@using HRM.Models
@using HRM.Services.Interfaces

@inject IAttendanceService AttendanceService



<div class="bg-white rounded-xl border border-slate-200 shadow-sm">

    <!-- Header -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">

        <div>
            <h2 class="text-base font-semibold text-slate-800">
                Uneven Logs
            </h2>

            <p class="text-xs text-slate-500">
                Recent device punch records
            </p>
        </div>

        <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center">
            <i class="fas fa-fingerprint text-blue-600"></i>
        </div>

    </div>


    @if (Logs == null || !Logs.Any())
    {
        <div class="py-10 text-center text-slate-500">
            No attendance logs found.
        </div>
    }
    else
    {
        <div class="divide-y divide-slate-100 max-h-[820px] overflow-y-auto">

            @foreach (var log in Logs)
            {
                var time = GetDateTime(log);
                @* px - 5 py - 4 *@
                <div class="flex items-center justify-between px-4 p-2 hover:bg-slate-50 transition">

                    <!-- Left -->
                    <div class="flex items-center gap-4">

                        <!-- Icon -->
                        <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center shrink-0">

                            @if (log.InOutModeID == 1)
                            {
                                <i class="fas fa-sign-in-alt text-green-600"></i>
                            }
                            else
                            {
                                <i class="fas fa-sign-out-alt text-red-500"></i>
                            }

                        </div>

                        <!-- Details -->
                        <div>

                            <div class="text-sm font-semibold text-slate-800">
                                @time.ToString("dd MMM yyyy")
                            </div>

                            <div class="text-xs text-slate-500 mt-0.5">
                                @time.ToString("hh:mm:ss tt")
                            </div>

                            <div class="text-xs text-slate-400 mt-1">
                                UID: @log.UIDStamp
                            </div>

                        </div>

                    </div>


                    <!-- Right -->
                    <div class="text-right">

                        <span class="@GetBadgeClass(log.AttendanceLogStateID)">
                            @GetStateLabel(log.AttendanceLogStateID)
                        </span>

                        <div class="text-xs text-slate-400 mt-2">
                            @(log.InOutModeID == 1 ? "Check In" : "Check Out")
                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

@code {

    [Parameter]
    public List<AttendanceLogDto> Logs { get; set; } = new();



    protected override async Task OnParametersSetAsync()
    {
        // Logs = await AttendanceService.GetJobIdByStaffId(StaffId);
        Logs = await AttendanceService.GetMyUnevenLogsAsync();
        
    }



    private DateTime GetDateTime(AttendanceLogDto log)
    {
        return new DateTime(
            log.Year,
            log.Month,
            log.Day,
            log.Hour,
            log.Minute,
            log.Second);
    }

    private string GetBadgeClass(int stateId)
    {
        return stateId switch
        {
            1 => "inline-flex px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700",
            2 => "inline-flex px-3 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-700",
            3 => "inline-flex px-3 py-1 rounded-full text-xs font-medium bg-red-100 text-red-700",
            _ => "inline-flex px-3 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-600"
        };
    }

    private string GetStateLabel(int stateId)
    {
        return stateId switch
        {
            1 => "Present",
            2 => "Late",
            3 => "Absent",
            _ => "Unknown"
        };
    }

}