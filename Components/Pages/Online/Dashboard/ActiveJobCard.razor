@using HRM.DTOs
@using HRM.DTOs.UserContext
@using HRM.Models
@using HRM.Services
@using HRM.Services.Interfaces
@inject IJobService JobService
 


<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-3">

    <div class="flex justify-between items-center ">
        <div>
            <h2 class="text-lg font-semibold">Active Jobs</h2>
            <p class="text-sm text-gray-500">Current employment records</p>
        </div>

        <i class="fas fa-briefcase text-blue-600 text-xl"></i>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-6 text-gray-500">
            Loading jobs...
        </div>
    }
    else if (job == null)
    {
        <div class="text-center py-6 text-gray-500">
            No active jobs found.
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">

                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">
                            Organization
                        </th>

                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">
                            Structure
                        </th>

                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">
                            Job Type
                        </th>

                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">
                            Joined Date
                        </th>

                        <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase">
                            Salary
                        </th>

                        <th class="px-4 py-3 text-center text-xs font-semibold text-gray-600 uppercase">
                            Status
                        </th>
                    </tr>
                </thead>

                <tbody class="bg-white divide-y divide-gray-100">

                    @if (job != null)
                    {
                        <tr class="hover:bg-gray-50">

                            <td class="px-4 py-3 text-sm">
                                @job.OrganisationName
                            </td>

                            <td class="px-4 py-3 text-sm">
                                @job.OrganisationStructureName
                            </td>

                            <td class="px-4 py-3 text-sm">
                                @job.JobTypeName
                            </td>

                            <td class="px-4 py-3 text-sm">
                                @job.JoinedDate.ToString("dd MMM yyyy")
                            </td>

                            <td class="px-4 py-3 text-sm text-right">
                                @(job.BasicSalary?.ToString("N2") ?? "-")
                            </td>

                            <td class="px-4 py-3 text-center">
                                <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-700">
                                    @(job.JobStateName ?? "Active")
                                </span>
                            </td>

                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="px-4 py-6 text-center text-gray-500">
                                No active job found.
                            </td>
                        </tr>
                    }

                </tbody>

            </table>
        </div>
    }

</div>

@code {

    private ActiveJobDto? job;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        job = await JobService.GetMyActiveJobAsync();
        isLoading = false;
    }

}