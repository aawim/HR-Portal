@page "/admin/attendance/{CategoryName}"
@using Microsoft.AspNetCore.Components.Authorization
@using HRM.Models
@using HRM.Services
@using HRM.Services.Interfaces
@using HRM.Components.Admin.Attendance.Attendance


@inject NavigationManager Navigation
 
@inject ILeaveService LeaveService



@rendermode RenderMode.InteractiveServer

<PageTitle>Settings - HR Portal</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="max-w-12xl mx-auto py-0 px-4">
            <!-- Back Button -->
            <a href="/admin/attendance" class="text-slate-400 hover:text-slate-600 text-sm mb-2 flex items-center gap-1 transition-colors w-fit">
                <svg class="w-4 h-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                Back to Settings Hub
            </a>

            <!-- Main Responsive Layout: Stacks vertically on mobile, side-by-side on md+ screens -->
            <div class="flex flex-col md:flex-row gap-1 items-start">
                <!-- LEFT: Sidebar Menu (Responsive width) -->
                <div class="flex-shrink-0 flex flex-col gap-1 transition-all duration-300 ease-in-out overflow-hidden @(isSidebarExpanded ? "w-full md:w-80" : "w-[60px]")">

                    <div class="flex items-center @(isSidebarExpanded ? "justify-between" : "justify-center") px-1 mb-3">

                        <h2 class="text-xl font-bold text-slate-800 capitalize truncate transition-opacity duration-300 @(isSidebarExpanded ? "opacity-100 block" : "opacity-0 hidden")">
                            @CategoryName Management
                        </h2>

                        <button @onclick="ToggleSidebar" class="p-2 rounded-lg text-slate-500 hover:bg-slate-100 hover:text-blue-600 transition-colors flex-shrink-0" title="@(isSidebarExpanded ? "Collapse Sidebar" : "Expand Sidebar")">
                            <svg class="w-6 h-6 transition-transform duration-300 @(isSidebarExpanded ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
                            </svg>
                        </button>
                    </div>

                    @foreach (var item in GetSubItems(CategoryName))
                    {
                    var currentPath = Navigation.ToBaseRelativePath(Navigation.Uri).ToLower();
 
                        <button @onclick="() => SelectItem(item)"title="@(!isSidebarExpanded ? item.Title : null)"
                           
                                class="text-left p-1 rounded-xl border shadow-sm transition-all duration-200 group flex items-center gap-3 overflow-hidden
                                @(activeItem?.Title == item.Title ? "bg-blue-50 border-blue-50" : "bg-white border-slate-50 hover:shadow-md hover:border-blue-50 hover:bg-slate-50")">
                           <div class="w-10 h-12 flex items-center justify-center rounded-lg text-xl flex-shrink-0 transition-colors duration-300 mx-auto">
                    
                                @item.Icon
                            </div>

                            <div class="flex-grow min-w-0 transition-all duration-300 @(isSidebarExpanded ? "opacity-100 w-auto" : "opacity-0 w-0 hidden")">
                                <h3 class="font-bold text-sm mb-0.5 truncate @(activeItem?.Title == item.Title ? "text-blue-800" : "text-slate-800 group-hover:text-blue-700")">
                                    @item.Title
                                </h3>
                                <p class="text-slate-500 text-xs leading-tight line-clamp-2">
                                    @item.Description
                                </p>
                            </div>

                            <div class="flex-shrink-0 transition-all duration-300 @(isSidebarExpanded ? "opacity-100 block" : "opacity-0 hidden") @(activeItem?.Title == item.Title ? "text-blue-600" : "text-slate-300 group-hover:text-blue-600")">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                            </div>
                        </button>
                        }
                </div>

                <!-- RIGHT: Dynamic Data Display -->
                <div class="w-full md:w-2/3 lg:w-3/4 flex-grow bg-white rounded-2xl border border-slate-200 shadow-sm p-2 md:p-8 min-h-[600px] mt-[40px]">
                    @if (activeItem == null)
                    {
                        <div class="h-full flex flex-col items-center justify-center text-slate-400 opacity-60 min-h-[400px]">
                            <div class="text-6xl mb-4">👈</div>
                            <p class="text-lg font-medium">Select an item from the menu to view data.</p>
                        </div>
                    }
                    else
                    {
                        <!-- Header for the selected data -->
                     @*    <div class="border-b border-slate-100 pb-4 mb-6 flex justify-between items-end">
                            <div>
                                <h2 class="text-xl font-bold text-slate-800">@activeItem.Title</h2>
                                <p class="text-sm text-slate-500 mt-1">@activeItem.Description</p>
                            </div>
                        </div> *@

                        <!-- Dynamic Component Rendering -->
                        <div class="mt-4">
                            @if (activeItem.ComponentType != null)
                            {
                                <DynamicComponent Type="@activeItem.ComponentType" />
                            }
                            else
                            {
                                <div class="bg-slate-50 border border-slate-100 rounded-xl p-8 text-center text-slate-500">
                                    <p>Component not yet assigned for <strong>@activeItem.Title</strong>.</p>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        <div class="p-6 text-center mt-12">
            <p class="text-slate-500 text-lg">
                Please log in to view the settings dashboard.
            </p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public string CategoryName { get; set; } = string.Empty;
    [Parameter] public string? Page { get; set; }

    // Fixed Record: Replaced 'Url' with 'ComponentType' to match your dynamic rendering goals
    private record SubItem(string Title, string Route, string Icon, string Description, Type? ComponentType = null);

    private SubItem? activeItem;

    private void SelectItem(SubItem item)
    {
        activeItem = item;
        // Navigation.NavigateTo(
        // $"/admin/attendance/{CategoryName}/{item.Route}");
    }
    private bool isSidebarExpanded = true;

    private void ToggleSidebar()
    {
        isSidebarExpanded = !isSidebarExpanded;
    }
 
    // protected override void OnInitialized()
    // {
    //     SetActiveItemFromUrl();
    //     Navigation.LocationChanged += OnLocationChanged;
    // }



    // private void SetActiveItemFromUrl()
    // {
    //     var currentPath = Navigation.ToBaseRelativePath(Navigation.Uri)
    //                                 .ToLower();

    //     activeItem = GetSubItems(CategoryName)
    //         .FirstOrDefault(x =>
    //             currentPath.EndsWith(x.Route.ToLower()));
    // }
  
     private List<SubItem> GetSubItems(string cat) => cat.ToLower() switch
    {
        "manage-attendance" => new() {
            new("My Attendance","my-attendance","👤","View your personal attendance logs and time history.",typeof(MyAttendanceGrid)),
            new("Individual Attendance","individual-attendance","🔍","Check detailed attendance records for specific employees.",typeof(IndividualAttendanceGrid)),
            new("Team Attendance","team-attendance","👥","Monitor daily attendance and time-tracking for your team.",typeof(TeamAttendanceGrid)),
            new("Organisation Daily","organisation-daily","🏢","View the daily attendance overview for the entire organisation.",typeof(OrganisationDaily)),
            new("Add Bulk Attendance","add-bulk-attendance","📋","Upload or manually enter attendance for multiple staff at once.",typeof(BulkAttendanceGrid)),
            new("Attendance Requests","attendance-requests","✉️","Review and approve manual attendance entries and adjustments.",typeof(AttendanceRequestGrid)),
            new("Attendance Invalidate Requests","attendance-invalidate-requests","🚫","Process requests to void or cancel incorrect attendance logs.",typeof(AttendanceInvalidateGrid)),
            new("Out Of Office Requests","out-of-office-requests","🚶‍♂️","Manage requests for off-site work, meetings, or short absences.",typeof(OutOfOfficeRequestGrid)),
            new("Uneven Logs","uneven-logs","⚠️","Resolve missing check-ins, check-outs, or incomplete shifts.",typeof(UnEvenLogGrid)),
            new("Official Trip Requests","official-trip-requests","✈️","Review and manage approvals for business travel and duty trips.",typeof(OfficialTripRequestGrid)),
            new("Former Staff", "former-staff","📁","Access historical attendance records for inactive or past employees.",typeof(FomerStaffGrid))
        },
        "manage-leaves" => new() {
            new("Search", "search", "🔍", "Find and review past or pending leave applications.", null),
            new("New Leave Application", "new-leave-application", "📝", "Apply for standard annual, casual, or special leave.", null),
            new("Sick Leave Lodge", "sick-leave-lodge", "🏥", "Submit medical certificates and lodge sick leave.", null),
            new("Family Leave Lodge", "family-leave-lodge", "👨‍👩‍👧‍👦", "Apply for maternity, paternity, or family responsibility leave.", null),
            new("Leave Change Request", "leave-change-request", "🔄", "Request modifications or cancellations to approved leave.", null),
            new("Staff Leave Report", "staff-leave-report", "📄", "Generate detailed leave balances and history for specific employees.", null),
            new("Organisation Leave Report", "organisation-leave-report", "📊", "View high-level leave trends and balances across the entire organisation.", null),
            new("Bulk Data Entry", "bulk-data-entry", "📑", "Import or manually enter multiple leave or attendance records simultaneously.", null)
        },
   
        "overtimes" => new() {
            new("OT Pre Approval","ot-pre-approval","⏳","Request or grant permission for upcoming overtime hours in advance.",null),
            new("OT Request","ot-request","⏰","Submit completed overtime hours for final approval and payroll processing.",null),
            new("Staff OT Report","staff-ot-report","📄","Generate detailed overtime summaries and costs for individual employees.",null),
            new("Organisation OT Report","organisation-ot-report","📊","View high-level overtime hour trends and costs across the entire organisation.",null)
        },
        "reports" => new() {
            new("Daily Attendance Report","daily-attendance-report","📅","Review day-to-day clock-in and clock-out logs for all employees.",null),
            new("Staff Attendance Report","staff-attendance-report","📋","Generate detailed time and attendance histories for specific individuals.",null),
            new("Team Attendance Report","team-attendance-report","👥","Analyze attendance trends and daily presence for specific departments or groups.",null),
            new("Staff OT Report","staff-ot-report","⏳","Review detailed overtime hours and summaries for individual employees.",null),
            new("Staff Leave Report","staff-leave-report","🏖️","Generate detailed leave balances and history for specific employees.",null),
            new("Staff Break Fine Report","staff-break-fine-report","☕","Track deductions and penalties for individuals exceeding allocated break times.",null),
            new("Staff Late Fine Report","staff-late-fine-report","⏰","Monitor tardiness records and associated financial deductions for specific employees.",null),
            new("Organisation OT Report","organisation-ot-report","📈","Analyze company-wide overtime hour trends and total compensation costs.",null),
            new("Organisation Leave Report","organisation-leave-report","📊","View high-level leave trends, absenteeism, and balances across the entire organisation.",null),
            new("Organisation Late Fine Report","organisation-late-fine-report","📉","Review aggregate tardiness data and total late fine deductions company-wide.",null)
        },
        
        _ => new() { new("General Configuration", "🔧", "System level management.", null) }
    };

    // --- Authentication and Service Logic ---
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    // private string UserName = "User";

    // Variables for Dashboard Data
    private List<JobLeaveType>? leaveBalances;
 
    // private List<Leaf>? leaveRequests;

    protected override async Task OnInitializedAsync()
    {
        
        leaveBalances = await LeaveService.GetMyLeaveBalancesAsync();

    }
}
