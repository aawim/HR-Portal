@using HRM.Models
@using HRM.Models.Archives
@using HRM.Services
@using HRM.Services.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@rendermode RenderMode.InteractiveServer

@inject HrmTeContext DbContext
@inject IUserAccessService _access

<div class="bg-white relative">
    <!-- Header & Action Bar -->
    <div class="flex justify-between items-end border-b border-slate-100 pb-4 mb-4 mt-[-30px]">
        <div>
            <h2 class="text-xl font-bold text-slate-800">Manage Configurations</h2>
            <p class="text-sm text-slate-500 mt-1">Configure global leave policies, durations, and system rules.</p>
        </div>

        <button @onclick="OpenAddPanel" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium shadow-sm transition-colors flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Add New
        </button>
    </div>

    <!-- Data Grid -->
    @if (LeaveConfigurableValues == null)
    {
        <!-- Loading State -->
        <div class="flex justify-center items-center p-12 min-h-[300px]">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
        </div>
    }
    else if (!LeaveConfigurableValues.Any())
    {
        <!-- Empty State -->
        <div class="bg-slate-50 border border-slate-100 rounded-xl p-12 text-center text-slate-500 min-h-[300px] flex flex-col items-center justify-center">
            <div class="text-4xl mb-3">⚙️</div>
            <p class="font-medium text-slate-700 text-lg">No configurations found.</p>
            <p class="text-sm mt-1">Click "Add New" to create your first configuration rule.</p>
        </div>
    }
    else
    {
        <!-- Data Table -->
        <div class="overflow-x-auto rounded-xl border border-slate-200 shadow-sm">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs uppercase tracking-wider">
                        <th class="p-4 font-bold">Value Type</th>
                        <th class="p-4 font-bold">Organisation</th>
                        <th class="p-4 font-bold">Value</th>
                        <th class="p-4 font-bold">Is Valid?</th>
                        <th class="p-4 font-bold">Job Type</th>
                        <th class="p-4 font-bold text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var config in LeaveConfigurableValues)
                    {
                        <tr class="hover:bg-slate-50 transition-colors duration-150">
                            <!-- Value Type -->
                            <td class="p-4">
                                <div class="font-bold text-slate-800 text-sm">@(config.LeaveConfigurableValueType?.Name ?? "N/A")</div>
                            </td>

                            <!-- Organisation -->
                            <td class="p-4">
                                <div class="font-bold text-slate-800 text-sm">@(config.Organisation?.OrganisationName ?? "N/A")</div>
                            </td>

                            <!-- Value -->
                            <td class="p-4 text-sm text-slate-700 font-medium">
                                @config.Value
                            </td>

                            <!-- Is Valid -->
                            <td class="p-4 text-sm">
                                @if (config.IsValid)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-green-50 text-green-700 text-xs font-bold border border-green-100">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                        True
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-slate-100 text-slate-500 text-xs font-bold border border-slate-200">
                                        False
                                    </span>
                                }
                            </td>

                            <!-- Job Type -->
                            <td class="p-4">
                                <div class="font-bold text-slate-800 text-sm">@(config.JobType?.TypeName ?? "N/A")</div>
                                @if (!string.IsNullOrWhiteSpace(config.JobType?.TypeNameDhivehi))
                                {
                                    <div class="text-xs text-slate-500 font-medium mt-0.5" dir="rtl">
                                        @config.JobType.TypeNameDhivehi
                                    </div>
                                }
                                else if (config.JobType == null)
                                {
                                    <div class="text-xs text-slate-500 font-medium mt-0.5 italic">
                                        No specific job type
                                    </div>
                                }
                            </td>

                            <!-- Actions -->
                            <td class="p-4 text-right">
                                <div class="flex justify-end gap-1">
                                    <!-- Edit Button -->
                                    <button @onclick="() => OpenEditPanel(config)" class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="Edit">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </button>
                                    <!-- Delete Button -->
                                    <button @onclick="() => OpenDeleteModal(config)" class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Delete">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- ========================================== -->
<!-- DELETE CONFIRMATION MODAL -->
<!-- ========================================== -->
@if (isDeleteModalOpen)
{
    <div class="fixed inset-0 z-[60] flex items-center justify-center overflow-hidden">
        <!-- Dark Backdrop -->
        <div class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm" @onclick="CloseDeleteModal"></div>

        <!-- Modal Content -->
        <div class="relative bg-white rounded-xl shadow-2xl p-6 max-w-sm w-full mx-4 transform transition-all">
            <div class="flex items-center justify-center w-12 h-12 rounded-full bg-red-100 mb-4 mx-auto">
                <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <h3 class="text-lg font-bold text-slate-800 text-center mb-2">Delete Configuration?</h3>
            <p class="text-sm text-slate-500 text-center mb-6">
                Are you sure you want to delete the configuration for <strong class="text-slate-800">@(configToDelete?.LeaveConfigurableValueType?.Name ?? "this item")</strong>? This action cannot be undone.
            </p>
            <div class="flex justify-center gap-3">
                <button @onclick="CloseDeleteModal" class="px-4 py-2 text-sm font-medium text-slate-600 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors w-full">
                    Cancel
                </button>
                <button @onclick="ConfirmDelete" class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition-colors w-full shadow-sm">
                    Delete
                </button>
            </div>
        </div>
    </div>
}

<!-- ========================================== -->
<!-- SLIDE-OUT PANEL OVERLAY (ADD/EDIT) -->
<!-- ========================================== -->
<div class="fixed inset-0 z-50 overflow-hidden @(isPanelOpen ? "" : "pointer-events-none")">

    <!-- Dark Backdrop -->
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm transition-opacity duration-300 ease-in-out @(isPanelOpen ? "opacity-100" : "opacity-0")"
    @onclick="ClosePanel">
    </div>

    <!-- Slide Panel -->
    <div class="absolute inset-y-0 right-0 max-w-md w-full bg-white shadow-2xl flex flex-col transform transition-transform duration-300 ease-in-out @(isPanelOpen ? "translate-x-0" : "translate-x-full")">

        <!-- Panel Header -->
        <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50">
            <h2 class="text-lg font-bold text-slate-800">
                @(isEditing ? "Edit Configuration" : "Add New Configuration")
            </h2>
            <button @onclick="ClosePanel" class="text-slate-400 hover:text-slate-600 hover:bg-slate-200 p-2 rounded-full transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <!-- Panel Body (Scrollable Form) -->
        <div class="p-6 flex-1 overflow-y-auto">
            @if (currentConfig != null)
            {
                <div class="space-y-5">

                    <!-- Organisation Dropdown -->
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Organisation</label>
                        <select @bind="currentConfig.OrganisationId" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm bg-white">
                            <option value="">-- Select Organisation --</option>
                            @if (organisations != null)
                            {
                                @foreach (var org in organisations)
                                {
                                    <option value="@org.BusinessEntityID">@org.OrganisationName</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Value Type Dropdown -->
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Value Type</label>
                        <select @bind="currentConfig.LeaveConfigurableValueTypeId" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm bg-white">
                            <option value="0">-- Select Value Type --</option>
                            @if (valueTypes != null)
                            {
                                @foreach (var type in valueTypes)
                                {
                                    <option value="@type.LeaveConfigurableValueTypeId">@type.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Job Type Dropdown -->
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Job Type (Optional)</label>
                        <select @bind="currentConfig.JobTypeId" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm bg-white">
                            <option value="">-- All Job Types --</option>
                            @if (jobTypes != null)
                            {
                                @foreach (var job in jobTypes)
                                {
                                    <option value="@job.JobTypeId">@job.TypeName</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Value -->
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Value</label>
                        <input type="text" @bind="currentConfig.Value" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" placeholder="Enter configuration value" />
                    </div>

                    <!-- Checkboxes -->
                    <div class="pt-2">
                        <label class="flex items-center gap-3 cursor-pointer">
                            <input type="checkbox" @bind="currentConfig.IsValid" class="w-4 h-4 text-blue-600 rounded border-slate-300 focus:ring-blue-500" />
                            <span class="text-sm text-slate-700 font-medium">Is Valid Active Rule?</span>
                        </label>
                    </div>
                </div>
            }
        </div>

        <!-- Panel Footer -->
        <div class="p-4 border-t border-slate-100 bg-slate-50 flex justify-end gap-3">
            <button @onclick="ClosePanel" class="px-4 py-2 text-sm font-medium text-slate-600 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">
                Cancel
            </button>
            <button @onclick="SaveConfig" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 shadow-sm transition-colors">
                Save Configuration
            </button>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    // --- Grid Data ---
    private List<LeaveConfigurableValue>? LeaveConfigurableValues;

    // --- Dropdown Data ---
    private List<Organisation>? organisations;
    private List<LeaveConfigurableValueType>? valueTypes;
    private List<JobType>? jobTypes;

    private int? loggedInUserOrgId;

    // --- Slide Panel State ---
    private bool isPanelOpen = false;
    private bool isEditing = false;
    private LeaveConfigurableValue? currentConfig = new();

    // --- Delete Modal State ---
    private bool isDeleteModalOpen = false;
    private LeaveConfigurableValue? configToDelete;

    protected override async Task OnInitializedAsync()
    {
        // 1. Fetch user state to determine default organization
        if (AuthState is not null)
        {
            var state = await AuthState;
            var user = state.User;

            if (user.Identity is not null && user.Identity.IsAuthenticated)
            {
                var orgClaim = user.FindFirst("orgId");
                if (orgClaim != null && int.TryParse(orgClaim.Value, out int orgId))
                {
                    loggedInUserOrgId = orgId;
                }
            }
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        // Fetch Dropdown Data
        organisations = await DbContext.Organisations.OrderBy(o => o.OrganisationName).ToListAsync();
        valueTypes = await DbContext.LeaveConfigurableValueTypes.OrderBy(v => v.Name).ToListAsync();
        jobTypes = await DbContext.JobTypes.OrderBy(j => j.TypeName).ToListAsync();

        // Fetch Grid Data
        LeaveConfigurableValues = await DbContext.LeaveConfigurableValues
            .Include(lct => lct.LeaveConfigurableValueType)
            .Include(org => org.Organisation)
            .Include(jt => jt.JobType)
            .OrderBy(l => l.LeaveConfigurableValueId)
            .ToListAsync();
    }

    // --- Add/Edit Panel Actions ---
    private async Task OpenAddPanel()
    {
        isEditing = false;

        currentConfig = new LeaveConfigurableValue
            {
                OrganisationId = await _access.GetCurrentOrganisationIdAsync(),
                IsValid = true
            };

        isPanelOpen = true;
    }

    private void OpenEditPanel(LeaveConfigurableValue config)
    {
        isEditing = true;

        // Map to a new object to prevent real-time unwanted edits in the grid
        currentConfig = new LeaveConfigurableValue
            {
                LeaveConfigurableValueId = config.LeaveConfigurableValueId,
                LeaveConfigurableValueTypeId = config.LeaveConfigurableValueTypeId,
                OrganisationId = config.OrganisationId,
                JobTypeId = config.JobTypeId,
                Value = config.Value,
                IsValid = config.IsValid
            };

        isPanelOpen = true;
    }

    private void ClosePanel()
    {
        isPanelOpen = false;
    }

    private async Task SaveConfig()
    {
        if (currentConfig == null) return;

        if (isEditing)
        {
            var existing = await DbContext.LeaveConfigurableValues.FindAsync(currentConfig.LeaveConfigurableValueId);
            if (existing != null)
            {
                existing.LeaveConfigurableValueTypeId = currentConfig.LeaveConfigurableValueTypeId;
                existing.OrganisationId = currentConfig.OrganisationId;
                existing.JobTypeId = currentConfig.JobTypeId;
                existing.Value = currentConfig.Value;
                existing.IsValid = currentConfig.IsValid;
            }
        }
        else
        {
            DbContext.LeaveConfigurableValues.Add(currentConfig);
        }

        await DbContext.SaveChangesAsync();
        await LoadData();
        ClosePanel();
    }

    // --- Delete Modal Actions ---
    private void OpenDeleteModal(LeaveConfigurableValue config)
    {
        configToDelete = config;
        isDeleteModalOpen = true;
    }

    private void CloseDeleteModal()
    {
        isDeleteModalOpen = false;
        configToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (configToDelete != null)
        {
            var entity = await DbContext.LeaveConfigurableValues.FindAsync(configToDelete.LeaveConfigurableValueId);
            if (entity != null)
            {
                DbContext.LeaveConfigurableValues.Remove(entity);
                await DbContext.SaveChangesAsync();
                await LoadData(); // Refresh the grid
            }
        }
        CloseDeleteModal();
    }
}